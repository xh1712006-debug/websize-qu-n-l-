<div class="max-w-7xl mx-auto space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700">
    
    <!-- HEADER -->
    <div class="relative overflow-hidden bg-slate-900 rounded-[3rem] p-12 text-white shadow-2xl shadow-slate-200">
        <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/20 blur-[100px] rounded-full -mr-20 -mt-20"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-indigo-600/20 blur-[80px] rounded-full -ml-20 -mb-20"></div>
        
        <div class="relative flex flex-col md:flex-row items-center gap-10">
            <div class="w-32 h-32 rounded-[2.5rem] bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-5xl font-black shadow-xl ring-4 ring-white/10">
                {{substring admin.fullName 0 1}}
            </div>
            <div class="text-center md:text-left flex-1">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-md rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-4 border border-white/5">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    Hệ thống Quản trị viên
                </div>
                <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-2">{{admin.fullName}}</h1>
                <p class="text-indigo-200/70 font-medium text-lg">{{admin.email}}</p>
            </div>
            <div class="flex gap-4">
                <button class="px-8 py-4 bg-white text-slate-900 rounded-2xl font-black text-sm uppercase tracking-wider hover:bg-indigo-50 transition-all shadow-lg">Chỉnh sửa hồ sơ</button>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <!-- LEFT COL: STATS & INFO -->
        <div class="space-y-10">
            <div class="bg-white rounded-[2.5rem] border border-slate-100 p-8 shadow-sm">
                <h3 class="text-lg font-black text-slate-900 mb-6 flex items-center gap-3">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Thông tin tài khoản
                </h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Vai trò</p>
                        <p class="text-sm font-bold text-slate-700">Administrator / Superuser</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Ngày tham gia</p>
                        <p class="text-sm font-bold text-slate-700">{{formatDate admin.createdAt 'DD/MM/YYYY'}}</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Trạng thái</p>
                        <span class="inline-flex px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase">Đang hoạt động</span>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-indigo-600 to-purple-700 rounded-[2.5rem] p-8 text-white shadow-xl shadow-indigo-100">
                <div class="w-12 h-12 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                </div>
                <h3 class="text-xl font-black mb-2">Dữ liệu quan trọng</h3>
                <p class="text-indigo-100/70 text-sm font-medium mb-6">Tất cả các đồ án hoặc đợt bảo vệ bạn đã đánh dấu lưu trữ sẽ xuất hiện tại đây để truy cập nhanh.</p>
                <div class="text-4xl font-black">{{#if admin.savedProjects}}{{admin.savedProjects.length}}{{else}}0{{/if}}</div>
                <p class="text-[10px] font-black uppercase tracking-widest text-indigo-200 mt-1">Mục đã lưu</p>
            </div>
        </div>

        <!-- RIGHT COL: SAVED DATA -->
        <div class="lg:col-span-2 space-y-8">
            <div class="flex items-center justify-between mb-2">
                <h2 class="text-2xl font-black text-slate-900 tracking-tight">Hồ sơ & Dữ liệu đã lưu</h2>
                <div class="flex gap-2">
                    <button class="p-3 bg-white border border-slate-100 rounded-xl text-slate-400 hover:text-slate-900 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4.5h14.25M3 9h9.75M3 13.5h9.75m4.5-4.5v12m0 0l-3.75-3.75M17.25 21L21 17.25"></path></svg>
                    </button>
                </div>
            </div>

            {{#if admin.savedProjects}}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {{#each admin.savedProjects}}
                <div class="group bg-white rounded-[2rem] border border-slate-100 p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="flex items-start justify-between mb-4">
                        <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-lg text-[8px] font-black uppercase tracking-widest">{{this.major}}</span>
                        <button onclick="unsaveProject('{{this._id}}')" class="text-slate-300 hover:text-rose-500 transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                        </button>
                    </div>
                    <h4 class="font-black text-slate-900 mb-4 line-clamp-2">{{this.inputProject}}</h4>
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-[10px] font-bold text-slate-500">
                            {{substring this.teacherInstruct 0 1}}
                        </div>
                        <div>
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">Giảng viên</p>
                            <p class="text-[11px] font-bold text-slate-700">{{this.teacherInstruct}}</p>
                        </div>
                    </div>
                    <a href="/admin/archive/period/{{this.periodId}}" class="w-full py-3 bg-slate-50 text-slate-600 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-slate-900 hover:text-white transition-all text-center block">Xem chi tiết</a>
                </div>
                {{/each}}
            </div>
            {{else}}
            <div class="bg-white rounded-[3rem] border border-dashed border-slate-200 p-20 text-center">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl opacity-30">🔖</div>
                <h3 class="text-xl font-black text-slate-900">Danh sách trống</h3>
                <p class="text-slate-500 font-medium mt-2 max-w-xs mx-auto">Bạn chưa lưu bất kỳ đồ án nào. Hãy nhấn biểu tượng lưu tại kho lưu trữ để đánh dấu các mục quan trọng.</p>
                <a href="/admin/archive" class="inline-block mt-8 px-8 py-4 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-blue-600 transition-all">Đi tới kho lưu trữ</a>
            </div>
            {{/if}}
        </div>
    </div>
</div>

<script>
    async function unsaveProject(id) {
        if (!confirm('Bạn có muốn xóa mục này khỏi danh sách lưu trữ cá nhân?')) return;
        
        try {
            const res = await fetch(`/admin/account/unsave-project/${id}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                location.reload();
            }
        } catch (err) {
            console.error(err);
        }
    }
</script>
