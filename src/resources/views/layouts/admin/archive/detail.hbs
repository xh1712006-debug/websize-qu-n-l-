<div class="space-y-8 animate-in fade-in slide-in-from-bottom-8 duration-1000">
    
    <!-- TOP NAVIGATION & SEARCH (GLASSMORPHISM) -->
    <div class="sticky top-0 z-40 bg-white/80 backdrop-blur-xl border-b border-slate-200/50 -mx-8 px-8 py-6 mb-8 transition-all">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex items-center gap-6">
                <a href="/admin/archive" class="group flex items-center justify-center w-12 h-12 bg-slate-900 rounded-2xl text-white hover:bg-blue-600 transition-all shadow-lg shadow-slate-200">
                    <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </a>
                <div>
                    <div class="flex items-center gap-2 mb-1">
                        <span class="px-2 py-0.5 bg-blue-100 text-blue-700 rounded text-[8px] font-black uppercase tracking-widest">Archive Inspector</span>
                        <span class="text-slate-300 text-xs">/</span>
                        <span class="text-slate-400 font-bold text-[10px] uppercase tracking-widest">{{period.semester}}</span>
                    </div>
                    <h1 class="text-2xl font-black text-slate-900 tracking-tight leading-none">{{period.name}}</h1>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <!-- SEARCH -->
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                        <svg class="w-4 h-4 text-slate-400 group-focus-within:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input type="text" id="archive-search" oninput="handleSearch(this.value)" placeholder="Tìm đề tài, mã SV, họ tên..." 
                        class="w-full md:w-80 pl-12 pr-6 py-3.5 bg-slate-50 border border-transparent focus:bg-white focus:border-blue-500 rounded-2xl outline-none transition-all font-bold text-slate-700 text-xs shadow-inner">
                </div>
                <!-- EXPORT (Placeholder) -->
                <button class="hidden md:flex items-center gap-2 px-5 py-3.5 bg-white border border-slate-200 rounded-2xl font-black text-[10px] uppercase tracking-widest text-slate-600 hover:bg-slate-50 transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    Xuất báo cáo
                </button>
            </div>
        </div>
    </div>

    <!-- TABS NAVIGATION (MODERN) -->
    <div class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-2">
        <button onclick="filterByCategory('all')" data-category="all" class="tab-btn px-8 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all bg-slate-900 text-white shadow-xl shadow-slate-200">
            Tất cả Ngành
        </button>
        {{#each majors}}
        <button onclick="filterByCategory('{{this}}')" data-category="{{this}}" class="tab-btn px-8 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all text-slate-400 hover:bg-white hover:text-slate-900 border border-transparent hover:border-slate-100 whitespace-nowrap">
            {{this}}
        </button>
        {{/each}}
    </div>

    <!-- PROJECT GRID -->
    <div id="archive-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 relative z-10">
        <!-- Loading Spinner -->
        <div class="col-span-full py-40 text-center">
            <div class="w-16 h-16 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-6"></div>
            <p class="text-slate-400 font-black uppercase tracking-widest text-xs">Đang truy xuất dữ liệu từ kho lưu trữ...</p>
        </div>
    </div>
</div>

<script>
    let archivedData = [];
    let currentCategory = 'all';
    let searchQuery = '';

    async function fetchArchive() {
        const fetchUrl = '/admin/archive/api/projects/{{period._id}}';
        try {
            const res = await fetch(fetchUrl);
            const text = await res.text();
            
            let data;
            try {
                data = JSON.parse(text);
            } catch (e) {
                console.error('Invalid JSON response:', text);
                throw new Error(`Phản hồi không phải JSON (Status: ${res.status}). URL: ${fetchUrl}`);
            }
            
            if (res.ok) {
                archivedData = data;
                renderArchive();
            } else {
                throw new Error(data.message || data.error || `Lỗi HTTP: ${res.status}`);
            }
        } catch (err) {
            console.error('Fetch Error:', err);
            document.getElementById('archive-grid').innerHTML = `
                <div class="col-span-full py-40 text-center">
                    <div class="w-20 h-20 bg-rose-50 rounded-full flex items-center justify-center mx-auto mb-6 text-rose-400 text-3xl">⚠️</div>
                    <h3 class="text-xl font-black text-slate-900 mb-2">Lỗi truy xuất dữ liệu</h3>
                    <p class="text-rose-500 font-medium text-xs break-all">${err.message}</p>
                    <p class="mt-4 text-[10px] text-slate-400 uppercase font-black tracking-widest cursor-pointer hover:text-blue-600" onclick="location.reload()">Thử lại</p>
                </div>`;
        }
    }

    function filterByCategory(cat) {
        currentCategory = cat;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            if (btn.dataset.category === cat) {
                btn.classList.add('bg-slate-900', 'text-white', 'shadow-xl', 'shadow-slate-200');
                btn.classList.remove('text-slate-400', 'hover:bg-white', 'hover:text-slate-900', 'border-transparent');
            } else {
                btn.classList.remove('bg-slate-900', 'text-white', 'shadow-xl', 'shadow-slate-200');
                btn.classList.add('text-slate-400', 'hover:bg-white', 'hover:text-slate-900', 'border-transparent');
            }
        });
        renderArchive();
    }

    function handleSearch(q) {
        searchQuery = q.trim().toLowerCase();
        renderArchive();
    }

    function renderArchive() {
        const container = document.getElementById('archive-grid');
        if (!container) return;
        container.innerHTML = '';

        const filtered = archivedData.filter(p => {
            const matchCat = currentCategory === 'all' || p.major === currentCategory;
            const matchSearch = !searchQuery || 
                (p.inputProject && p.inputProject.toLowerCase().includes(searchQuery)) ||
                (p.students && p.students.some(s => s.fullName.toLowerCase().includes(searchQuery) || s.studentCode.toLowerCase().includes(searchQuery)));
            return matchCat && matchSearch;
        });

        if (filtered.length === 0) {
            container.innerHTML = `
                <div class="col-span-full py-40 text-center">
                    <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-8 text-slate-200">
                        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-black text-slate-900 mb-2 uppercase tracking-tight">Không có bản ghi phù hợp</h3>
                    <p class="text-slate-400 font-medium">Vui lòng thử lại với từ khóa khác hoặc thay đổi chuyên ngành.</p>
                </div>`;
            return;
        }

        filtered.forEach((p, index) => {
            const card = document.createElement('div');
            card.className = 'group relative bg-white rounded-[3rem] border border-slate-100 p-8 shadow-sm hover:shadow-2xl hover:shadow-slate-200/50 transition-all duration-500 animate-in fade-in slide-in-from-bottom-6';
            card.style.animationDelay = `${index * 50}ms`;

            card.innerHTML = `
                <!-- PROJECT INFO -->
                <div class="mb-8 relative z-10">
                    <div class="flex items-center justify-between mb-4">
                        <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-lg text-[9px] font-black uppercase tracking-widest border border-blue-100">${p.major || 'KỸ THUẬT PHẦN MỀM'}</span>
                        <button onclick="toggleSaveProject('${p._id}', this)" class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 hover:bg-blue-600 hover:text-white transition-all shadow-sm group/save">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                        </button>
                    </div>
                    <h3 class="text-xl font-black text-slate-900 leading-tight line-clamp-2 group-hover:text-blue-600 transition-colors">${p.inputProject}</h3>
                </div>

                <!-- ADVISOR INFO -->
                <div class="p-5 bg-slate-50/50 rounded-3xl border border-slate-100/50 mb-8 flex items-center gap-4 group-hover:bg-white group-hover:shadow-inner transition-all duration-500">
                    <div class="w-10 h-10 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 text-xs font-black">GV</div>
                    <div>
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Giảng viên hướng dẫn</p>
                        <p class="text-xs font-black text-slate-700 tracking-tight">${p.teacherInstruct}</p>
                    </div>
                </div>

                <!-- STUDENT RESULTS -->
                <div class="space-y-3">
                    <p class="px-2 text-[9px] font-black text-slate-300 uppercase tracking-widest">Danh sách Sinh viên & Kết quả</p>
                    ${p.students && p.students.length > 0 ? p.students.map(s => `
                        <div class="relative p-5 bg-white rounded-3xl border border-slate-100 shadow-sm hover:border-blue-200 transition-all group/student overflow-hidden">
                            <div class="absolute top-0 right-0 p-2 opacity-10 group-hover/student:opacity-100 transition-opacity">
                                <svg class="w-3 h-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0z"></path></svg>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <div class="min-w-0">
                                    <p class="text-xs font-black text-slate-900 truncate mb-1">${s.fullName}</p>
                                    <div class="flex items-center gap-1.5">
                                        <span class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">${s.studentCode}</span>
                                        <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                                        <span class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">${s.studentClass || 'N/A'}</span>
                                    </div>
                                </div>
                                <div class="flex flex-col items-end">
                                    <div class="px-3 py-1 ${s.badgeClass || 'bg-slate-100 text-slate-600'} rounded-xl text-[10px] font-black shadow-sm text-center min-w-[70px] transition-all group-hover/student:scale-105">
                                        ${s.finalScore}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('') : `
                        <div class="p-6 bg-rose-50/30 rounded-3xl border border-dashed border-rose-100 text-center">
                            <p class="text-[10px] font-bold text-rose-400 uppercase tracking-widest italic">Hồ sơ sinh viên bị khuyết</p>
                        </div>
                    `}
                </div>
            `;
            container.appendChild(card);
        });
    }

    async function toggleSaveProject(id, btn) {
        try {
            const res = await fetch(`/admin/account/save-project/${id}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                btn.classList.add('bg-blue-600', 'text-white');
                btn.querySelector('svg').setAttribute('fill', 'currentColor');
                btn.onclick = () => unsaveProjectFromArchive(id, btn);
            }
        } catch (err) { console.error(err); }
    }

    async function unsaveProjectFromArchive(id, btn) {
        try {
            const res = await fetch(`/admin/account/unsave-project/${id}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                btn.classList.remove('bg-blue-600', 'text-white');
                btn.querySelector('svg').setAttribute('fill', 'none');
                btn.onclick = () => toggleSaveProject(id, btn);
            }
        } catch (err) { console.error(err); }
    }

    document.addEventListener('DOMContentLoaded', fetchArchive);
</script>
