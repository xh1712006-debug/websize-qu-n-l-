<div class="space-y-12 animate-in fade-in slide-in-from-bottom-8 duration-1000">
    
    <!-- DASHBOARD HEADER -->
    <div class="relative overflow-hidden bg-slate-900 rounded-[3rem] p-12 text-white shadow-2xl shadow-slate-300">
        <!-- Background Decoration -->
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-64 h-64 bg-indigo-500/10 rounded-full blur-[80px]"></div>

        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-10">
            <div class="space-y-4">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 rounded-full border border-white/10 backdrop-blur-md">
                    <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-blue-200">Digital Archive Hub</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black tracking-tight leading-tight">
                    Kho Lưu trữ <br> <span class="text-blue-400 italic">Hồ sơ Đồ án</span>
                </h1>
                <p class="max-w-md text-slate-400 font-medium text-sm leading-relaxed">
                    Hệ thống lưu trữ lịch sử đồ án tốt nghiệp qua các năm. Đảm bảo tính toàn vẹn và dễ dàng tra cứu cho công tác kiểm định.
                </p>
            </div>

            <!-- QUICK STATS -->
            <div class="grid grid-cols-2 gap-4 w-full md:w-auto">
                <div class="p-6 bg-white/5 rounded-3xl border border-white/5 backdrop-blur-xl">
                    <p class="text-3xl font-black text-white mb-1">{{periods.length}}</p>
                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Đợt đã đóng</p>
                </div>
                <div class="p-6 bg-blue-600 rounded-3xl shadow-lg shadow-blue-900/20">
                    <div class="w-8 h-8 bg-white/20 rounded-xl flex items-center justify-center mb-3 text-white text-lg">📁</div>
                    <p class="text-[9px] font-black text-blue-100 uppercase tracking-widest">An toàn & Bảo mật</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ARCHIVE TIMELINE / GRID -->
    <div class="space-y-8">
        <div class="flex items-center justify-between px-4">
            <h2 class="text-xl font-black text-slate-900 tracking-tight flex items-center gap-3">
                <span class="w-1.5 h-8 bg-blue-600 rounded-full"></span>
                Danh sách Đợt bảo vệ
            </h2>
            <div class="text-xs font-bold text-slate-400 uppercase tracking-widest">Sắp xếp: Mới nhất</div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
            {{#each periods}}
            <div class="group relative bg-white rounded-[2.5rem] border border-slate-100 p-8 shadow-sm hover:shadow-2xl hover:shadow-slate-200/50 transition-all duration-500 overflow-hidden">
                <!-- Hover Decoration -->
                <div class="absolute -right-10 -top-10 w-32 h-32 bg-slate-50 rounded-full group-hover:bg-blue-50 transition-colors duration-500"></div>

                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-8">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-xl group-hover:bg-slate-900 group-hover:text-white transition-all duration-500">
                                {{#if (eq this.semester 'Học kỳ 1')}}❄️{{else if (eq this.semester 'Học kỳ 2')}}☀️{{else}}🍂{{/if}}
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-0.5">{{this.year}}</p>
                                <p class="text-[11px] font-black text-slate-900 uppercase">{{this.semester}}</p>
                            </div>
                        </div>
                        <div class="w-2 h-2 rounded-full bg-slate-300 group-hover:bg-blue-500 transition-colors"></div>
                    </div>

                    <h3 class="text-2xl font-black text-slate-900 mb-2 leading-tight group-hover:text-blue-600 transition-colors">{{this.name}}</h3>
                    <p class="text-[11px] font-bold text-slate-400 flex items-center gap-2 mb-10">
                        <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        {{this.dateRange}}
                    </p>

                    <div class="pt-8 border-t border-slate-50 flex items-center justify-between">
                        <div class="space-y-1">
                            <p class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Cơ sở dữ liệu</p>
                            <p class="text-[10px] font-black text-emerald-600 flex items-center gap-1.5">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                ĐÃ NIÊM PHONG
                            </p>
                        </div>
                        <a href="/admin/archive/period/{{this._id}}" class="px-6 py-3.5 bg-slate-900 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-blue-600 hover:-translate-y-1 transition-all shadow-xl shadow-slate-200">
                            TRUY XUẤT
                        </a>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="col-span-full py-40 text-center bg-white rounded-[4rem] border-2 border-dashed border-slate-100 relative overflow-hidden">
                <div class="absolute inset-0 bg-slate-50/30 opacity-50"></div>
                <div class="relative z-10 max-w-sm mx-auto">
                    <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-8 text-5xl">📦</div>
                    <h3 class="text-2xl font-black text-slate-900 tracking-tight">Chưa có dữ liệu lịch sử</h3>
                    <p class="text-slate-400 font-medium mt-3 text-sm">Hồ sơ sẽ tự động được đóng gói và lưu trữ tại đây sau khi bạn kết thúc một đợt bảo vệ hiện hành.</p>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</div>
