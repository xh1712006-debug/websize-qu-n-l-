<div class="space-y-8 animate-in fade-in slide-in-from-bottom-6 duration-700 pb-10">

    <!-- HEADER -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Nhật ký Hệ thống</h1>
            <p class="text-slate-500 font-medium mt-1">Theo dõi toàn bộ hoạt động quản trị và thay đổi dữ liệu</p>
        </div>
        <div class="flex gap-3">
             <button onclick="location.reload()" class="p-4 bg-white border border-slate-100 rounded-2xl text-slate-400 hover:text-blue-600 transition-all shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
             </button>
        </div>
    </div>

    <!-- LOGS LIST -->
    <div class="space-y-4">
        {{#each logs}}
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-md transition-all group relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full {{#if (eq this.action 'DELETE_STUDENT')}}bg-rose-500{{else if (eq this.action 'UNLOCK_POINT')}}bg-amber-500{{else}}bg-blue-500{{/if}}"></div>
            
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <!-- User Info -->
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-xl">
                        {{#if (eq this.userRole 'Admin')}}🛡️{{else}}👤{{/if}}
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="font-black text-slate-900 text-sm tracking-tight">{{this.userRole}}</span>
                            <span class="text-[10px] font-bold px-2 py-0.5 bg-slate-100 text-slate-400 rounded-full uppercase tracking-tighter">{{this.userId}}</span>
                        </div>
                        <p class="text-xs font-bold text-blue-600 mt-0.5">{{this.action}}</p>
                    </div>
                </div>

                <!-- Action Details -->
                <div class="flex-1 max-w-xl">
                    <p class="text-sm font-medium text-slate-600 leading-relaxed italic">"${this.reason}"</p>
                    {{#if this.details}}
                    <div class="mt-2 text-[10px] font-mono text-slate-400 bg-slate-50 p-2 rounded-lg line-clamp-1 group-hover:line-clamp-none transition-all">
                        Target: {{json this.details}}
                    </div>
                    {{/if}}
                </div>

                <!-- Timestamp -->
                <div class="text-right">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{dateFormat this.createdAt}}</p>
                    <div class="flex items-center justify-end gap-1 mt-1">
                        <span class="w-2 h-2 rounded-full {{#if (eq this.action 'DELETE_STUDENT')}}bg-rose-500{{else}}bg-emerald-500{{/if}} animate-pulse"></span>
                        <span class="text-[9px] font-black text-slate-500 uppercase tracking-tighter">Verified</span>
                    </div>
                </div>
            </div>
        </div>
        {{else}}
        <div class="py-24 text-center bg-white rounded-[3rem] border border-slate-100 border-dashed">
            <div class="text-6xl mb-6 opacity-20">📜</div>
            <h3 class="text-xl font-black text-slate-400 uppercase tracking-widest">Chưa có nhật ký hoạt động</h3>
        </div>
        {{/each}}
    </div>

</div>
