<div class="space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700 pb-20">

    <!-- PAGE HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-blue-600 rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-blue-100">
                ➕
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Thêm Đề tài Mới</h1>
                <p class="text-slate-500 font-medium mt-1">Thiết lập thông tin chi tiết cho đồ án tốt nghiệp học kỳ mới</p>
            </div>
        </div>
        
        <a href="/admin/project" class="px-6 py-3 bg-white border border-slate-200 rounded-2xl text-[10px] font-black text-slate-500 uppercase tracking-widest hover:bg-slate-50 transition-colors shadow-sm">
            Quay lại kho đồ án
        </a>
    </div>

    <!-- MAIN FORM CARD -->
    <div class="bg-white rounded-[3.5rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div class="absolute top-0 right-0 w-80 h-80 bg-blue-50 rounded-full -mr-40 -mt-40 opacity-40"></div>
        
        <form class="relative z-10 p-10 md:p-14 space-y-12">
            
            <!-- SECTION 1: BASIC INFO -->
            <div class="space-y-8">
                <h2 class="text-[10px] font-black text-blue-500 uppercase tracking-[0.2em] flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span>
                    Thông tin Cơ bản
                </h2>
                
                <div class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên đề tài đồ án</label>
                        <input type="text" placeholder="VD: Xây dựng hệ thống quản lý năng lượng thông minh..."
                            class="input__project w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-5 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                    </div>
                    
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mô tả chi tiết nội dung</label>
                        <textarea rows="4" placeholder="Mô tả các tính năng chính, phạm vi nghiên cứu..."
                            class="content__project w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-5 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner resize-none"></textarea>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                
                <!-- SECTION 2: TECHNICAL & REQUIREMENTS -->
                <div class="space-y-10">
                    <div class="space-y-6">
                        <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                            <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span>
                            Kỹ thuật & Yêu cầu
                        </h2>
                        
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Công nghệ đề xuất</label>
                                <input type="text" placeholder="VD: NodeJS, React, Flutter, AWS..."
                                    class="technology w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                            </div>

                            <div class="space-y-3">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Danh sách yêu cầu cụ thể</label>
                                <div id="requirementList" class="space-y-3">
                                    <!-- Dynamic rows from script -->
                                </div>
                                <button type="button" onclick="addRequirement()"
                                    class="w-full py-3 border-2 border-dashed border-slate-200 rounded-xl text-[9px] font-black text-slate-400 uppercase tracking-widest hover:border-blue-300 hover:text-blue-500 transition-all flex items-center justify-center gap-2">
                                    <span>+ Thêm dòng yêu cầu</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 3: STAFF & CAPACITY -->
                <div class="space-y-10">
                    <div class="space-y-6">
                        <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                            <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span>
                            Điều phối & Giới hạn
                        </h2>
                        
                        <div class="space-y-4">
                            <div class="grid grid-cols-1 gap-4">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Giảng viên hướng dẫn</label>
                                    <select class="teacher__instruct w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                        <!-- Dynamic options -->
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Giảng viên phản biện</label>
                                    <select class="teacher__feedback w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                        <!-- Dynamic options -->
                                    </select>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">SL Sinh viên tối đa</label>
                                    <input type="number" min="1" placeholder="10"
                                        class="number__student w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Hạn đăng ký</label>
                                    <input type="date"
                                        class="date w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                                </div>
                            </div>

                            <div class="space-y-2">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Trạng thái phát hành</label>
                                <select class="status w-full bg-emerald-50 border-2 border-transparent focus:border-emerald-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-emerald-700 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                    <option value="Mở">Đang mở đăng ký</option>
                                    <option value="Đóng">Tạm đóng đăng ký</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ACTION BUTTONS -->
            <div class="pt-10 border-t border-slate-50 flex flex-col md:flex-row gap-4">
                <button type="submit" class="submit flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-5 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-blue-100 transition-all hover:-translate-y-1 active:translate-y-0">
                    LƯU VÀ PHÁT HÀNH ĐỀ TÀI
                </button>
                <button type="reset" class="px-10 bg-slate-100 text-slate-500 py-5 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] hover:bg-slate-200 transition-colors">
                    LÀM MỚI
                </button>
            </div>

        </form>
    </div>

</div>

<script>
    function addRequirement(value = "") {
        const list = document.getElementById("requirementList");
        const div = document.createElement("div");
        div.className = "flex gap-2 group/item animate-in fade-in slide-in-from-left-2 duration-300";
        div.innerHTML = `
            <input type="text" value="${value}" placeholder="Nhập yêu cầu..."
                class="requirementText flex-1 bg-white border-2 border-slate-100 rounded-xl px-4 py-3 text-xs font-bold text-slate-600 focus:border-blue-500 outline-none transition-all shadow-sm">
            <button type="button" onclick="this.parentElement.remove()"
                class="w-11 h-11 bg-rose-50 text-rose-500 rounded-xl flex items-center justify-center hover:bg-rose-500 hover:text-white transition-all shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
        `;
        list.appendChild(div);
    }
    // Khởi tạo dòng đầu nếu list trống
    window.onload = () => {
        if(document.getElementById("requirementList").children.length === 0) addRequirement();
    }
</script>
