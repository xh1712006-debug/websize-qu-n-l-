<div class="min-h-screen bg-gray-50 py-10 px-4">

  <!-- WRAPPER -->
  <div class="max-w-4xl mx-auto">

    <!-- HEADER -->
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-bold text-gray-800">
        ➕ Thêm đồ án tốt nghiệp        
      </h2>
      <p class="text-gray-500 text-sm mt-2">
        Nhập thông tin chi tiết để tạo đồ án mới
      </p>
    </div>

    <!-- FORM CARD -->
    <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100">

      <form class="space-y-8">

        <!-- TÊN ĐỒ ÁN -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-3">
            Tên đồ án
          </label>
          <input 
            type="text"
            placeholder="Nhập tên đồ án..."
            class="input__project w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition">
        </div>

        <!-- MÔ TẢ -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-3">
            Mô tả
          </label>
          <textarea
            rows="4"
            placeholder="Nhập mô tả đồ án..."
            class="content__project w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition"></textarea>
        </div>

        <!-- GIẢNG VIÊN -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <!-- GVHD -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-3">
              Giảng viên hướng dẫn
            </label>
            <select class="teacher__instruct w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition">
              {{!-- <option>Chọn giảng viên</option>
              <option>Nguyễn Văn C</option>
              <option>Trần Văn D</option> --}}
            </select>
          </div>

          <!-- GVPB -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-3">
              Giảng viên phản biện
            </label>
            <select class="teacher__feedback w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition">
              {{!-- <option>Chọn giảng viên</option>
              <option>Phạm Văn E</option>
              <option>Lê Văn F</option> --}}
            </select>
          </div>

        </div>

        <!-- SỐ LƯỢNG + DEADLINE -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <!-- MAX STUDENT -->
          <div>
            <label class=" block text-sm font-semibold text-gray-700 mb-3">
              Số sinh viên tối đa
            </label>
            <input 
              type="number"
              min="1"
              placeholder="Ví dụ: 10"
              class="number__student w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition">
          </div>

          <!-- DEADLINE -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-3">
              Deadline đăng ký
            </label>
            <input 
              type="date"
              class="date w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition">
          </div>

        </div>

        <!-- TRẠNG THÁI -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-3">
            Trạng thái
          </label>
          <select class="status w-full border border-gray-300 rounded-xl px-5 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none transition">
            <option value="open">Đang mở đăng ký</option>
            <option value="closed">Đóng đăng ký</option>
          </select>
        </div>

        <!-- BUTTON -->
        <div class="flex justify-end gap-4 pt-6 border-t">

          <button type="button"
            class="px-6 py-2 rounded-xl border border-gray-300 text-gray-600 hover:bg-gray-100 transition">
            Hủy
          </button>

          <button type="submit"
            class="submit bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl shadow-lg transition">
            💾 Lưu đồ án
          </button>

        </div>

      </form>

    </div>

  </div>

</div>

<!-- DANH SÁCH ĐỒ ÁN ADMIN ĐÃ TẠO -->