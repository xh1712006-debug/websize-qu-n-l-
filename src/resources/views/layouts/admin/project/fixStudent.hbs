<div class="mt-12 max-w-4xl mx-auto">

  <div class="mb-8">
    <h2 class="text-3xl font-bold text-gray-800">
      ✏️ Sửa đồ án
    </h2>
    <p class="text-gray-500 mt-2">
      Cập nhật thông tin đồ án bên dưới
    </p>
  </div>

  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">

    <form id="editForm">
      <div class="fix__form p-6 space-y-6">

        <div>
          <label class="block text-sm font-medium mb-2">📚 Tên đồ án</label>
          <input type="text" id="inputProject"
                 class="w-full border rounded-xl px-4 py-2">
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">📝 Nội dung</label>
          <textarea id="contentProject"
                    rows="4"
                    class="w-full border rounded-xl px-4 py-2"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">👨‍🏫 Giảng viên</label>
          <input type="text" id="teacherInstruct"
                 class="w-full border rounded-xl px-4 py-2">
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">👥 Số sinh viên</label>
          <input type="number" id="numberStudent"
                 class="w-full border rounded-xl px-4 py-2">
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">📅 Ngày bắt đầu</label>
          <input type="date" id="date"
                 class="w-full border rounded-xl px-4 py-2">
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">🔄 Trạng thái</label>
          <select id="statuss"
                  class="w-full border rounded-xl px-4 py-2">
            <option value="open">đang open</option>
            <option value="close">đang close</option>
          </select>
        </div>

      </div>

      <div class="bg-gray-50 px-6 py-4 flex justify-end space-x-3">
        <button type="submit"
                class="submit px-5 py-2 rounded-lg bg-blue-600 text-white">
          💾 Cập nhật
        </button>
      </div>

    </form>

  </div>
</div>
