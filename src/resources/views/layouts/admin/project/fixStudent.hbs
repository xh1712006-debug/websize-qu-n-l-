<div class="space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700 pb-20 max-w-4xl mx-auto">

    <!-- PAGE HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-amber-500 rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-amber-100">
                ✏️
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Cập nhật Đồ án</h1>
                <p class="text-slate-500 font-medium mt-1">Chỉnh sửa thông số, người hướng dẫn hoặc trạng thái của đề tài</p>
            </div>
        </div>
        
        <a href="/admin/project" class="px-6 py-3 bg-white border border-slate-200 rounded-2xl text-[10px] font-black text-slate-500 uppercase tracking-widest hover:bg-slate-50 transition-colors shadow-sm">
            Quay lại kho đồ án
        </a>
    </div>

    <!-- MAIN FORM CARD -->
    <div class="bg-white rounded-[3.5rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div class="absolute top-0 right-0 w-80 h-80 bg-amber-50 rounded-full -mr-40 -mt-40 opacity-40"></div>
        
        <form id="editForm" class="relative z-10">
            <div class="fix__form p-10 md:p-14 space-y-8">

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên đồ án (Đề tài)</label>
                    <input type="text" id="inputProject" placeholder="Nhập tên đồ án..."
                        class="w-full bg-slate-50 border-2 border-transparent focus:border-amber-500 focus:bg-white rounded-2xl p-5 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nội dung tóm tắt</label>
                    <textarea id="contentProject" rows="4" placeholder="Mô tả nội dung đồ án..."
                        class="w-full bg-slate-50 border-2 border-transparent focus:border-amber-500 focus:bg-white rounded-2xl p-5 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner resize-none"></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Giảng viên phụ trách</label>
                        <input type="text" id="teacherInstruct" placeholder="Tên giảng viên..."
                            class="w-full bg-slate-50 border-2 border-transparent focus:border-amber-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Số lượng sinh viên tối đa</label>
                        <input type="number" id="numberStudent"
                            class="w-full bg-slate-50 border-2 border-transparent focus:border-amber-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Ngày bắt đầu / Cập nhật</label>
                        <input type="date" id="date"
                            class="w-full bg-slate-50 border-2 border-transparent focus:border-amber-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Trạng thái hiện tại</label>
                        <select id="statuss" class="w-full bg-slate-50 border-2 border-transparent focus:border-amber-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                            <option value="open">Đang Mở (Open)</option>
                            <option value="close">Đã Đóng (Closed)</option>
                        </select>
                    </div>
                </div>

            </div>

            <!-- FORM FOOTER -->
            <div class="bg-slate-50 px-10 md:px-14 py-8 flex justify-center border-t border-slate-100">
                <button type="submit" class="submit w-full md:w-auto px-16 py-4 bg-gradient-to-r from-amber-500 to-orange-600 text-white rounded-[2rem] font-black text-xs uppercase tracking-widest shadow-xl shadow-amber-100 transition-all hover:-translate-y-1 active:translate-y-0">
                    LƯU THAY ĐỔI ĐỀ TÀI
                </button>
            </div>

        </form>
    </div>

</div>
