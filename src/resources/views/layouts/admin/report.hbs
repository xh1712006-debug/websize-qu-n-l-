<div class="bg-white p-8 rounded-2xl shadow-xl max-w-2xl mx-auto border border-gray-100">

  <!-- Title -->
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-800">
      📢 Gửi thông báo
    </h2>
  </div>

  <!-- Form -->
  <form id="notificationForm" class="space-y-4">

    <!-- Title -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Tiêu đề
      </label>
      <input type="text"
             id="title"
             required
             placeholder="Nhập tiêu đề thông báo..."
             class="w-full border border-gray-300 px-4 py-2 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
    </div>

    <!-- Receiver -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Gửi đến
      </label>
      <select class="w-full border border-gray-300 px-4 py-2 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
        <option value="">-- Chọn đối tượng --</option>
        <option>Sinh viên</option>
        <option>Giảng viên</option>
        <option>Tất cả</option>
      </select>
    </div>

    <!-- Priority -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Mức độ
      </label>
      <select class="w-full border border-gray-300 px-4 py-2 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
        <option>Bình thường</option>
        <option>Quan trọng</option>
        <option>Khẩn cấp</option>
      </select>
    </div>

    <!-- Content -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Nội dung
      </label>
      <textarea
        id="content"
        required
        rows="5"
        placeholder="Nhập nội dung thông báo..."
        class="w-full border border-gray-300 px-4 py-2 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition"></textarea>
    </div>

    <!-- Attachment -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Đính kèm (tùy chọn)
      </label>
      <input type="file"
             class="w-full border border-gray-300 px-3 py-2 rounded-xl bg-gray-50">
    </div>

    <!-- Buttons -->
    <div class="flex justify-end gap-3 pt-4">
      <button type="reset"
              class="px-5 py-2 rounded-xl border border-gray-300 hover:bg-gray-100 transition">
        Hủy
      </button>

      <button type="submit"
              class="px-6 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 shadow-md transition">
        🚀 Gửi thông báo
      </button>
    </div>

  </form>

</div>


<script>
document.getElementById("notificationForm").addEventListener("submit", function(e) {
  e.preventDefault();

  const title = document.getElementById("title").value.trim();
  const content = document.getElementById("content").value.trim();

  if (!title || !content) {
    alert("Vui lòng nhập đầy đủ tiêu đề và nội dung!");
    return;
  }

  alert("Thông báo đã được gửi thành công!");
  this.reset();
});
</script>
