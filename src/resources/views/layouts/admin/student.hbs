<div class="space-y-8 animate-in fade-in slide-in-from-bottom-6 duration-700">

    <!-- PAGE HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-blue-100">
                🎓
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Quản lý Sinh viên</h1>
                <p class="text-slate-500 font-medium mt-1 uppercase text-[10px] tracking-[0.2em]">Hồ sơ sinh viên & Trạng thái đồ án</p>
            </div>
        </div>
        
        <!-- SEARCH BAR -->
        <div class="relative w-full md:w-96 group">
            <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-slate-400 group-focus-within:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
            <input type="text" id="student-search" placeholder="Tìm theo mã SV hoặc tên..." 
                class="w-full pl-14 pr-6 py-4 bg-white border border-slate-200 rounded-2xl outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-50 transition-all font-bold text-slate-700 shadow-sm text-sm">
        </div>
    </div>

    <!-- TABS NAVIGATION (MAJOR) -->
    <div class="flex items-center gap-2 overflow-x-auto pb-4 no-scrollbar border-b border-slate-100">
        <button onclick="filterByMajor('all')" data-major="all" class="major-tab-btn px-6 py-3 rounded-xl font-black text-[11px] uppercase tracking-wider transition-all bg-slate-900 text-white shadow-lg shadow-slate-200">
            Tất cả Ngành
        </button>
        {{#each majors}}
        <button onclick="filterByMajor('{{this}}')" data-major="{{this}}" class="major-tab-btn px-6 py-3 rounded-xl font-black text-[11px] uppercase tracking-wider transition-all text-slate-500 hover:bg-slate-100 whitespace-nowrap">
            {{this}}
        </button>
        {{/each}}
    </div>

    <!-- TABS NAVIGATION (STATUS) -->
    <div class="flex items-center gap-4 bg-slate-50/50 p-2 rounded-2xl border border-slate-100">
        <button onclick="filterByStatus('all')" data-status="all" class="status-tab-btn flex-1 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all bg-white text-blue-600 shadow-sm border border-blue-100">
            Tất cả Trạng thái
        </button>
        <button onclick="filterByStatus('approved')" data-status="approved" class="status-tab-btn flex-1 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-400 hover:text-slate-600">
            Đang thực hiện
        </button>
        <button onclick="filterByStatus('pending')" data-status="pending" class="status-tab-btn flex-1 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-400 hover:text-slate-600">
            Đang chờ duyệt
        </button>
        <button onclick="filterByStatus('none')" data-status="none" class="status-tab-btn flex-1 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-400 hover:text-slate-600">
            Chưa đăng ký
        </button>
    </div>

    <!-- CARDS GRID -->
    <div id="student-cards-container" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 relative z-10">
        <!-- Loaded via AJAX as Cards -->
    </div>
</div>

<!-- MODAL STUDENT (CREATE/EDIT) -->
<div id="modal-student" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[60] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-[2.5rem] shadow-2xl w-full max-w-lg mx-4 overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="p-8 border-b border-slate-100 flex justify-between items-center">
            <h3 id="modal-title" class="text-2xl font-black text-slate-900 tracking-tight">Thêm sinh viên mới</h3>
            <button onclick="closeModal()" class="w-10 h-10 rounded-full hover:bg-slate-100 flex items-center justify-center transition-colors text-slate-400">×</button>
        </div>
        
        <form id="form-student" class="p-8 space-y-6">
            <input type="hidden" id="student-id">
            
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mã sinh viên</label>
                    <input type="text" id="input-code" required placeholder="VD: SV001" 
                        class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 rounded-2xl outline-none transition-all font-bold text-slate-700">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Họ và tên</label>
                    <input type="text" id="input-name" required placeholder="VD: Nguyễn Văn A" 
                        class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 rounded-2xl outline-none transition-all font-bold text-slate-700">
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Email sinh viên</label>
                <input type="email" id="input-email" required placeholder="example@student.com" 
                    class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 rounded-2xl outline-none transition-all font-bold text-slate-700">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Lớp</label>
                    <input type="text" id="input-class" placeholder="VD: IT01" 
                        class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 rounded-2xl outline-none transition-all font-bold text-slate-700 shadow-inner">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Chuyên ngành</label>
                    <select id="input-major" required class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 rounded-2xl outline-none transition-all font-bold text-slate-700 shadow-inner appearance-none cursor-pointer">
                        <option value="">-- Chọn chuyên ngành --</option>
                        {{#each majors}}
                        <option value="{{this}}">{{this}}</option>
                        {{/each}}
                    </select>
                </div>
            </div>

            <div class="pt-4 flex gap-4">
                <button type="button" onclick="closeModal()" class="flex-1 py-4 text-slate-400 font-black text-xs uppercase tracking-widest hover:text-slate-600 transition-colors">HỦY BỎ</button>
                <button type="submit" class="flex-1 py-4 bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-blue-100 hover:scale-105 transition-all">LƯU THÔNG TIN</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/admin-student.js"></script>
