<div class="space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700 pb-20">

    <!-- PAGE HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-blue-600 rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-blue-100">
                ➕
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Thêm Giảng viên</h1>
                <p class="text-slate-500 font-medium mt-1">Khởi tạo tài khoản mới cho cán bộ giảng dạy và nghiên cứu</p>
            </div>
        </div>
        
        <a href="/admin/teacher" class="px-6 py-3 bg-white border border-slate-200 rounded-2xl text-[10px] font-black text-slate-500 uppercase tracking-widest hover:bg-slate-50 transition-colors shadow-sm">
            Quay lại danh sách
        </a>
    </div>

    <!-- MAIN FORM CARD -->
    <div class="bg-white rounded-[3.5rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div class="absolute top-0 right-0 w-80 h-80 bg-blue-50 rounded-full -mr-40 -mt-40 opacity-40"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-slate-50 rounded-full -ml-32 -mb-32 opacity-40"></div>
        
        <form id="teacherForm" class="relative z-10 p-10 md:p-14 space-y-12">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                
                <!-- IDENTITY SECTION -->
                <div class="space-y-6">
                    <h2 class="text-[10px] font-black text-blue-500 uppercase tracking-[0.2em] flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span>
                        Thông tin Định danh
                    </h2>
                    
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mã số Giảng viên (Username)</label>
                            <input id="teacherId" type="text" required placeholder="GV00123"
                                class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Họ và Tên đầy đủ</label>
                            <input id="name" type="text" required placeholder="ThS. Nguyễn Văn A"
                                class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                        </div>
                    </div>
                </div>

                <!-- CONTACT SECTION -->
                <div class="space-y-6">
                    <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span>
                        Liên hệ trực tuyến
                    </h2>
                    
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Địa chỉ Email</label>
                            <input id="email" type="email" required placeholder="gv_name@university.edu.vn"
                                class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Số điện thoại</label>
                            <input id="phone" type="tel" placeholder="0987 654 321"
                                class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                        </div>
                    </div>
                </div>

                <!-- ACADEMIC SECTION -->
                <div class="space-y-6">
                    <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span>
                        Đơn vị & Chức vụ
                    </h2>
                    
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Khoa / Phòng ban</label>
                            <input id="department" type="text" placeholder="Khoa Công nghệ Thông tin"
                                class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Học vị</label>
                                <select id="degree" class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                    <option>Cử nhân</option>
                                    <option selected>Thạc sĩ</option>
                                    <option>Tiến sĩ</option>
                                    <option>PGS. Tiến sĩ</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Vị trí</label>
                                <select id="role" class="w-full bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl p-4 text-sm font-bold text-slate-700 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                    <option value="GVHD" selected>GV Hướng dẫn</option>
                                    <option value="GVPB">GV Phản biện</option>
                                    <option value="Council">Hội đồng</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- APPEARANCE SECTION -->
                <div class="space-y-6">
                    <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span>
                        Ảnh đại diện
                    </h2>
                    
                    <div class="bg-slate-50 border-2 border-dashed border-slate-200 rounded-[2.5rem] p-8 flex flex-col items-center justify-center relative hover:bg-slate-100 transition-colors group">
                        <input type="file" id="avatarFile" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-10">
                        <div id="uploadContent" class="flex flex-col items-center text-center">
                            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center text-2xl shadow-sm mb-4 group-hover:scale-110 transition-transform">📸</div>
                            <p class="text-xs font-black text-slate-700 uppercase tracking-widest">Chọn tệp hình ảnh</p>
                            <p class="text-[10px] text-slate-400 font-bold mt-1 uppercase">PNG, JPG tối đa 2MB</p>
                        </div>
                        <img id="preview" class="w-24 h-24 rounded-[2rem] hidden border-4 border-white shadow-xl object-cover relative z-20">
                    </div>
                </div>

            </div>

            <!-- ACTION BUTTONS -->
            <div class="pt-10 border-t border-slate-50 flex flex-col md:flex-row gap-4">
                <button type="submit" class="submit flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-5 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-blue-100 transition-all hover:-translate-y-1 active:translate-y-0">
                    XÁC NHẬN KHỞI TẠO TÀI KHOẢN
                </button>
                <button type="reset" class="reset px-10 bg-slate-100 text-slate-500 py-5 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] hover:bg-slate-200 transition-colors">
                    RESETS
                </button>
            </div>

        </form>
    </div>

</div>

<script>
    // File preview logic (integrated into layout for immediate effect)
    document.getElementById('avatarFile').onchange = function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(event) {
                const preview = document.getElementById('preview');
                const content = document.getElementById('uploadContent');
                preview.src = event.target.result;
                preview.classList.remove('hidden');
                content.classList.add('hidden');
            }
            reader.readAsDataURL(file);
        }
    }
</script>