<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if title}}{{title}}{{else}}Hệ thống Quản lý Đồ án - Project OS{{/if}}</title>
    
    <!-- FONTS & ICONOGRAPHY -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        
        /* Sidebar active state */
        .menu-item.active { 
            background: rgba(79, 70, 229, 0.08); 
            border-right: 4px solid #4f46e5; 
            color: #4f46e5; 
        }

        /* Sidebar collapsed state */
        .sidebar-collapsed { width: 88px; }
        .sidebar-collapsed .sidebar-text { display: none; }
        .sidebar-collapsed .sidebar-logo { justify-content: center; }
        .sidebar-collapsed .sidebar-logo .sidebar-text { display: none; }
        .sidebar-collapsed .sidebar-logo div { margin-right: 0; }
        
        /* Custom scrollbar */
        .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 20px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #CBD5E1; }

        /* Animation utilities */
        .animate-in { animation: animateIn 0.5s ease-out forwards; }
        @keyframes animateIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    {{{_sections.head}}}
</head>

<body class="bg-[#F8FAFC] text-slate-900 overflow-hidden text-[13px]">

    <div class="flex h-screen overflow-hidden">
        
        <!-- SIDEBAR PARTIAL -->
        {{> common/sidebar }}

        <!-- MAIN LAYOUT CONTENT -->
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden relative">
            
            <!-- MAIN VIEWPORT (Global Header Removed as requested) -->

            <!-- MAIN VIEWPORT -->
            <main id="main-content" class="flex-1 overflow-y-auto p-8 lg:p-12 custom-scrollbar relative bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px]">
                <div class="max-w-7xl mx-auto">
                    {{{body}}}
                </div>
            </main>

        </div>
    </div>

    <!-- GLOBAL SCRIPTS -->
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('sidebar-collapsed');
            
            // Save state to localStorage for persistence across pages
            const isCollapsed = sidebar.classList.contains('sidebar-collapsed');
            localStorage.setItem('sidebarState', isCollapsed ? 'collapsed' : 'expanded');
        }

        // Apply saved sidebar state on load
        window.addEventListener('DOMContentLoaded', () => {
            const savedState = localStorage.getItem('sidebarState');
            if (savedState === 'collapsed') {
                document.getElementById('sidebar').classList.add('sidebar-collapsed');
            }
        });

        // SYSTEM RESET FUNCTION (For Admin)
        async function triggerSystemReset() {
            const { value: confirm } = await Swal.fire({
                title: 'Tái thiết lập hệ thống?',
                text: "HÀNH ĐỘNG CỰC KỲ NGUY HIỂM: Toàn bộ dữ liệu hoạt động sẽ bị xoá sạch và hệ thống sẽ quay về trạng thái ban đầu. Bạn có chắc chắn không?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đúng, xoá sạch tất cả!',
                cancelButtonText: 'Hủy bỏ'
            });

            if (confirm) {
                Swal.fire({
                    title: 'Đang xử lý...',
                    text: 'Hệ thống đang được làm sạch, vui lòng đợi.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                try {
                    const response = await fetch('/admin/period/system/reset', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const result = await response.json();

                    if (result.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            text: result.message,
                            timer: 3000
                        });
                        window.location.href = '/admin/dashboard';
                    } else {
                        Swal.fire('Lỗi', result.message || 'Không thể reset hệ thống', 'error');
                    }
                } catch (err) {
                    Swal.fire('Lỗi kết nối', 'Không thể kết nối đến máy chủ', 'error');
                }
            }
        }
    </script>
    
    {{{_sections.script}}}

</body>
</html>
