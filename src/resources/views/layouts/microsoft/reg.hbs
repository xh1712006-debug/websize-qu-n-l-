<div class="min-h-screen flex items-center justify-center p-6 bg-slate-900 relative overflow-hidden">
    
    <!-- HUMG Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="/img/humg_bg.png" class="w-full h-full object-cover opacity-50 shadow-2xl" alt="HUMG Campus">
        <div class="absolute inset-0 bg-gradient-to-br from-[#0f172a]/70 via-[#0f172a]/40 to-blue-900/30"></div>
    </div>

    <!-- Main Card -->
    <div class="w-full max-w-xl bg-white rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)] p-8 md:p-12 relative z-10 border border-white/10 animate-in fade-in zoom-in duration-500">
        
        <!-- Header / Logo HUMG -->
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-white rounded-2xl shadow-xl border border-slate-50 mb-6 p-2 transition-transform hover:rotate-3 duration-300">
                <img src="/img/logo_humg.png" class="w-full h-auto object-contain" alt="HUMG Logo">
            </div>
            
            <h2 class="text-2xl font-extrabold text-slate-800 tracking-tight mb-2 uppercase">Kích hoạt Tài khoản</h2>
            <div class="h-1 w-12 bg-blue-600 mx-auto rounded-full mb-6"></div>
            
            <div class="bg-blue-50 py-3 px-6 rounded-2xl inline-block border border-blue-100">
                <p class="text-slate-600 font-semibold">
                    Xin chào, <span class="text-blue-700 font-bold uppercase">{{user.fullName}}</span>
                </p>
            </div>
            
            <p class="text-slate-400 text-[11px] mt-4 font-bold uppercase tracking-widest leading-relaxed">
                Đại học Mỏ - Địa chất <br>
                Hệ thống Quản lý Đồ án Tốt nghiệp
            </p>
        </div>

        <!-- Notification Box -->
        <div class="mb-8 p-4 bg-amber-50 border border-amber-100 rounded-2xl flex items-start gap-3">
            <span class="text-xl">🛡️</span>
            <p class="text-amber-800 text-xs font-medium leading-relaxed">
                Để bảo mật tuyệt đối cho tài khoản đồng bộ từ Microsoft, vui lòng thiết lập mật khẩu riêng cho hệ thống đồ án.
            </p>
        </div>

        <!-- Password Setup Form -->
        <form id="setupPasswordForm" class="space-y-6">
            
            <!-- New Password -->
            <div class="space-y-2 group">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mật khẩu mới</label>
                <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center text-slate-400 group-focus-within:text-blue-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                    </div>
                    <input type="password" id="password" name="password" 
                        placeholder="Tối thiểu 6 ký tự"
                        class="w-full pl-12 pr-4 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-blue-600 focus:bg-white focus:outline-none transition-all duration-300 text-slate-800 font-bold placeholder:text-slate-300" 
                        required>
                </div>
            </div>

            <!-- Confirm Password -->
            <div class="space-y-2 group">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Xác nhận mật khẩu</label>
                <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center text-slate-400 group-focus-within:text-blue-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    </div>
                    <input type="password" id="confirmPassword" 
                        placeholder="Nhập lại mật khẩu trên"
                        class="w-full pl-12 pr-4 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-blue-600 focus:bg-white focus:outline-none transition-all duration-300 text-slate-800 font-bold placeholder:text-slate-300" 
                        required>
                </div>
            </div>

            <!-- Error Message -->
            <div id="errorMessage" class="hidden animate-in fade-in slide-in-from-top-2">
                <div class="bg-rose-50 border border-rose-100 text-rose-600 px-4 py-3 rounded-xl text-xs font-bold flex items-center gap-3">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span id="errorText"></span>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
                <button type="button" id="submitBtn" onclick="handleSetupPassword()"
                    class="w-full py-5 bg-blue-600 text-white rounded-2xl font-black text-base shadow-xl shadow-blue-500/20 hover:bg-blue-700 hover:shadow-blue-500/30 hover:-translate-y-1 active:translate-y-0 transition-all duration-300 flex items-center justify-center gap-3 group">
                    <span>Xác nhận & Vào hệ thống</span>
                    <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </div>

            <!-- Footer Text -->
            <div class="flex flex-col items-center gap-4 pt-4">
                <div class="w-full h-px bg-slate-100"></div>
                <p class="text-center text-slate-400 text-[9px] font-bold uppercase tracking-widest">
                    Bản quyền thuộc về Trường Đại học Mỏ - Địa chất
                </p>
            </div>
        </form>
    </div>
</div>

<script>
async function handleSetupPassword() {
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirmPassword').value;
    const errorDiv = document.getElementById('errorMessage');
    const errorText = document.getElementById('errorText');
    const submitBtn = document.getElementById('submitBtn');

    // Reset error
    errorDiv.classList.add('hidden');

    // Validation
    if (password.length < 6) {
        showError("Mật khẩu phải có ít nhất 6 ký tự!");
        return;
    }

    if (password !== confirmPassword) {
        showError("Xác nhận mật khẩu không khớp!");
        return;
    }

    // Loading state
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        <span>Đang xác thực...</span>
    `;

    try {
        const response = await fetch('/api/auth/reg', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password })
        });

        const data = await response.json();

        if (data.success) {
            Swal.fire({
                icon: 'success',
                title: 'Thành công',
                text: 'Mật khẩu đã được thiết lập. Chào mừng bạn đến với hệ thống!',
                timer: 2000,
                showConfirmButton: false
            }).then(() => {
                window.location.href = data.redirect;
            });
        } else {
            showError(data.message || "Có lỗi xảy ra, vui lòng thử lại!");
            resetBtn();
        }
    } catch (e) {
        showError("Lỗi kết nối máy chủ!");
        resetBtn();
    }
}

function resetBtn() {
    const submitBtn = document.getElementById('submitBtn');
    submitBtn.disabled = false;
    submitBtn.innerHTML = `<span>Xác nhận & Vào hệ thống</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>`;
}

function showError(msg) {
    const errorDiv = document.getElementById('errorMessage');
    const errorText = document.getElementById('errorText');
    errorText.innerText = msg;
    errorDiv.classList.remove('hidden');
}
</script>