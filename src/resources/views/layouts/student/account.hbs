<script>
    function openEditModal() {
        const modal = document.getElementById('editContactModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function closeEditModal() {
        const modal = document.getElementById('editContactModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    async function handleContactUpdate() {
        const email = document.getElementById('editEmail').value.trim();
        const phone = document.getElementById('editPhone').value.trim();

        if (!email || !phone) {
            Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Vui lòng điền đầy đủ email và số điện thoại.' });
            return;
        }

        try {
            const res = await fetch('/student/account/update-contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentEmail: email, studentPhone: phone })
            });
            const data = await res.json();
            if (data.success) {
                await Swal.fire({ icon: 'success', title: 'Thành công', text: data.message, timer: 1500, showConfirmButton: false });
                window.location.reload();
            } else {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message });
            }
        } catch (err) {
            console.error(err);
            Swal.fire({ icon: 'error', title: 'Lỗi hệ thống', text: 'Không thể kết nối máy chủ.' });
        }
    }

    async function handlePasswordUpdate() {
        const currentPass = document.getElementById('currentPassword').value.trim();
        const newPass = document.getElementById('newPassword').value.trim();
        const confirmPass = document.getElementById('confirmPassword').value.trim();

        if (!currentPass || !newPass || !confirmPass) {
            Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Vui lòng nhập đầy đủ các trường mật khẩu.' });
            return;
        }

        if (newPass !== confirmPass) {
            Swal.fire({ icon: 'warning', title: 'Không khớp', text: 'Mật khẩu mới và xác nhận mật khẩu không trùng khớp.' });
            return;
        }

        try {
            const res = await fetch('/student/account/data', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ currentPassword: currentPass, newPassword: newPass })
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('changePassMessage').classList.remove('hidden');
                setTimeout(() => document.getElementById('changePassMessage').classList.add('hidden'), 3000);
                
                // Clear fields
                document.getElementById('currentPassword').value = '';
                document.getElementById('newPassword').value = '';
                document.getElementById('confirmPassword').value = '';

                Swal.fire({ icon: 'success', title: 'Thành công', text: 'Mật khẩu đã được thay đổi.', timer: 1500, showConfirmButton: false });
            } else {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message });
            }
        } catch (err) {
            console.error(err);
            Swal.fire({ icon: 'error', title: 'Lỗi hệ thống', text: 'Đã có lỗi xảy ra.' });
        }
    }
</script>
