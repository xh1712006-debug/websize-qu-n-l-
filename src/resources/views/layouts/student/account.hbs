      <!-- BẢO MẬT -->
      <section class="bg-white p-6 rounded-xl shadow">
        <div id="message"
        class="hidden mb-4 p-3 rounded-lg bg-green-100 text-green-700 text-sm">
            ✅ Đổi mật khẩu thành công
        </div>
        <h2 class="text-lg font-semibold mb-4 border-b pb-2">
