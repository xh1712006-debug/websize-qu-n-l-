                HUỶ BỎ
            </button>
            <button onclick="handleContactUpdate()" class="py-5 bg-gradient-to-r from-indigo-600 to-purple-700 text-white rounded-[1.5rem] font-black text-xs hover:opacity-90 transition-all shadow-xl shadow-indigo-100 uppercase tracking-widest">
                LƯU THAY ĐỔI
