<!-- ================= TITLE ================= -->
<div class="mb-6">
  <h1 class="text-2xl font-bold flex items-center gap-2">
    💬 Phản hồi từ giảng viên
  </h1>
  <p class="text-gray-600 text-sm mt-1">
    Các nhận xét và góp ý trong quá trình thực hiện đồ án tốt nghiệp
  </p>
</div>

<!-- ================= CHAT BOX ================= -->
<div class="bg-white rounded-2xl shadow border flex flex-col h-[520px]">

  <!-- CHAT HEADER -->
  <div class="px-6 py-4 border-b">
    <h2 class="font-semibold text-lg">📨 Trao đổi với giảng viên</h2>
    <p class="text-sm text-gray-500">Giảng viên ↔ Sinh viên</p>
  </div>

  <!-- ================= MESSAGE LIST ================= -->
  <div
    id="list__content"
    class="flex-1 overflow-y-auto px-6 py-5 space-y-4 text-sm bg-gray-50"
  >

    <!-- TEACHER MESSAGE (sample) -->
    {{!--
    <div class="max-w-[80%] bg-white p-4 rounded-2xl shadow-sm border-l-4 border-blue-500">
      <p class="font-semibold text-blue-700 mb-1">👨‍🏫 ThS. Trần Văn B</p>
      <p>
        Phần phân tích yêu cầu tương đối tốt. Tuy nhiên cần
        bổ sung thêm sơ đồ use case và mô tả chi tiết các chức năng.
      </p>
      <p class="text-xs text-gray-400 mt-2">
        15/02/2026 · Báo cáo tiến độ
      </p>
    </div>
    --}}

    <!-- STUDENT MESSAGE (sample) -->
    {{!--
    <div class="ml-auto max-w-[80%] bg-white p-4 rounded-2xl shadow-sm border-l-4 border-green-500">
      <p class="font-semibold text-green-700 mb-1">👨‍🎓 Bạn</p>
      <p>
        Em đã bổ sung sơ đồ use case và chỉnh sửa lại phần mô tả
        theo góp ý của thầy.
      </p>
      <p class="text-xs text-gray-400 mt-2 text-right">
        16/02/2026
      </p>
    </div>
    --}}

  </div>

  <!-- ================= INPUT FORM ================= -->
  <form class="from__feedback border-t p-4 bg-white rounded-b-2xl">
    <div class="flex gap-3 items-end">

      <textarea
        class="text__content flex-1 border rounded-xl p-3 resize-none
               focus:outline-none focus:ring-2 focus:ring-blue-400"
        rows="2"
        placeholder="Nhập phản hồi của bạn..."
      ></textarea>

      <button
        type="submit"
        class="flex__feedback px-6 py-3 bg-blue-600 hover:bg-blue-700
               text-white rounded-xl transition"
      >
        📤 Gửi
      </button>

    </div>
  </form>

</div>
