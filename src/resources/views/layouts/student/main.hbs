<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QL Đồ án - Sinh viên Premium</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .menu-item.active { background: rgba(79, 70, 229, 0.1); border-right: 4px solid #4f46e5; color: #4f46e5; }
        .sidebar-collapsed { width: 88px; }
        .sidebar-collapsed .sidebar-text { display: none; }
        .sidebar-collapsed .sidebar-logo { justify-content: center; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
    </style>
</head>

<body class="bg-[#F8FAFC] text-slate-900 overflow-hidden text-[13px]">

<div class="flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <aside id="sidebar" class="w-72 bg-white border-r border-slate-200 transition-all duration-300 flex-shrink-0 flex flex-col z-50 shadow-sm">
        
        <!-- LOGO -->
        <div class="sidebar-logo flex items-center gap-3 p-8 border-b border-slate-50">
            <div class="w-10 h-10 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-500/20">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
            </div>
            <div class="sidebar-text">
                <span class="font-black text-lg tracking-tight text-slate-900 uppercase">Student</span>
                <span class="block text-[9px] font-bold text-indigo-500 uppercase tracking-widest -mt-1">Project Board</span>
            </div>
        </div>

        <!-- MENU -->
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto custom-scrollbar">
            
            {{#if hasProject}}
            <a href="/student/dashboard" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'dashboard')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Tổng quan</span>
            </a>

            <a href="/student/project" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'project')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332 0.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332 0.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332 0.477-4.5 1.253"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Đồ án của tôi</span>
            </a>
            {{else}}
            <a href="/student/addproject" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'addproject')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Đăng ký đồ án</span>
            </a>
            {{/if}}

            {{#if hasProject}}
            <a href="/student/report" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'report')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a1 1 0 001 1h14a1 1 0 001-1v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Nộp báo cáo</span>
            </a>

            <a href="/student/feedback" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'feedback')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Trao đổi GV</span>
            </a>

            <a href="/student/score" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'score')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Kết quả điểm</span>
            </a>
            {{/if}}

            <div class="h-px bg-slate-50 my-6 mx-2"></div>

            <a href="/student/account" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'account')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Hồ sơ cá nhân</span>
            </a>

        </nav>

        <!-- USER PROFILE FOOTER -->
        <div class="p-6 border-t border-slate-50">
            <div class="user-profile p-4 bg-slate-50 rounded-2xl flex items-center gap-3 border border-slate-100 group">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-emerald-500 flex items-center justify-center text-white font-bold text-sm shadow-inner overflow-hidden">
                    {{#if user.fullName}}{{substring user.fullName 0 1}}{{else}}S{{/if}}
                </div>
                <div class="user-info flex-1 min-w-0">
                    <p class="text-xs font-bold truncate text-slate-900 leading-tight">{{user.fullName}}</p>
                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-wider mt-0.5">{{user.studentCode}}</p>
                </div>
                <a href="/loggin/logout?role=student" class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </a>
            </div>
        </div>

    </aside>

    <!-- CONTENT AREA -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden relative">
        
        <!-- HEADER -->
        <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-10 z-10">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="p-2.5 bg-slate-50 text-slate-600 rounded-xl hover:bg-slate-100 transition-all border border-slate-100">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
                </button>
                <div class="h-4 w-px bg-slate-200 mx-2"></div>
                <span class="text-slate-900 font-bold uppercase tracking-widest text-[11px]">{{active}}</span>
            </div>
            
            <div class="flex items-center gap-5">
                <div class="hidden md:flex flex-col items-end mr-2">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Trạng thái</span>
                    <span class="text-emerald-500 font-bold text-[11px] leading-none mt-1 flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                        Đã kết nối
                    </span>
                </div>
                <div class="w-px h-10 bg-slate-200"></div>
                
                <!-- NOTIFICATION DROP-DOWN -->
                <div class="relative">
                    <button id="notiBtn" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-slate-50 border border-slate-100 text-slate-400 hover:bg-indigo-600 hover:text-white transition-all shadow-sm relative">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 01-6 0v-1m6 0H9"></path></svg>
                        <span id="notiCount" class="absolute top-2 right-2 w-4 h-4 bg-red-500 text-white text-[8px] font-black rounded-full flex items-center justify-center border-2 border-white hidden"></span>
                    </button>
                    
                    <div id="notiMenu" class="absolute right-0 mt-4 w-80 bg-white border border-slate-100 rounded-3xl shadow-2xl p-6 hidden animate-in zoom-in duration-200 origin-top-right z-[100]">
                        <div class="flex items-center justify-between mb-4 pb-4 border-b border-slate-50">
                            <h3 class="font-black text-slate-900 uppercase tracking-tight">Thông báo</h3>
                            <span class="text-[9px] font-bold text-indigo-500 uppercase cursor-pointer hover:text-indigo-700">Đánh dấu đã đọc</span>
                        </div>
                        <div id="notiList" class="space-y-4 max-h-[400px] overflow-y-auto custom-scrollbar">
                           <p class="text-center text-slate-400 py-6 font-bold italic">Không có thông báo mới</p>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- MAIN CONTENT -->
        <main id="content" class="flex-1 overflow-y-auto p-10 custom-scrollbar relative bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px]">
            <div class="max-w-7xl mx-auto animate-in fade-in slide-in-from-bottom-4 duration-700">
                {{{body}}}
            </div>
        </main>
    </div>

</div>

<script>
    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('sidebar-collapsed');
    }

    // Modal & Click Out Logic
    const notiBtn = document.getElementById('notiBtn');
    const notiMenu = document.getElementById('notiMenu');
    
    notiBtn.onclick = (e) => {
        e.stopPropagation();
        notiMenu.classList.toggle('hidden');
    };

    window.onclick = () => {
        notiMenu.classList.add('hidden');
    };

    notiMenu.onclick = (e) => e.stopPropagation();

    // Fetch Noti Logic (Call from specific pages like project.js or here)
    async function loadNotifications() {
        try {
            const res = await fetch('/student/project/getProject');
            const data = await res.json();
            if (data.notifications && data.notifications.length > 0) {
                const list = document.getElementById('notiList');
                const count = document.getElementById('notiCount');
                
                const unread = data.notifications.filter(n => !n.isRead);
                if (unread.length > 0) {
                    count.innerText = unread.length;
                    count.classList.remove('hidden');
                }

                list.innerHTML = data.notifications.map(n => `
                    <div class="p-4 rounded-2xl ${n.isRead ? 'bg-slate-50/50 opacity-60' : 'bg-indigo-50'} border border-slate-100 group cursor-pointer transition-all hover:scale-[1.02]">
                        <p class="text-[11px] font-black text-slate-900 line-clamp-1">${n.title}</p>
                        <p class="text-[10px] text-slate-500 mt-1 line-clamp-2 leading-relaxed">${n.message}</p>
                        <p class="text-[8px] font-bold text-slate-400 mt-2 uppercase tracking-widest">${new Date(n.createdAt).toLocaleDateString('vi-VN')}</p>
                    </div>
                `).join('');
            }
        } catch(e) {}
    }
    loadNotifications();
</script>

</body>
</html>
