<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Quản lý đồ án</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 overflow-hidden">

<div class="flex h-screen">

  <!-- SIDEBAR -->
  <aside id="sidebar"
    class="w-64 bg-gradient-to-b from-blue-800 to-blue-900
           text-white transition-all duration-300 flex-shrink-0">

    <!-- HEADER -->
    <div class="flex items-center justify-between p-4 border-b border-blue-600">
      <span class="font-bold text-lg sidebar-text tracking-wide">
        QL ĐỒ ÁN
      </span>
      <button onclick="toggleSidebar()" class="text-2xl hover:text-gray-200">
        ☰
      </button>
    </div>

    <!-- MENU -->
    <nav class="mt-4 px-2">
      <ul class="space-y-1 text-sm">

        <li>
          <a href="/student/dashboard" class="menu {{#if (eq active 'dashboard')}} active {{/if}} ">
            🏠 <span class="ml-3 sidebar-text">Dashboard</span>
          </a>
        </li>

        <li>
          <a href="/student/project" class="menu {{#if (eq active 'project')}} active {{/if}} ">
            📘 <span class="ml-3 sidebar-text">Đồ án của tôi</span>
          </a>
        </li>

        <li>
          <a href="/student/progress" class="menu {{#if (eq active 'progress')}} active {{/if}} ">
            ⏳ <span class="ml-3 sidebar-text">Tiến độ</span>
          </a>
        </li>

        <li>
          <a href="/student/report" class="menu {{#if (eq active 'report')}} active {{/if}} ">
            📤 <span class="ml-3 sidebar-text">Nộp báo cáo</span>
          </a>
        </li>

        <li>
          <a href="/student/feedback" class="menu {{#if (eq active 'feedback')}} active {{/if}} ">
            💬 <span class="ml-3 sidebar-text">Phản hồi</span>
          </a>
        </li>

        <li>
          <a href="/student/score" class="menu {{#if (eq active 'score')}} active {{/if}} ">
            📊 <span class="ml-3 sidebar-text">Kết quả</span>
          </a>
        </li>

        <li class="border-t border-blue-600 mt-3 pt-2">
          <a href="/student/account" class="menu {{#if (eq active 'account')}} active {{/if}} ">
            👤 <span class="ml-3 sidebar-text">Tài khoản</span>
          </a>
        </li>

      </ul>
    </nav>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="content"
    class="flex-1 overflow-y-auto p-6 transition-all duration-300">

    {{{body}}}

  </main>

</div>

<script src="/{{figure}}/{{active}}.js"></script>

<style>
.menu {
  display: flex;
  align-items: center;
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  cursor: pointer;
  transition: all 0.2s;
}

.menu:hover {
  background-color: rgba(255,255,255,0.15);
}

.menu.active {
  background-color: rgba(255,255,255,0.25);
  font-weight: 600;
}

</style>

</body>
</html>
