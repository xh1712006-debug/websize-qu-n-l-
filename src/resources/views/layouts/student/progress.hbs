<!-- TITLE -->
<div class="mb-6">
  <h1 class="text-2xl font-bold flex items-center gap-2">
    ⏳ Tiến độ thực hiện đồ án
  </h1>
  <p class="text-gray-600 text-sm mt-1">
    Theo dõi tình trạng thực hiện đồ án tốt nghiệp
  </p>
</div>

<!-- OVERALL PROGRESS -->
<div class="bg-white p-6 rounded-lg shadow mb-6">
  <p class="text-sm text-gray-500 mb-2">Tiến độ tổng thể</p>

  <div class="flex items-center justify-between mb-2">
    <span class="font-semibold">Hoàn thành</span>
    <span class="progress__number font-bold text-blue-600">0%</span>
  </div>

  <div class="progress__width w-full bg-gray-200 rounded-full h-3">
    {{!-- <div class="bg-blue-600 h-3 rounded-full" style="width:0%"></div> --}}
  </div>
</div>

<!-- WEEKLY TIMELINE -->
<div class="bg-white p-6 rounded-lg shadow">
  <h2 class="text-lg font-semibold mb-6">🗓 Hành trình 10 Tuần</h2>

  <div class="relative wrap overflow-hidden p-4 h-full">
    <!-- Đường thẳng dọc -->
    <div class="absolute border-dashed border-2 border-blue-200 h-full" style="left: 50%; transform: translateX(-50%);"></div>

    <div id="timeline-list" class="space-y-8 w-full">
      <!-- Generated by JS -->
    </div>
  </div>
</div>

{{!-- <!-- JS -->
<script>
  const progressNumber = document.querySelector('.progress__number')
  const progressWidth = document.querySelector('.progress__width')
  const taskList = document.querySelector('#task-list')

  // 🔥 DATA TEST (bạn có thể thay bằng API sau)
  let requirements = [
    { title: "Phân tích yêu cầu", status: "pass", deadline: "10/02/2026" },
    { title: "Thiết kế CSDL", status: "doing", deadline: "25/02/2026" },
    { title: "Xây dựng API", status: "pending", deadline: "20/03/2026" }
  ]

  // render toàn bộ
  function render() {
    renderTasks(requirements)

    const percent = calculateProgress(requirements)

    progressNumber.innerText = percent + '%'
    progressWidth.style.width = percent + '%'
  }

  // render bảng
  function renderTasks(data) {
    taskList.innerHTML = data.map(item => {
      let statusText = ''
      let statusClass = ''

      if (item.status === 'pass') {
        statusText = 'Hoàn thành'
        statusClass = 'text-green-600 font-semibold'
      } else if (item.status === 'doing') {
        statusText = 'Đang làm'
        statusClass = 'text-blue-600 font-semibold'
      } else {
        statusText = 'Chưa bắt đầu'
        statusClass = 'text-gray-500'
      }

      return `
        <tr>
          <td class="p-2 border">${item.title}</td>
          <td class="p-2 border ${statusClass}">${statusText}</td>
          <td class="p-2 border">${item.deadline}</td>
        </tr>
      `
    }).join('')
  }

  // tính %
  function calculateProgress(data) {
    const total = data.length
    const done = data.filter(item => item.status === 'pass').length

    if (total === 0) return 0

    return Math.round((done / total) * 100)
  }

  // chạy lần đầu
  render()
</script> --}}
