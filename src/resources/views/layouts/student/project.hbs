<div class="max-w-6xl mx-auto space-y-12 py-6 animate-in fade-in slide-in-from-bottom-6 duration-700">

  {{#if noProject}}
  <!-- ENHANCED EMPTY STATE -->
  <div class="bg-white rounded-[4rem] shadow-2xl shadow-slate-200/50 border border-slate-100 p-20 text-center space-y-8 relative overflow-hidden group">
    <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-50/50 rounded-full -mr-32 -mt-32 blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
    <div class="relative z-10">
        <div class="w-32 h-32 bg-slate-50 text-slate-300 rounded-[3rem] flex items-center justify-center text-6xl mx-auto mb-8 shadow-inner group-hover:bg-indigo-600 group-hover:text-white transition-all duration-500">
            🔭
        </div>
        <h2 class="text-4xl font-black text-slate-900 tracking-tight italic">Khởi đầu hành trình</h2>
        <p class="text-slate-500 font-medium text-lg max-w-sm mx-auto leading-relaxed">Bạn hiện chưa có đồ án nào đang thực hiện. Hãy chọn một đề tài để bắt đầu ngay!</p>
        <div class="pt-10">
            <a href="/student/addproject" class="inline-flex items-center gap-4 px-10 py-5 bg-indigo-600 text-white rounded-[2.5rem] font-black text-sm uppercase tracking-[0.2em] hover:bg-slate-900 hover:-translate-y-1 transition-all shadow-2xl shadow-indigo-200 active:scale-95">
                <span>Khám phá đề tài</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        </div>
    </div>
  </div>
  {{else}}

  <!-- ELITE HEADER AREA -->
  <div class="relative group bg-white/50 backdrop-blur-sm p-6 rounded-[3rem] border border-white/50">
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
        <div class="flex items-center gap-8 px-4">
            <div class="w-24 h-24 bg-[#0F172A] rounded-[2.5rem] flex items-center justify-center text-4xl shadow-2xl shadow-slate-300 ring-[12px] ring-white">
                🎓
            </div>
            <div class="space-y-1">
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tighter italic">Đồ án của tôi</h1>
                <div class="flex items-center gap-4 mt-2">
                    <span class="flex items-center gap-2 px-4 py-1.5 bg-emerald-50 text-emerald-600 text-[10px] font-black uppercase tracking-widest rounded-xl border border-emerald-100 italic">
                        <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                        Đang thực hiện
                    </span>
                    <span class="text-slate-300 font-bold text-xs">/</span>
                    <div class="flex items-center gap-3">
                        <div class="w-32 md:w-48 bg-slate-100 h-2 rounded-full overflow-hidden p-0.5 border border-slate-200/50">
                            <div class="bg-gradient-to-r from-emerald-400 to-teal-500 h-full rounded-full shadow-[0_0_10px_rgba(16,185,129,0.4)]" style="width: {{progress.percent}}%"></div>
                        </div>
                        <span class="text-[11px] font-black text-slate-900 italic tracking-tighter">{{progress.percent}}%</span>
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">{{completedCount}} / {{totalCount}} Nhiệm vụ 🎯</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3 px-4">
            <a href="/student/report" class="flex items-center gap-3 px-10 py-5 bg-[#0F172A] text-white rounded-3xl font-black text-xs uppercase tracking-widest shadow-xl hover:shadow-indigo-200 transition-all hover:-translate-y-1 active:scale-95">
                <span>Nộp báo cáo hồ sơ</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            </a>
        </div>
    </div>
  </div>

  {{#if isWaitingConfirm}}
  <!-- GLASS CONFIRMATION BANNER -->
  <div class="bg-gradient-to-r from-amber-500 via-orange-600 to-rose-600 rounded-[3.5rem] p-12 shadow-2xl shadow-orange-200/50 flex flex-col lg:flex-row items-center justify-between gap-10 animate-bounce-subtle relative overflow-hidden group">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#ffffff_20%,transparent_80%)] opacity-10"></div>
    <div class="flex items-center gap-8 relative z-10">
        <div class="w-20 h-20 bg-white/20 rounded-3xl flex items-center justify-center text-4xl backdrop-blur-md border border-white/30 rotate-12 group-hover:rotate-0 transition-transform duration-500">
            ⚠️
        </div>
        <div class="space-y-2">
            <h3 class="text-2xl font-black text-white italic tracking-tight uppercase">Yêu cầu xác nhận thay đổi</h3>
            <p class="text-white/80 font-medium text-lg leading-relaxed max-w-xl italic">Giảng viên đã tinh chỉnh nội dung. Vui lòng rà soát và xác nhận để hành trình được tiếp tục.</p>
        </div>
    </div>
    <button onclick="confirmProjectChanges()" class="relative z-10 px-12 py-6 bg-white text-orange-600 rounded-[2.5rem] font-black text-sm uppercase tracking-[0.2em] shadow-2xl hover:bg-slate-900 hover:text-white transition-all hover:scale-105 active:scale-95 whitespace-nowrap">
        Tôi đồng ý với các thay đổi
    </button>
  </div>
  {{/if}}

  <!-- FULL-WIDTH PROJECT SYSTEM -->
  <div class="space-y-12">
    
    <!-- CORE PROJECT DETAILS -->
    <div class="bg-white rounded-[4rem] shadow-sm border border-slate-100 p-12 md:p-16 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-80 h-80 bg-slate-50/50 rounded-full blur-[80px] -mr-40 -mt-40 transition-transform duration-1000 group-hover:scale-110"></div>
            
            <div class="relative z-10 space-y-12">
                <!-- Title Header -->
                <div class="space-y-4">
                  <div class="flex items-center gap-3">
                      <span class="w-8 h-8 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center text-sm font-black">#</span>
                      <p class="text-[10px] uppercase tracking-[0.5em] font-black text-indigo-400 italic">Đang nghiên cứu</p>
                  </div>
                  <h2 class="text-4xl md:text-5xl font-black text-slate-900 leading-[1.1] tracking-tight italic">{{project.inputProject}}</h2>
               </div>

                <!-- Strategic Roadmap Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <!-- Objectives -->
                    <div class="space-y-6">
                        <h3 class="text-[10px] font-black text-slate-900 uppercase tracking-[0.3em] flex items-center gap-3 italic">
                            <span class="w-8 h-8 bg-slate-900 text-white rounded-xl flex items-center justify-center text-xs">01</span>
                            Mục tiêu chiến lược
                        </h3>
                        <p class="text-slate-600 leading-relaxed text-base font-medium italic border-l-2 border-slate-100 pl-6 py-1">
                            {{#if project.objective}}{{project.objective}}{{else}}Chưa cập nhật mục tiêu cụ thể cho đề tài này.{{/if}}
                        </p>
                    </div>

                    <!-- Scope -->
                    <div class="space-y-6">
                        <h3 class="text-[10px] font-black text-slate-900 uppercase tracking-[0.3em] flex items-center gap-3 italic">
                            <span class="w-8 h-8 bg-slate-900 text-white rounded-xl flex items-center justify-center text-xs">02</span>
                            Phạm vi thực hiện
                        </h3>
                        <p class="text-slate-600 leading-relaxed text-base font-medium italic border-l-2 border-slate-100 pl-6 py-1">
                            {{#if project.scope}}{{project.scope}}{{else}}Chưa xác định phạm vi chi tiết cho đợt này.{{/if}}
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-4">
                    <!-- Tech Mosaic -->
                    <div class="space-y-6">
                        <h3 class="text-[10px] font-black text-slate-900 uppercase tracking-[0.3em] flex items-center gap-3 italic">
                            <span class="w-8 h-8 bg-slate-900 text-white rounded-xl flex items-center justify-center text-xs">03</span>
                            Nền tảng công nghệ
                        </h3>
                        <div class="flex flex-wrap gap-2">
                            {{#if project.technology.length}}
                                {{#each project.technology}}
                                <span class="px-5 py-2.5 bg-slate-50 text-slate-900 rounded-2xl text-[10px] font-black border border-slate-100 uppercase tracking-widest shadow-sm hover:bg-slate-900 hover:text-white transition-all transform hover:-rotate-2 cursor-default">{{this}}</span>
                                {{/each}}
                            {{else}}
                                <span class="text-slate-400 text-xs font-semibold italic">Chưa cấu hình Tech Stack.</span>
                            {{/if}}
                        </div>
                    </div>

                    <!-- Expected Outcome -->
                    <div class="space-y-6">
                        <h3 class="text-[10px] font-black text-slate-900 uppercase tracking-[0.3em] flex items-center gap-3 italic">
                            <span class="w-8 h-8 bg-slate-900 text-white rounded-xl flex items-center justify-center text-xs">04</span>
                            Kết quả dự kiến
                        </h3>
                        <div class="p-6 bg-slate-50/50 rounded-3xl border-2 border-dashed border-slate-100 group-hover:border-indigo-100 transition-colors">
                            <p class="text-slate-700 text-sm font-bold italic leading-relaxed">
                                {{#if project.expectedOutcome}}"{{project.expectedOutcome}}"{{else}}Đang cập nhật kết quả bàn giao...{{/if}}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- STRATEGIC MILESTONES ROADMAP -->
        <div class="bg-[#0F172A] rounded-[4rem] shadow-2xl p-12 md:p-16 text-white relative overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#4f46e5,#0f172a_50%)] opacity-20"></div>
            
            <div class="flex items-center justify-between mb-16 relative z-10">
                <div>
                    <h2 class="text-3xl font-black tracking-tight italic">Hành trình 10 Tuần</h2>
                    <p class="text-slate-500 text-[10px] font-black uppercase tracking-[0.3em] mt-2">Lộ trình bám sát tiến độ nộp báo cáo</p>
                </div>
                <div class="w-16 h-16 bg-white/10 rounded-3xl flex items-center justify-center text-3xl backdrop-blur-md animate-bounce-slow">🚀</div>
            </div>

            <div class="relative space-y-12 pl-12 border-l border-white/10 ml-4 relative z-10">
                {{#each requirements}}
                <div class="relative group">
                    <!-- Achievement Dot -->
                    <div class="absolute -left-[61px] top-0 w-6 h-6 rounded-full bg-[#0F172A] border-4 {{#if (eq this.status 'completed')}}border-emerald-500 shadow-[0_0_15px_#10b981]{{else}}border-white/10{{/if}} z-10 transition-all duration-500 group-hover:scale-125"></div>
                    
                    <div class="bg-white/5 backdrop-blur-sm p-8 rounded-[3rem] border border-white/5 hover:border-white/20 hover:bg-white/10 transition-all duration-500 group">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div class="space-y-3">
                                <div class="flex items-center gap-4">
                                    <h4 class="text-xl font-black italic tracking-tight {{#if (eq this.status 'completed')}}text-emerald-400{{else}}text-white{{/if}}">{{this.name}}</h4>
                                    {{#if (eq this.status 'completed')}}
                                    <span class="px-3 py-1 bg-emerald-500/20 text-emerald-400 text-[9px] font-black uppercase rounded-lg tracking-widest border border-emerald-500/20 shadow-sm shadow-emerald-500/10">Achievement</span>
                                    {{/if}}
                                </div>
                                <div class="flex items-center gap-3 text-[11px] font-bold text-slate-500 italic">
                                    <span class="flex items-center gap-1.5 group-hover:text-rose-400 transition-colors">
                                        ⏱ Hạn chốt: {{dateFormat this.createdAt}}
                                    </span>
                                </div>
                            </div>
                            <div class="flex-shrink-0">
                                <a href="/student/report?requirementId={{this._id}}" class="inline-flex items-center gap-3 px-8 py-4 bg-white/10 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-white hover:text-[#0F172A] transition-all transform hover:scale-105 active:scale-95 shadow-xl">
                                    Mở hồ sơ &rarr;
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>

    </div>
  </div>
  {{/if}}
</div>

<script>
async function confirmProjectChanges() {
    if(!confirm("Bạn có chắc chắn đồng ý với các nội dung thay đổi của đề tài này không?")) return;
    try {
        const response = await fetch('/student/project/confirm', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if(data.success) {
            window.location.reload();
        } else {
            alert("❌ Lỗi: " + data.message);
        }
    } catch(err) {
        console.error(err);
        alert("Có lỗi xảy ra khi kết nối máy chủ.");
    }
}
</script>

<style>
@keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
}
.animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
}
@keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
}
.animate-bounce-subtle {
    animation: bounce-subtle 3s infinite ease-in-out;
}
</style>