<div class="animate-in space-y-10 pb-20">
    <!-- BACKGROUND DECORATION -->
    <div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
        <div class="absolute top-[-20%] right-[-10%] w-[50%] h-[50%] bg-indigo-50 blur-[150px] rounded-full"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-purple-50 blur-[150px] rounded-full"></div>
    </div>

    <!-- HEADER SECTION -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-slate-100 pb-8">
        <div class="space-y-2">
            <h1 class="text-4xl font-black text-slate-900 tracking-tight uppercase leading-none">Hành trình <span class="text-indigo-600">Bảo vệ</span></h1>
            <p class="text-slate-500 font-medium italic">Tất cả thông tin bạn cần cho buổi bảo vệ đồ án tốt nghiệp.</p>
        </div>
        <div class="bg-white px-5 py-3 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-3">
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
            <span class="text-[10px] font-black text-slate-600 uppercase tracking-widest">{{userObj.studentMajor}} - Khóa 2024</span>
        </div>
    </div>

    {{#if myProject}}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- LEFT: PERSONAL DASHBOARD -->
        <div class="lg:col-span-2 space-y-8">
            <!-- 1. MY SESSION CARD -->
            <div class="relative group">
                <div class="absolute inset-0 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-[3rem] blur-xl opacity-10 group-hover:opacity-20 transition-opacity"></div>
                <div class="relative bg-white rounded-[3rem] border border-slate-100 shadow-xl overflow-hidden p-8 md:p-12">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
                        <div class="px-4 py-1.5 bg-indigo-50 text-indigo-600 rounded-full text-[10px] font-black uppercase tracking-[0.2em]">Phiên bảo vệ của bạn</div>
                        <div class="flex items-center gap-4">
                            <div class="text-right">
                                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Trạng thái hồ sơ</p>
                                <span class="px-3 py-1 bg-emerald-100 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-tight italic">Đã sẵn sàng</span>
                            </div>
                        </div>
                    </div>

                    <h2 class="text-3xl font-black text-slate-900 uppercase leading-snug tracking-tighter mb-10 text-transparent bg-clip-text bg-gradient-to-r from-slate-900 via-slate-800 to-indigo-900">{{myProject.projectName}}</h2>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 flex flex-col items-center text-center">
                            <svg class="w-6 h-6 text-indigo-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <span class="text-[9px] font-black text-slate-400 uppercase mb-1">Thời gian bắt đầu</span>
                            <p class="font-black text-slate-800 uppercase">{{#if myProject.defenseTime}}{{myProject.defenseTime}}{{else}}Chưa gán{{/if}}</p>
                        </div>
                        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 flex flex-col items-center text-center">
                            <svg class="w-6 h-6 text-indigo-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                            <span class="text-[9px] font-black text-slate-400 uppercase mb-1">Phòng hội đồng</span>
                            <p class="font-black text-slate-800 uppercase">{{#if myProject.defenseRoom}}{{myProject.defenseRoom}}{{else}}Chưa gán{{/if}}</p>
                        </div>
                        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 flex flex-col items-center text-center">
                            <svg class="w-6 h-6 text-indigo-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span class="text-[9px] font-black text-slate-400 uppercase mb-1">GV Hướng dẫn</span>
                            <p class="font-black text-slate-800 uppercase">{{myProject.teacherInstruct}}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. COUNCIL INFO -->
            <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-lg overflow-hidden">
                <div class="px-8 py-6 bg-slate-900 flex items-center justify-between">
                    <h3 class="text-white font-black uppercase text-xs tracking-widest">Hội đồng chấm bảo vệ của bạn</h3>
                    <div class="px-3 py-1 bg-white/10 rounded-lg text-[9px] font-black text-white/60 uppercase">Defense Council</div>
                </div>
                <div class="p-8">
                    {{#if myCouncil}}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-6">
                            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                                <div class="w-10 h-10 rounded-xl bg-indigo-600 text-white flex items-center justify-center font-black">CT</div>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Chủ tịch hội đồng</p>
                                    <p class="font-black text-slate-800 uppercase text-xs">{{myCouncil.chairmanId.fullName}}</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                                <div class="w-10 h-10 rounded-xl bg-orange-500 text-white flex items-center justify-center font-black">TK</div>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Thư ký hội đồng</p>
                                    <p class="font-black text-slate-800 uppercase text-xs">{{myCouncil.secretaryId.fullName}}</p>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                                <div class="w-10 h-10 rounded-xl bg-emerald-500 text-white flex items-center justify-center font-black">PB</div>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Giảng viên Phản biện</p>
                                    <p class="font-black text-slate-800 uppercase text-xs">{{myProject.teacherFeedbackId.fullName}}</p>
                                </div>
                            </div>
                             <div class="space-y-2">
                                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Các Ủy viên khác</p>
                                <div class="flex flex-wrap gap-2">
                                    {{#each myCouncil.memberIds}}
                                    <span class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-[10px] font-black text-slate-600 uppercase">{{this.fullName}}</span>
                                    {{/each}}
                                </div>
                             </div>
                        </div>
                    </div>
                    {{else}}
                    <div class="py-10 text-center space-y-4">
                        <div class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center mx-auto">
                            <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <p class="text-slate-400 font-bold italic text-sm text-center">Đang cập nhật danh sách hội đồng của bạn...</p>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>

        <!-- RIGHT: PREPARATION & GUIDE -->
        <div class="space-y-8">
            <div class="bg-indigo-600 rounded-[2.5rem] p-8 text-white shadow-xl shadow-indigo-100">
                <h3 class="font-black uppercase text-xs tracking-widest mb-8 border-b border-indigo-500 pb-4">Checklist chuẩn bị</h3>
                <div class="space-y-6">
                    <div class="flex items-start gap-4 group cursor-pointer">
                        <div class="w-6 h-6 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0 group-hover:bg-white/40 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[11px] font-black uppercase tracking-tight">Slide Thuyết trình</p>
                            <p class="text-[10px] text-indigo-200 font-medium">Chuẩn bị file .pptx và file dự phòng .pdf</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 group cursor-pointer">
                        <div class="w-6 h-6 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0 group-hover:bg-white/40 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[11px] font-black uppercase tracking-tight">Quyển Báo cáo in (x3)</p>
                            <p class="text-[10px] text-indigo-200 font-medium">Mỗi hội đồng cần ít nhất 3 quyển tóm tắt.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 group cursor-pointer">
                        <div class="w-6 h-6 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0 group-hover:bg-white/40 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <div class="space-y-1">
                            <p class="text-[11px] font-black uppercase tracking-tight">Demo & Source Code</p>
                            <p class="text-[10px] text-indigo-200 font-medium">Kiểm tra ứng dụng chạy ổn định trên máy cá nhân.</p>
                        </div>
                    </div>
                </div>
                <div class="mt-10 p-5 bg-white/10 rounded-2xl text-[10px] font-bold border border-white/10 italic leading-relaxed">
                    "Hãy đến sớm ít nhất 15 phút để chuẩn bị máy chiếu và kiểm tra phần mềm."
                </div>
            </div>

            <!-- QUICK LOOK -->
            <div class="bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-lg">
                <h4 class="font-black uppercase text-[10px] text-slate-400 tracking-[0.2em] mb-6">Mục tiêu Đồ án</h4>
                <div class="space-y-3">
                    <p class="text-[11px] font-bold text-slate-600 leading-relaxed italic border-l-2 border-indigo-500 pl-4">
                        "{{myProject.objective}}"
                    </p>
                </div>
            </div>
        </div>
    </div>
    {{else}}
    <div class="py-20 text-center animate-pulse">
        <p class="text-slate-400 font-black uppercase text-xs tracking-[0.3em]">Hệ thống đang đồng bộ dữ liệu đồ án...</p>
    </div>
    {{/if}}

</div>
