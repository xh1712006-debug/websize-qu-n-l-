            <div class="mb-16">
                <p class="text-sm uppercase tracking-widest mb-4">Họ và tên sinh viên</p>
                <h2 class="text-4xl font-black uppercase underline decoration-2 underline-offset-8">{{fullName}}</h2>
                <p class="mt-4 font-bold">Mã số sinh viên: {{studentCode}}</p>
            </div>

            <div class="mb-16 px-20">
                <p class="text-sm uppercase tracking-widest mb-4">Tên đồ án tốt nghiệp</p>
