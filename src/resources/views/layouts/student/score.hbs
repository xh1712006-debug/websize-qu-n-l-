        </div>

        <div class="relative z-10 flex flex-col h-full text-center">
            <!-- Header -->
            <div class="flex justify-between items-start mb-20 text-left">
                <div>
                    <img src="/img/logo_humg.png" class="h-20 mb-4" alt="">
                    <p class="text-sm font-black uppercase">Đại học Mỏ - Địa chất</p>
                    <p class="text-xs font-bold uppercase">Khoa Công nghệ thông tin</p>
                </div>
                <div class="text-right">
                    <p class="text-sm font-black uppercase">Cộng hòa xã hội chủ nghĩa Việt Nam</p>
                    <p class="text-xs font-bold underline">Độc lập - Tự do - Hạnh phúc</p>
