<div class="max-w-5xl mx-auto py-10 px-4 space-y-10 no-print">
    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-blue-600 text-white rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-blue-200">
                🏆
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Kết quả Bảo vệ</h1>
                <p class="text-slate-500 font-medium mt-1">Chứng nhận thành tích nghiên cứu đồ án tốt nghiệp</p>
            </div>
        </div>
        <button onclick="window.print()" class="px-8 py-4 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-2xl hover:bg-blue-600 transition-all flex items-center gap-3 active:scale-95">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2-2v4a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
            In phiếu điểm (PDF)
        </button>
    </div>

    {{#if noProject}}
    <div class="bg-white rounded-[3rem] p-20 text-center border-2 border-dashed border-slate-200 space-y-6">
        <div class="text-6xl">🔍</div>
        <h3 class="text-2xl font-black text-slate-900">Dữ liệu đang được cập nhật</h3>
        <p class="text-slate-500 font-medium max-w-sm mx-auto">Bạn chưa tham gia đợt bảo vệ nào hoặc đồ án chưa được ghi nhận trên hệ thống.</p>
    </div>
    {{else}}
    {{#if isApproved}}
    {{#each data}}
    <!-- MAIN CERTIFICATE CARD -->
    <div class="relative bg-white rounded-[3.5rem] shadow-2xl border border-slate-100 overflow-hidden group">
        <!-- Decoration HUMG Logo Watermark -->
        <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none select-none">
            <img src="/img/logo_humg.png" class="w-96 grayscale" alt="">
        </div>

        <div class="relative z-10 p-10 md:p-16">
            <!-- HEADER LOGOS -->
            <div class="flex justify-between items-start mb-16">
                <div class="flex items-center gap-4">
                    <img src="/img/logo_humg.png" class="h-16 w-auto" alt="HUMG">
                    <div class="h-10 w-px bg-slate-200 mx-2"></div>
                    <div class="text-left uppercase">
                        <p class="text-[10px] font-black text-slate-400 tracking-[0.2em]">Khoa Công nghệ thông tin</p>
                        <p class="text-xs font-black text-slate-900 tracking-tight">Kỳ bảo vệ đồ án tốt nghiệp</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{periodName}}</p>
                    <p class="text-xs font-black text-blue-600 mt-1 uppercase">{{semester}} — {{year}}</p>
                </div>
            </div>

            <!-- STUDENT & PROJECT INFO -->
            <div class="text-center mb-16 space-y-4">
                <p class="text-[10px] font-black text-indigo-500 uppercase tracking-[0.4em] mb-4">Chứng nhận kết quả cho</p>
                <h2 class="text-5xl font-black text-slate-900 tracking-tighter">{{fullName}}</h2>
                <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-slate-50 border border-slate-100 rounded-full">
                    <span class="text-xs font-black text-slate-400">MSSV:</span>
                    <span class="text-xs font-black text-slate-900">{{studentCode}}</span>
                </div>
                <div class="pt-10 max-w-2xl mx-auto">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Đề tài tốt nghiệp</p>
                    <h3 class="text-2xl font-bold text-slate-800 leading-tight italic">“{{projectName}}”</h3>
                </div>
            </div>

            <!-- SCORE MEASUREMENT (GRID 4) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
                <!-- Content Score -->
                <div class="p-6 bg-slate-50/50 rounded-[2rem] border border-slate-100 text-center transition-all hover:bg-white hover:shadow-xl">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-3">Nội dung</p>
                    <div class="text-3xl font-black text-slate-900 tracking-tighter">{{scoreContent}}</div>
                    <div class="h-1 w-8 bg-indigo-500 mx-auto mt-3 rounded-full opacity-30"></div>
                </div>

                <!-- Presentation Score -->
                <div class="p-6 bg-slate-50/50 rounded-[2rem] border border-slate-100 text-center transition-all hover:bg-white hover:shadow-xl">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-3">Hình thức</p>
                    <div class="text-3xl font-black text-slate-900 tracking-tighter">{{scorePresentation}}</div>
                    <div class="h-1 w-8 bg-emerald-500 mx-auto mt-3 rounded-full opacity-30"></div>
                </div>

                <!-- Q&A Score -->
                <div class="p-6 bg-slate-50/50 rounded-[2rem] border border-slate-100 text-center transition-all hover:bg-white hover:shadow-xl">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-3">Phản biện</p>
                    <div class="text-3xl font-black text-slate-900 tracking-tighter">{{scoreQA}}</div>
                    <div class="h-1 w-8 bg-amber-500 mx-auto mt-3 rounded-full opacity-30"></div>
                </div>

                <!-- FINAL SCORE -->
                <div class="relative p-6 rounded-[2rem] bg-slate-900 text-white shadow-2xl overflow-hidden group/final flex flex-col items-center justify-center">
                    <div class="absolute inset-0 bg-blue-600/10 opacity-0 group-hover/final:opacity-100 transition-opacity"></div>
                    <p class="text-[9px] font-black text-blue-300 uppercase tracking-[0.2em] mb-2 relative z-10">Tổng kết</p>
                    <div class="text-4xl font-black text-white tracking-tighter relative z-10 drop-shadow-xl">{{finalResult}}</div>
                    <div class="mt-2 px-3 py-1 bg-blue-500/20 border border-blue-500/30 rounded-lg relative z-10">
                        <span class="text-[8px] font-black text-blue-200 uppercase tracking-widest">{{statusText}}</span>
                    </div>
                </div>
            </div>

            <!-- COUNCIL DETAILS -->
            {{#if council}}
            <div class="bg-slate-50/30 border border-slate-100 rounded-[2.5rem] p-10 mb-16">
                <div class="flex items-center gap-3 mb-8">
                    <span class="p-2 bg-white text-blue-600 rounded-xl shadow-sm">🎓</span>
                    <h4 class="text-sm font-black text-slate-900 uppercase tracking-widest">Hội đồng chấm bảo vệ: {{council.name}}</h4>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="space-y-1">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Chủ tịch</p>
                        <p class="text-sm font-bold text-slate-800">{{council.chairman}}</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Thư ký</p>
                        <p class="text-sm font-bold text-slate-800">{{council.secretary}}</p>
                    </div>
                    <div class="lg:col-span-2 space-y-1">
                        <p class="text-[9px] font-black text-slate-400 uppercase">Ủy viên</p>
                        <div class="flex flex-wrap gap-2 mt-1">
                            {{#each council.members}}
                            <span class="text-sm font-bold text-slate-800">{{this}}{{#unless @last}}, {{/unless}}</span>
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>
            {{/if}}

            <!-- COMMENT SECTION -->
            <div class="relative bg-blue-50/50 p-12 rounded-[2.5rem] border border-blue-100 group/msg">
                <div class="absolute -top-4 left-10 px-5 py-2 bg-indigo-600 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-100">
                    Nhận xét & Đánh giá
                </div>
                <div class="flex gap-6">
                    <div class="text-5xl text-blue-200 font-serif -mt-4">“</div>
                    <p class="text-lg font-medium text-slate-600 leading-relaxed italic">
                        {{comment}}
                    </p>
                    <div class="text-5xl text-blue-200 font-serif self-end -mb-8">”</div>
                </div>
            </div>
        </div>

        <!-- FOOTER BAR -->
        <div class="bg-slate-900 p-8 flex justify-center">
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-[0.5em]">HUMG • DEPARTMENT OF COMPUTER SCIENCE • CERTIFIED RESULT</p>
        </div>
    </div>
    {{/each}}
    {{else}}
    <!-- NOT APPROVED YET -->
    <div class="bg-white rounded-[3rem] p-20 text-center border-2 border-dashed border-slate-200 space-y-6">
        <div class="w-20 h-20 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center mx-auto text-4xl animate-pulse">
            ⏳
        </div>
        <h3 class="text-2xl font-black text-slate-900">Dữ liệu đang được cập nhật</h3>
        <p class="text-slate-500 font-medium max-w-sm mx-auto">Hội đồng đang hoàn tất các bước cuối cùng. Kết quả chính thức sẽ hiển thị sau khi được phê duyệt bởi Ban quản lý.</p>
    </div>
    {{/if}}
    {{/if}}
</div>

<!-- PRINT ONLY SECTION (HIDDEN ON SCREEN) -->
