<div class="space-y-12 animate-in fade-in slide-in-from-bottom-6 duration-700">
{{#each data}}

    <!-- HERO WELCOME SECTION -->
    <div class="relative overflow-hidden bg-[#0F172A] rounded-[3.5rem] p-10 md:p-14 text-white shadow-2xl group">
        <!-- Abstract Background Elements -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-indigo-600/20 rounded-full -mr-32 -mt-32 blur-[80px] animate-pulse"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-600/10 rounded-full -ml-32 -mb-32 blur-[60px]"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-10">
            <div class="space-y-4">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md rounded-2xl border border-white/10 text-xs font-black uppercase tracking-widest text-indigo-300">
                    <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                    Hệ thống đã sẵn sàng
                </div>
                <h1 class="text-4xl md:text-5xl font-black tracking-tight italic">
                    Chào buổi sáng, <br>
                    <span class="bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400">{{fullName}}</span> 👋
                </h1>
                <p class="text-slate-400 font-medium text-lg max-w-md">Bắt đầu ngày mới với cái nhìn tổng quan về hành trình đồ án của bạn.</p>
            </div>

            <div class="flex flex-col gap-4">
                {{#if ../activePeriod}}
                <div class="p-6 bg-white/5 backdrop-blur-xl rounded-[2.5rem] border border-white/10 shadow-inner group-hover:border-indigo-500/50 transition-all duration-500">
                    <p class="text-[10px] font-black text-indigo-300 uppercase tracking-[0.2em] mb-2">Đợt đăng ký hiện tại</p>
                    <h3 class="text-xl font-bold italic">{{../activePeriod.name}}</h3>
                    <div class="mt-4 flex items-center gap-2">
                        <span class="px-3 py-1 bg-emerald-500/20 text-emerald-400 rounded-lg text-[9px] font-black uppercase tracking-widest">Đang mở</span>
                        <span class="text-[10px] font-bold text-slate-500 italic">Còn {{../daysLeft}} ngày</span>
                    </div>
                </div>
                {{/if}}
            </div>
        </div>
    </div>

    <!-- ELITE MISSION CONTROL (STATS) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <!-- Stat 1: Logic -->
        <div class="relative overflow-hidden bg-white p-8 rounded-[3rem] shadow-sm border border-slate-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-500/5 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">📁</div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Số lượng đồ án</p>
            <div class="flex items-baseline gap-3 mt-2">
                <span class="text-5xl font-black text-slate-900 italic tracking-tighter">{{projectCount}}</span>
                <span class="text-[10px] font-black text-blue-500 bg-blue-50 px-2 py-0.5 rounded-lg uppercase tracking-widest">Active</span>
            </div>
        </div>

        <!-- Stat 2: Progress -->
        <div class="relative overflow-hidden bg-white p-8 rounded-[3rem] shadow-sm border border-slate-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-500/5 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">📈</div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tiến độ tổng thể</p>
            <div class="flex items-baseline gap-3 mt-2 mb-4">
                <span class="text-5xl font-black text-slate-900 italic tracking-tighter">{{percent}}%</span>
            </div>
            <div class="w-full bg-slate-50 h-2 rounded-full overflow-hidden p-0.5">
                <div class="bg-gradient-to-r from-emerald-400 to-teal-500 h-full rounded-full transition-all duration-1000 shadow-[0_0_10px_rgba(16,185,129,0.3)]" style="width:{{percent}}%"></div>
            </div>
        </div>

        <!-- Stat 3: Reports -->
        <div class="relative overflow-hidden bg-white p-8 rounded-[3rem] shadow-sm border border-slate-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-500/5 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
            <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">✉️</div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Báo cáo đã nộp</p>
            <div class="flex items-baseline gap-3 mt-2">
                <span class="text-5xl font-black text-slate-900 italic tracking-tighter">{{report.length}}</span>
                <span class="text-[10px] font-black text-amber-500 bg-amber-50 px-2 py-0.5 rounded-lg uppercase tracking-widest">Bản nộp</span>
            </div>
        </div>

        <!-- Stat 4: Feedback -->
        <div class="relative overflow-hidden bg-white p-8 rounded-[3rem] shadow-sm border border-slate-100 group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-indigo-500/5 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
            <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center text-xl mb-6 shadow-inner">💬</div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Phản hồi mới</p>
            <div class="flex items-baseline gap-3 mt-2">
                <span class="text-5xl font-black text-slate-900 italic tracking-tighter">{{feedbackCount}}</span>
                <span class="text-[10px] font-black text-indigo-500 bg-indigo-50 px-2 py-0.5 rounded-lg uppercase tracking-widest">Message</span>
            </div>
        </div>

    </div>

    <!-- STRATEGIC JOURNEY & FEEDBACK -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

        <!-- JOURNEY ROADMAP -->
        <div class="lg:col-span-7 bg-white p-10 md:p-14 rounded-[4rem] shadow-sm border border-slate-100 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-slate-50/50 rounded-full blur-3xl -mr-32 -mt-32"></div>
            
            <div class="relative z-10 flex items-center justify-between mb-12">
                <div>
                    <h2 class="text-2xl font-black text-slate-900 tracking-tight italic">Chiến lược lộ trình</h2>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mt-1">Các cột mốc quan trọng tiếp theo</p>
                </div>
                <a href="/student/report" class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 hover:bg-slate-900 hover:text-white transition-all shadow-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
            </div>

            <div class="relative z-10 space-y-10 pl-8 border-l-2 border-slate-100 border-dashed ml-4">
                {{#if upcomingTasks.length}}
                    {{#each upcomingTasks}}
                    <div class="relative group">
                        <!-- Connector Dot -->
                        <div class="absolute -left-[41px] top-0 w-5 h-5 rounded-full bg-white border-4 border-{{statusColor}}-500 shadow-lg shadow-{{statusColor}}-100 group-hover:scale-125 transition-transform"></div>
                        
                        <div class="p-6 bg-slate-50/50 rounded-[2.5rem] border border-slate-50 hover:bg-white hover:shadow-xl hover:shadow-slate-100/50 hover:border-{{statusColor}}-100 transition-all duration-500">
                            <div class="flex items-center justify-between gap-4">
                                <div>
                                    <h4 class="text-lg font-black text-slate-900 italic tracking-tight group-hover:text-{{statusColor}}-600 transition-colors">{{name}}</h4>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">Hạn nộp: {{deadline}}</p>
                                </div>
                                <div class="px-4 py-2 bg-white rounded-2xl shadow-sm border border-slate-50">
                                    {{#if daysLeft}}
                                        <span class="text-sm font-black text-{{statusColor}}-500 italic">Còn {{daysLeft}} ngày</span>
                                    {{else}}
                                        <span class="text-sm font-black text-slate-400 italic">N/A</span>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                    </div>
                    {{/each}}
                {{else}}
                    <div class="py-12 text-center">
                        <div class="text-5xl mb-4 grayscale">🏆</div>
                        <p class="text-slate-900 font-extrabold uppercase tracking-widest text-xs">Phạm vi đã hoàn tất</p>
                        <p class="text-slate-400 text-[10px] mt-1 font-medium italic">Không còn nhiệm vụ tồn đọng cho tuần này.</p>
                    </div>
                {{/if}}
            </div>
        </div>

        <!-- ELITE FEEDBACK TERMINAL -->
        <div class="lg:col-span-5 bg-[#0F172A] p-10 md:p-14 rounded-[4rem] text-white shadow-2xl relative overflow-hidden group border border-white/5">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#4f46e5,#0f172a_50%)] opacity-20"></div>
            
            <div class="relative z-10 space-y-10">
                <div class="flex items-center justify-between">
                    <span class="px-4 py-2 bg-white/10 backdrop-blur-md rounded-2xl border border-white/10 text-[10px] font-black uppercase tracking-widest text-indigo-300">
                        Phản hồi mới nhất
                    </span>
                    <a href="/student/feedback" class="text-[10px] font-black text-slate-500 uppercase tracking-widest hover:text-white transition-colors underline decoration-indigo-500 decoration-2 underline-offset-4">Hộp thư ✉️</a>
                </div>

                <div class="relative">
                    <span class="text-[6rem] text-indigo-500/20 absolute -top-12 -left-4 font-serif italic select-none">“</span>
                    <div class="relative z-10 pt-4 leading-relaxed text-slate-200 text-lg md:text-xl font-medium italic">
                        {{feedbackContent}}
                    </div>
                    <span class="text-[6rem] text-indigo-500/20 absolute -bottom-16 right-0 font-serif italic select-none">”</span>
                </div>

                <div class="pt-10 border-t border-white/10 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center text-xl font-black shadow-lg shadow-indigo-500/20">
                            {{substring teacherName 0 1}}
                        </div>
                        <div>
                            <h4 class="font-black italic tracking-tight">{{teacherName}}</h4>
                            <p class="text-[10px] font-bold text-slate-500">{{FeedbackDate}}</p>
                        </div>
                    </div>
                    <div class="w-10 h-10 bg-white/5 rounded-xl border border-white/10 flex items-center justify-center animate-pulse">
                        <span class="w-2 h-2 bg-indigo-500 rounded-full shadow-[0_0_10px_#4f46e5]"></span>
                    </div>
                </div>
            </div>
        </div>

    </div>

{{/each}}
</div>
