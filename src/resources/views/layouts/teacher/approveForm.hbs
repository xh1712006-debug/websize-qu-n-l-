document.getElementById('approveForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const projectId = formData.get('projectId');
    const teacherName = formData.get('teacherName');
    
    // Thu thập requirements
    const reqNames = formData.getAll('reqName[]');
    const reqDeadlines = formData.getAll('reqDeadline[]');
    const requirements = reqNames.map((name, index) => ({
        name: name,
        deadline: reqDeadlines[index]
    }));

    try {
        const response = await fetch('/teacher/request/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                projectId,
                teacherName,
                requirements
            })
        });

        const data = await response.json();
        if (data.success) {
            alert('🎉 Phê duyệt và khởi tạo đồ án thành công!');
            window.location.href = '/teacher/request';
        } else {
            alert('❌ Lỗi: ' + data.message);
        }
    } catch (err) {
        console.error(err);
        alert('Có lỗi xảy ra trong quá trình xử lý!');
    }
});
</script>

