<div class="animate-in fade-in slide-in-from-bottom-6 duration-700 space-y-10">

    <!-- EXECUTIVE HEADER -->
    <div class="bg-[#0F172A] p-10 md:p-12 rounded-[3.5rem] shadow-2xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl -mr-32 -mt-32 transition-transform group-hover:scale-110 duration-1000"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl -ml-24 -mb-24 transition-transform group-hover:scale-110 duration-1000"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="flex items-center gap-8">
                <div class="w-24 h-24 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-[2.5rem] flex items-center justify-center text-4xl shadow-2xl shadow-indigo-500/20 transform -rotate-3 group-hover:rotate-0 transition-all duration-500">
                    🏛️
                </div>
                <div class="space-y-2">
                    <h2 class="text-4xl font-black text-white tracking-tight font-display">Chào mừng, Chủ tịch {{teacherName}}</h2>
                    <div class="flex items-center gap-4">
                        <span class="px-4 py-1.5 bg-white/10 text-indigo-300 rounded-full text-[10px] font-black uppercase tracking-[0.2em] backdrop-blur-md border border-white/5 italic">Trung tâm Điều hành Hội đồng</span>
                        {{#if stats.councilCount}}
                            <span class="text-slate-400 text-xs font-medium italic">Đang điều hành {{stats.councilCount}} hội đồng bảo vệ</span>
                        {{/if}}
                    </div>
                </div>
            </div>

            <div class="flex flex-col items-end gap-3">
                <div class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-xl flex items-center gap-3">
                    <div class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_15px_rgba(52,211,153,0.5)]"></div>
                    <span class="text-white font-black text-[10px] uppercase tracking-widest italic">Hệ thống Điều hành Trực tuyến</span>
                </div>
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest">Vai trò: CHỦ TỊCH HỘI ĐỒNG (CT)</p>
            </div>
        </div>
    </div>

    <!-- STATS GRID -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Tổng sinh viên</p>
            <div class="flex items-baseline gap-3">
                <span class="text-5xl font-black text-slate-900">{{stats.total}}</span>
                <span class="text-xs font-bold text-slate-400 uppercase italic">Thí sinh</span>
            </div>
            <div class="mt-6 w-full h-1 bg-slate-50 rounded-full overflow-hidden">
                <div class="h-full bg-slate-900 rounded-full" style="width: 100%"></div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-amber-500/5 rounded-full -mr-8 -mt-8 blur-xl"></div>
            <p class="text-[10px] font-black text-amber-500 uppercase tracking-widest mb-4">Chờ Chủ tịch duyệt</p>
            <div class="flex items-baseline gap-3">
                <span class="text-5xl font-black text-amber-600">{{stats.pendingFinal}}</span>
                <span class="px-2 py-1 bg-amber-50 text-amber-500 rounded-lg text-[9px] font-black uppercase">Cần ký duyệt</span>
            </div>
            <div class="mt-6 w-full h-1 bg-amber-50 rounded-full overflow-hidden">
                <div class="h-full bg-amber-500 rounded-full" style="width: {{percent stats.pendingFinal stats.total}}%"></div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/5 rounded-full -mr-8 -mt-8 blur-xl"></div>
            <p class="text-[10px] font-black text-emerald-500 uppercase tracking-widest mb-4">Đã hoàn thành</p>
            <div class="flex items-baseline gap-3">
                <span class="text-5xl font-black text-emerald-600">{{stats.completed}}</span>
                <span class="px-2 py-1 bg-emerald-50 text-emerald-500 rounded-lg text-[9px] font-black uppercase">Xong</span>
            </div>
            <div class="mt-6 w-full h-1 bg-emerald-50 rounded-full overflow-hidden">
                <div class="h-full bg-emerald-500 rounded-full" style="width: {{percent stats.completed stats.total}}%"></div>
            </div>
        </div>

        <div class="bg-indigo-600 p-8 rounded-[3rem] shadow-lg shadow-indigo-200 hover:-translate-y-1 transition-all duration-300 group">
            <p class="text-[10px] font-black text-indigo-200 uppercase tracking-widest mb-4">Hội đồng phụ trách</p>
            <div class="flex items-baseline gap-3">
                <span class="text-5xl font-black text-white">{{stats.councilCount}}</span>
                <span class="text-xs font-bold text-indigo-300 uppercase italic">Ban hội đồng</span>
            </div>
            <div class="mt-6 flex gap-1">
                {{#each myCouncils}}
                    <div class="w-full h-1 bg-white/20 rounded-full"></div>
                {{/each}}
            </div>
        </div>

    </div>

    <!-- MONITORING SECTION -->
    <div class="bg-white rounded-[3.5rem] border border-slate-100 shadow-sm overflow-hidden relative group">
        <div class="absolute top-0 right-0 w-full h-1.5 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
        
        <div class="p-10 border-b border-slate-50 flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div>
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Danh sách Điều hành Bảo vệ</h3>
                <p class="text-xs text-slate-400 font-medium italic mt-1">Chủ tịch thực hiện phê duyệt cuối cùng sau khi các thành viên đã chấm điểm.</p>
            </div>
            <div class="flex items-center gap-4">
                <button onclick="fetchStudents()" class="w-14 h-14 bg-slate-50 border border-slate-100 rounded-2xl flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-white hover:border-indigo-100 transition-all shadow-sm">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="px-10 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">Sinh viên</th>
                        <th class="px-6 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">Hội đồng / Phòng</th>
                        <th class="px-6 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Tiến độ chấm</th>
                        <th class="px-6 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Trạng thái</th>
                        <th class="px-10 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Phê duyệt cuối</th>
                    </tr>
                </thead>
                <tbody id="student-list" class="divide-y divide-slate-50">
                    <!-- JS Rendered -->
                </tbody>
            </table>
        </div>
    </div>

</div>

{{#section 'script'}}
<script>
    async function fetchStudents() {
        try {
            const res = await fetch('/teacher/chairman/api/students');
            const data = await res.json();
            const tbody = document.getElementById('student-list');
            
            if (!data.length) {
                tbody.innerHTML = `<tr><td colspan="5" class="px-10 py-24 text-center">
                    <div class="flex flex-col items-center gap-4">
                        <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-3xl grayscale opacity-50">📁</div>
                        <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">Chưa có sinh viên nào trong hội đồng của bạn</p>
                    </div>
                </td></tr>`;
                return;
            }

            tbody.innerHTML = data.map(s => {
                const isCompleted = s.projectStatus === 'COMPLETED';
                const canApprove = s.status === 'approved' && !isCompleted;
                const scoreProgress = (s.councilScoresCount / s.councilMembersCount) * 100;

                return `
                    <tr class="group hover:bg-slate-50/30 transition-all">
                        <td class="px-10 py-8">
                            <div class="flex items-center gap-5">
                                <div class="w-12 h-12 bg-[#0F172A] rounded-2xl flex items-center justify-center text-white font-black text-sm shadow-xl shadow-slate-200">
                                    ${s.fullName.substring(0, 1)}
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-black text-slate-900 uppercase tracking-tight truncate">${s.fullName}</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">${s.studentCode}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-8">
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-black text-slate-700 uppercase">${s.councilName}</span>
                                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest italic">Hội đồng đang trực</span>
                            </div>
                        </td>
                        <td class="px-6 py-8">
                            <div class="flex flex-col items-center gap-2">
                                <div class="flex items-center gap-3 w-40">
                                    <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                        <div class="h-full bg-indigo-500 transition-all duration-1000" style="width: ${scoreProgress}%"></div>
                                    </div>
                                    <span class="text-[10px] font-black text-slate-700">${s.councilScoresCount}/${s.councilMembersCount}</span>
                                </div>
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Giảng viên đã chấm</span>
                            </div>
                        </td>
                        <td class="px-6 py-8 text-center">
                            ${isCompleted ? `
                                <span class="px-4 py-2 bg-emerald-50 text-emerald-600 rounded-xl font-black text-[9px] uppercase tracking-widest border border-emerald-100 flex items-center justify-center gap-2 mx-auto w-fit">
                                    <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></div>
                                    Đã hoàn thành
                                </span>
                            ` : (canApprove ? `
                                <span class="px-4 py-2 bg-amber-50 text-amber-600 rounded-xl font-black text-[9px] uppercase tracking-widest border border-amber-100 flex items-center justify-center gap-2 mx-auto w-fit">
                                    <div class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse"></div>
                                    Chờ ký duyệt
                                </span>
                            ` : `
                                <span class="px-4 py-2 bg-slate-50 text-slate-400 rounded-xl font-black text-[9px] uppercase tracking-widest border border-slate-100 flex items-center justify-center gap-2 mx-auto w-fit italic">
                                    Đang chấm điểm
                                </span>
                            `)}
                        </td>
                        <td class="px-10 py-8 text-right">
                            ${canApprove ? `
                                <button onclick="approveFinal('${s.studentId}', '${s.fullName}')" class="px-6 py-3 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-slate-900 transition-all shadow-xl shadow-indigo-100">
                                    Ký duyệt cuối
                                </button>
                            ` : (isCompleted ? `
                                <button disabled class="px-6 py-3 bg-slate-50 text-slate-300 border border-slate-100 rounded-2xl font-black text-[10px] uppercase tracking-widest cursor-not-allowed">
                                    Đã ký xong
                                </button>
                            ` : `
                                <span class="text-[10px] font-black text-slate-300 uppercase italic tracking-widest px-4">Đợi hội đồng...</span>
                            `)}
                        </td>
                    </tr>
                `;
            }).join('');
        } catch (err) { console.error(err); }
    }

    async function approveFinal(studentId, name) {
        if (!confirm(`Xác nhận phê duyệt KẾT QUẢ CUỐI CÙNG cho sinh viên ${name}? \nHành động này sẽ gửi thông báo kết quả chính thức cho sinh viên.`)) return;
        
        try {
            const res = await fetch('/teacher/score/approveFinal', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId })
            });
            const data = await res.json();
            if (data.success) {
                alert(data.message);
                fetchStudents();
            } else {
                alert(data.message);
            }
        } catch (err) { console.error(err); }
    }

    fetchStudents();
</script>
{{/section}}
