<div class="animate-in">
    <!-- HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-amber-50 text-amber-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path></svg>
                Quản lý Điều hành
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Lịch Bảo vệ Hội đồng</h1>
            <p class="text-slate-500 font-medium italic">Danh sách lịch bảo vệ của tất cả sinh viên thuộc các hội đồng bạn làm Chủ tịch.</p>
        </div>
        
        {{#if schedules.length}}
        <div class="flex items-center gap-3">
            <div class="px-6 py-3 bg-white border border-slate-200 rounded-2xl shadow-sm">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block leading-none mb-1">Tổng sinh viên</span>
                <span class="text-xl font-black text-amber-600 leading-none">{{schedules.length}}</span>
            </div>
        </div>
        {{/if}}
    </div>

    {{#if noCouncil}}
    <div class="bg-white rounded-[3rem] border border-slate-100 p-20 text-center shadow-sm">
        <div class="w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center text-slate-300 mx-auto mb-6">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight">Chưa có lịch bảo vệ</h3>
        <p class="text-slate-400 font-medium mt-2">Bạn hiện không phải là Chủ tịch của hội đồng nào đang hoạt động.</p>
    </div>
    {{else}}
    
    <div class="grid grid-cols-1 gap-6">
        {{#each schedules}}
        <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-500 overflow-hidden group">
            <div class="flex flex-col lg:flex-row">
                <!-- TIME SECTION -->
                <div class="lg:w-64 p-8 bg-slate-50/50 border-r border-slate-50 flex flex-col justify-center items-center text-center">
                    {{#if this.defenseDate}}
                        <div class="w-16 h-16 bg-white rounded-2xl shadow-sm flex flex-col items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-500">
                            <span class="text-[10px] font-black text-amber-500 uppercase leading-none mb-1">{{substring (dateFormat this.defenseDate "MMMM") 0 3}}</span>
                            <span class="text-2xl font-black text-slate-900 leading-none">{{dateFormat this.defenseDate "DD"}}</span>
                        </div>
                        <div class="space-y-1">
                            <p class="text-sm font-black text-slate-900">{{this.defenseTime}}</p>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Phòng {{this.defenseRoom}}</p>
                        </div>
                    {{else}}
                        <div class="w-12 h-12 bg-slate-100 rounded-2xl flex items-center justify-center text-slate-300 mb-3">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Chờ sắp xếp</p>
                    {{/if}}
                </div>

                <!-- INFO SECTION -->
                <div class="flex-1 p-8 flex flex-col md:flex-row md:items-center justify-between gap-8">
                    <div class="space-y-4 flex-1">
                        <div class="flex items-center gap-3">
                            <span class="px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[9px] font-black uppercase tracking-widest">{{this.councilName}}</span>
                            <span class="px-3 py-1 bg-slate-900 text-white rounded-lg text-[9px] font-black uppercase tracking-widest">Hội đồng</span>
                        </div>
                        <div>
                            <h4 class="text-xl font-black text-slate-900 uppercase tracking-tight line-clamp-2 leading-tight mb-2">{{this.projectName}}</h4>
                            <div class="flex flex-wrap items-center gap-y-2 gap-x-6">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center text-[10px] font-black text-slate-500">{{substring this.studentName 0 1}}</div>
                                    <span class="text-xs font-bold text-slate-600">{{this.studentName}}</span>
                                    <span class="text-[10px] font-black text-slate-300 uppercase tracking-tighter">{{this.studentCode}}</span>
                                </div>
                                <div class="flex items-center gap-2 border-l border-slate-100 pl-6">
                                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">GVHD:</span>
                                    <span class="text-xs font-bold text-slate-600">{{this.advisorName}}</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col items-end gap-3 shrink-0">
                        <div class="px-4 py-2 bg-emerald-50 text-emerald-600 rounded-xl text-[10px] font-black uppercase tracking-widest border border-emerald-100">
                            {{#if (eq this.status 'DEFENDED')}}Đã bảo vệ{{else if (eq this.status 'ELIGIBLE_DEFENSE')}}Sẵn sàng{{else}}Đang chuẩn bị{{/if}}
                        </div>
                        <a href="/teacher/chairman/defense?councilId={{this.councilId}}" class="px-6 py-3 bg-white border-2 border-slate-200 text-slate-900 rounded-xl font-black text-[10px] uppercase tracking-[0.15em] hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all shadow-sm">
                            Vào trang điều hành
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}
</div>
