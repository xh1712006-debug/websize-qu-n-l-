<div class="animate-in space-y-10 pb-20">
    <!-- MESH BACKGROUND -->
    <div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
        <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-amber-50/30 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[50%] bg-indigo-50/20 blur-[100px] rounded-full"></div>
    </div>

    <!-- COUNCIL SWITCHER (NEW) -->
    {{#if (gt myCouncils.length 1)}}
    <div class="flex flex-wrap gap-4 mb-8">
        {{#each myCouncils}}
        <a href="?councilId={{this._id}}" class="flex-1 min-w-[200px] p-6 rounded-[2rem] border transition-all duration-300 {{#if (eq ../activeCouncil._id this._id)}} bg-[#0F172A] text-white border-transparent shadow-xl shadow-slate-200 {{else}} bg-white text-slate-500 border-slate-100 hover:border-amber-200 hover:bg-amber-50/30 {{/if}} group">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl {{#if (eq ../activeCouncil._id this._id)}} bg-amber-500 {{else}} bg-slate-50 group-hover:bg-amber-100 {{/if}} flex items-center justify-center text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <div class="min-w-0">
                    <p class="text-[9px] font-black uppercase tracking-widest {{#if (eq ../activeCouncil._id this._id)}} text-amber-500 {{else}} text-slate-400 {{/if}}">Hội đồng</p>
                    <p class="text-xs font-black truncate">{{this.councilName}}</p>
                </div>
            </div>
        </a>
        {{/each}}
    </div>
    {{/if}}

    <!-- HEADER: COUNCIL BRANDING -->
    <div class="bg-white/60 backdrop-blur-xl p-8 rounded-[3rem] border border-white shadow-xl shadow-amber-100/20 flex flex-col lg:flex-row items-center justify-between gap-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-32 h-32 bg-amber-500/5 rounded-full -ml-16 -mt-16 blur-2xl"></div>
        
        <div class="flex flex-col md:flex-row items-center gap-8 z-10">
            <div class="w-20 h-20 rounded-[2rem] bg-amber-500 text-white flex items-center justify-center shadow-lg shadow-amber-200">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <div class="text-center md:text-left space-y-2">
                <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tighter leading-none">
                    {{#if activeCouncil}}{{activeCouncil.councilName}}{{else}}Hội đồng chưa xác định{{/if}}
                </h1>
                <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
                    <span class="px-4 py-1.5 bg-amber-50 text-amber-700 rounded-full text-[10px] font-black uppercase tracking-widest border border-amber-100">Phòng: {{activeCouncil.room}}</span>
                    <span class="px-4 py-1.5 bg-indigo-50 text-indigo-700 rounded-full text-[10px] font-black uppercase tracking-widest border border-indigo-100">Chuyên ngành: {{activeCouncil.major}}</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full lg:w-auto">
            <div class="text-center p-4 bg-white/40 rounded-[2rem] border border-white/60">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Chủ tịch</p>
                <p class="text-[11px] font-black text-slate-800">{{activeCouncil.chairmanId.fullName}}</p>
            </div>
            <div class="text-center p-4 bg-white/40 rounded-[2rem] border border-white/60">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Thư ký</p>
                <p class="text-[11px] font-black text-slate-800">{{activeCouncil.secretaryId.fullName}}</p>
            </div>
            {{#each activeCouncil.memberIds}}
            <div class="text-center p-4 bg-white/40 rounded-[2rem] border border-white/60">
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Ủy viên</p>
                <p class="text-[11px] font-black text-slate-800">{{this.fullName}}</p>
            </div>
            {{/each}}
        </div>
    </div>

    <!-- MAIN DASHBOARD -->
    <div class="space-y-8">
        <div class="flex items-center justify-between">
            <h2 class="text-xl font-black text-slate-800 uppercase tracking-tight flex items-center gap-3">
                <span class="w-8 h-8 rounded-xl bg-amber-500 text-white flex items-center justify-center shadow-md">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                </span>
                Danh sách Phiên bảo vệ
            </h2>
            <button onclick="fetchStudents()" class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-slate-200 rounded-2xl text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-amber-600 hover:border-amber-200 transition-all shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                Làm mới dữ liệu
            </button>
        </div>

        <div id="defense-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Rendered by JS -->
        </div>
    </div>
</div>

<!-- APPROVE MODAL (UPGRADED) -->
<div id="approve-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-md animate-in fade-in duration-300">
    <div class="bg-white/90 backdrop-blur-2xl w-full max-w-lg rounded-[4rem] shadow-2xl overflow-hidden border border-white/50 animate-in zoom-in-95 duration-300">
        <div class="p-12 text-center space-y-8">
            <div class="w-24 h-24 bg-gradient-to-br from-emerald-400 to-teal-600 text-white rounded-[2.5rem] flex items-center justify-center text-4xl mx-auto mb-4 border-8 border-emerald-50 shadow-xl shadow-emerald-100">🏆</div>
            <div class="space-y-2">
                <h3 class="text-3xl font-black text-slate-900 uppercase tracking-tighter">Phê duyệt Kết quả</h3>
                <p class="text-slate-500 font-medium leading-relaxed italic px-8">Hành động này sẽ khóa điểm vĩnh viễn và gửi thông báo chính thức cho sinh viên. Bạn đã sẵn sàng?</p>
            </div>
            
            <div class="p-8 bg-gradient-to-r from-emerald-50 to-teal-50 rounded-[2.5rem] border border-emerald-100 flex items-center justify-between text-left shadow-inner">
                <div>
                    <p class="text-[10px] font-black text-emerald-700/60 uppercase tracking-widest mb-1">Điểm trung bình cuối</p>
                    <p id="approve-score" class="text-5xl font-black text-emerald-700 tracking-tighter">0.00</p>
                </div>
                <div class="text-right space-y-2">
                    <p class="text-[10px] font-black text-emerald-700/60 uppercase tracking-widest">Trạng thái hồ sơ</p>
                    <span class="inline-block px-4 py-1.5 bg-white text-emerald-600 rounded-full text-[10px] font-black uppercase border border-emerald-200 shadow-sm">Hợp lệ</span>
                </div>
            </div>

            <div class="flex flex-col gap-3">
                <button onclick="confirmApproval()" class="w-full py-5 bg-slate-900 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-2xl shadow-slate-200 hover:bg-black transition-all">Xác nhận Phê duyệt</button>
                <button onclick="closeApproveModal()" class="w-full py-4 text-slate-400 font-black text-[10px] uppercase tracking-widest hover:text-rose-600 transition-all">Hủy quay lại</button>
            </div>
        </div>
    </div>
</div>

{{#section 'script'}}
<script>
    let students = [];
    let selectedStudentId = null;

    async function fetchStudents() {
        try {
            const councilId = '{{activeCouncil._id}}';
            const res = await fetch(`/teacher/council/getStudents?councilId=${councilId}`);
            students = await res.json();
            renderDefense();
        } catch (err) { console.error(err); }
    }

    function renderDefense() {
        const grid = document.getElementById('defense-grid');
        grid.innerHTML = students.map(s => {
            const isDefending = s.status === 'active';
            const isFinished = s.status === 'finished' || s.status === 'DEFENDED' || s.status === 'COMPLETED';
            const canApprove = s.finalScore && s.defenseQuestions.length > 0 && s.status !== 'COMPLETED';
            const gradingProgress = (s.councilCount / 5) * 100;

            return `
                <div class="bg-white/80 backdrop-blur-md p-8 rounded-[3.5rem] border ${isDefending ? 'border-amber-400 ring-8 ring-amber-500/5 shadow-2xl shadow-amber-100' : 'border-white shadow-sm'} transition-all relative overflow-hidden group">
                    ${isDefending ? `
                        <div class="absolute top-0 right-0 px-6 py-2 bg-amber-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-bl-[2rem] animate-pulse z-20 shadow-md">
                            Đang Báo cáo
                        </div>
                    ` : ''}
                    
                    <div class="flex items-center gap-5 mb-10">
                        <div class="w-16 h-16 rounded-[2rem] ${isDefending ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-500'} flex items-center justify-center font-black text-xl shadow-inner border border-white">
                            ${s.fullName.substring(0, 1)}
                        </div>
                        <div class="space-y-1">
                            <h4 class="font-black text-slate-900 uppercase text-base tracking-tight leading-none">${s.fullName}</h4>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">${s.studentCode}</p>
                        </div>
                    </div>

                    <div class="space-y-8 mb-10">
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">Tiến độ Chấm điểm</p>
                                <span class="text-[11px] font-black ${s.councilCount >= 3 ? 'text-emerald-600' : 'text-amber-600'}">${s.councilCount}/5 thành viên</span>
                            </div>
                            <div class="h-3 w-full bg-slate-100 rounded-full overflow-hidden p-0.5 border border-slate-200/50 shadow-inner">
                                <div class="h-full rounded-full transition-all duration-1000 ${s.councilCount >= 3 ? 'bg-gradient-to-r from-emerald-400 to-teal-500' : 'bg-gradient-to-r from-amber-400 to-orange-500'}" style="width: ${gradingProgress}%"></div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div class="p-5 rounded-[2rem] bg-slate-50/50 border border-slate-100 flex flex-col items-center justify-center text-center">
                                <p class="text-[9px] font-black text-slate-400 uppercase mb-2">Biên bản</p>
                                <div class="w-8 h-8 rounded-full ${s.defenseQuestions.length > 0 ? 'bg-emerald-100 text-emerald-600' : 'bg-slate-200 text-slate-400'} flex items-center justify-center shadow-sm">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </div>
                            </div>
                            <div class="p-5 rounded-[2rem] bg-indigo-50/30 border border-indigo-100/50 flex flex-col items-center justify-center text-center">
                                <p class="text-[9px] font-black text-indigo-400 uppercase mb-2">Điểm trung bình</p>
                                <p class="text-2xl font-black ${s.finalScore ? 'text-indigo-600' : 'text-slate-300'} tracking-tighter">${s.finalScore || '0.00'}</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-3">
                        ${!isFinished ? `
                            <button onclick="updateStatus('${s.studentId}', 'active')" class="w-full py-5 bg-amber-500 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-amber-100 hover:bg-amber-600 hover:-translate-y-1 transition-all ${isDefending ? 'hidden' : ''}">Bắt đầu bảo vệ</button>
                            <button onclick="updateStatus('${s.studentId}', 'finished')" class="w-full py-5 bg-slate-900 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-slate-200 hover:bg-black transition-all ${!isDefending ? 'hidden' : ''}">Kết thúc & Lưu tạm</button>
                        ` : ''}

                        ${canApprove ? `
                            <button onclick="openApproveModal('${s.studentId}', '${s.finalScore}')" class="w-full py-5 bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-2xl shadow-emerald-200 hover:scale-105 transition-all">Duyệt & Chốt điểm cuối</button>
                        ` : ''}

                        ${s.status === 'COMPLETED' ? `
                            <div class="w-full py-5 bg-emerald-50 text-emerald-600 rounded-[2rem] font-black text-xs uppercase tracking-widest text-center border border-emerald-100 flex items-center justify-center gap-3">
                                <div class="w-6 h-6 bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-md">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                </div>
                                Đã hoàn tất phê duyệt
                            </div>
                        ` : ''}
                    </div>
                </div>
            `;
        }).join('');
    }

    async function updateStatus(studentId, status) {
        try {
            const res = await fetch('/teacher/council/updateDefenseStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId, status })
            });
            const data = await res.json();
            if (data.success) fetchStudents();
        } catch (err) { console.error(err); }
    }

    function openApproveModal(studentId, score) {
        selectedStudentId = studentId;
        document.getElementById('approve-score').innerText = score;
        document.getElementById('approve-modal').classList.remove('hidden');
    }

    function closeApproveModal() {
        document.getElementById('approve-modal').classList.add('hidden');
    }

    async function confirmApproval() {
        try {
            const res = await fetch('/teacher/council/approveFinal', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId: selectedStudentId })
            });
            const data = await res.json();
            if (data.success) {
                closeApproveModal();
                fetchStudents();
                alert(data.message);
            } else {
                alert(data.message);
            }
        } catch (err) { console.error(err); }
    }

    fetchStudents();
</script>
{{/section}}

<style>
    .animate-in {
        animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
