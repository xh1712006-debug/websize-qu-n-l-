<div class="animate-in">
    <!-- COUNCIL SWITCHER (NEW) -->
    {{#if (gt myCouncils.length 1)}}
    <div class="flex flex-wrap gap-4 mb-8">
        {{#each myCouncils}}
        <a href="?councilId={{this._id}}" class="flex-1 min-w-[200px] p-6 rounded-[2rem] border transition-all duration-300 {{#if (eq ../activeCouncil._id this._id)}} bg-[#0F172A] text-white border-transparent shadow-xl shadow-slate-200 {{else}} bg-white text-slate-500 border-slate-100 hover:border-indigo-200 hover:bg-indigo-50/30 {{/if}} group">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl {{#if (eq ../activeCouncil._id this._id)}} bg-indigo-500 {{else}} bg-slate-50 group-hover:bg-indigo-100 {{/if}} flex items-center justify-center text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <div class="min-w-0">
                    <p class="text-[9px] font-black uppercase tracking-widest {{#if (eq ../activeCouncil._id this._id)}} text-indigo-400 {{else}} text-slate-400 {{/if}}">Hội đồng</p>
                    <p class="text-xs font-black truncate">{{this.councilName}}</p>
                </div>
            </div>
        </a>
        {{/each}}
    </div>
    {{/if}}

    <!-- HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z"></path><path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" clip-rule="evenodd"></path></svg>
                Hội đồng: {{activeCouncil.councilName}} | Phòng: {{activeCouncil.room}}
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Chấm điểm Hội đồng</h1>
            <p class="text-slate-500 font-medium italic">Đánh giá độc lập dựa trên 3 tiêu chí: Nội dung (40%), Hình thức (20%), Phản biện (40%).</p>
        </div>
        <button onclick="fetchStudents()" class="p-4 bg-white border border-slate-200 rounded-2xl text-slate-400 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </button>
    </div>

    <!-- STUDENT TABLE -->
    <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden relative group">
        <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/30">
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Sinh viên</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">GVHD/GVPB</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Điểm của tôi</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="student-list" class="divide-y divide-slate-50">
                    <!-- Rendered by JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- GRADING MODAL -->
<div id="grading-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-300">
    <div class="bg-white w-full max-w-2xl rounded-[3.5rem] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300">
        <div class="p-10 border-b border-slate-50 flex items-center justify-between bg-slate-50/30">
            <div>
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Phiếu chấm điểm</h3>
                <p id="modal-student-name" class="text-xs text-indigo-500 font-bold uppercase tracking-widest mt-1">Họ tên sinh viên</p>
            </div>
            <button onclick="closeModal()" class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-500 transition-all shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <form id="grading-form" class="p-10 space-y-8">
            <input type="hidden" id="modal-student-id">
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nội dung (40%)</label>
                    <input type="number" id="modal-content" step="0.1" min="0" max="10" required 
                        class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-lg font-black focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all"
                        placeholder="0.0">
                </div>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Hình thức (20%)</label>
                    <input type="number" id="modal-presentation" step="0.1" min="0" max="10" required 
                        class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-lg font-black focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all"
                        placeholder="0.0">
                </div>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Phản biện (40%)</label>
                    <input type="number" id="modal-qa" step="0.1" min="0" max="10" required 
                        class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-lg font-black focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all"
                        placeholder="0.0">
                </div>
            </div>

            <div class="space-y-3">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nhận xét chi tiết</label>
                <textarea id="modal-comment" rows="4" 
                    class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] text-sm font-bold focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all resize-none"
                    placeholder="Nhập nhận xét của bạn bài bảo vệ..."></textarea>
            </div>

            <div class="flex items-center justify-between p-6 bg-indigo-50 rounded-[2rem] border border-indigo-100">
                <div class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">Dự kiến Tổng điểm:</div>
                <div id="live-total" class="text-3xl font-black text-indigo-600">0.00</div>
            </div>

            <button type="submit" class="w-full py-5 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-2xl shadow-indigo-200 hover:scale-[1.02] active:scale-95 transition-all">
                Lưu kết quả thẩm định
            </button>
        </form>
    </div>
</div>

{{#section 'script'}}
<script>
    async function fetchStudents() {
        try {
            const councilId = '{{activeCouncil._id}}';
            const res = await fetch(`/teacher/council/getStudents?councilId=${councilId}`);
            const data = await res.json();
            const tbody = document.getElementById('student-list');
            
            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="px-8 py-20 text-center text-slate-400 font-medium font-black uppercase tracking-widest text-[10px]">Chưa có sinh viên đủ điều kiện</td></tr>`;
                return;
            }

            tbody.innerHTML = data.map(s => `
                <tr class="group hover:bg-slate-50/50 transition-all">
                    <td class="px-8 py-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center text-slate-400 font-black text-xs group-hover:bg-indigo-600 group-hover:text-white transition-all shadow-sm">
                                ${s.fullName.substring(0, 1)}
                            </div>
                            <div>
                                <p class="text-sm font-black text-slate-900 uppercase">${s.fullName}</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-0.5">${s.studentCode}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-8 py-6 text-center">
                        <div class="flex flex-col gap-3">
                            <div class="group/info relative">
                                <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1 text-left">GV Hướng dẫn</p>
                                <div class="flex items-center justify-between gap-4">
                                    <span class="text-[10px] font-black text-slate-700 uppercase truncate max-w-[120px]">${s.advisorName}</span>
                                    ${s.proposedScore.gvhd > 0 ? `<span class="px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded-md font-black text-[9px]">${s.proposedScore.gvhd}</span>` : ''}
                                </div>
                            </div>
                            <div class="group/info relative pt-2 border-t border-slate-50">
                                <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1 text-left">GV Phản biện</p>
                                <div class="flex items-center justify-between gap-4">
                                    <span class="text-[10px] font-black text-slate-700 uppercase truncate max-w-[120px]">${s.reviewerName}</span>
                                    ${s.proposedScore.gvpb > 0 ? `<span class="px-2 py-0.5 bg-amber-50 text-amber-600 rounded-md font-black text-[9px]">${s.proposedScore.gvpb > 1 ? s.proposedScore.gvpb : 'Đạt'}</span>` : ''}
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="px-8 py-6 text-center">
                        ${s.myScore !== null ? `
                            <div class="inline-flex flex-col items-center">
                                <span class="text-xl font-black text-indigo-600">${s.myScore}</span>
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-tighter">Tổng hợp chi tiết</span>
                            </div>
                        ` : `
                            <span class="text-[10px] font-black text-slate-300 uppercase italic tracking-widest">Chưa chấm</span>
                        `}
                    </td>
                    <td class="px-8 py-6 text-right">
                        ${s.isLocked ? `
                             <span class="px-4 py-2 bg-slate-50 text-slate-400 rounded-xl font-black text-[9px] uppercase tracking-widest border border-slate-100">Đã chốt kết quả</span>
                        ` : `
                            <button onclick="openModal('${s.studentId}', '${s.fullName}', ${JSON.stringify(s.myCriteria)}, '${s.myScore}', '${s.proposedComment.gvhd}')" class="px-6 py-3 bg-white border-2 border-slate-200 text-slate-900 rounded-2xl font-black text-[10px] uppercase tracking-[0.15em] hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all shadow-sm">
                                ${s.myScore !== null ? 'Cập nhật điểm' : 'Thẩm định'}
                            </button>
                        `}
                    </td>
                </tr>
            `).join('');
        } catch (err) { console.error(err); }
    }

    function openModal(id, name, criteria, score, comment) {
        document.getElementById('modal-student-id').value = id;
        document.getElementById('modal-student-name').innerText = name;
        document.getElementById('modal-content').value = criteria ? criteria.content : '';
        document.getElementById('modal-presentation').value = criteria ? criteria.presentation : '';
        document.getElementById('modal-qa').value = criteria ? criteria.qa : '';
        document.getElementById('modal-comment').value = comment || '';
        updateLiveTotal();
        document.getElementById('grading-modal').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('grading-modal').classList.add('hidden');
    }

    function updateLiveTotal() {
        const c = parseFloat(document.getElementById('modal-content').value) || 0;
        const p = parseFloat(document.getElementById('modal-presentation').value) || 0;
        const q = parseFloat(document.getElementById('modal-qa').value) || 0;
        const total = (c * 0.4 + p * 0.2 + q * 0.4).toFixed(2);
        document.getElementById('live-total').innerText = total;
    }

    ['modal-content', 'modal-presentation', 'modal-qa'].forEach(id => {
        document.getElementById(id).addEventListener('input', updateLiveTotal);
    });

    document.getElementById('grading-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const studentId = document.getElementById('modal-student-id').value;
        const criteria = {
            content: parseFloat(document.getElementById('modal-content').value),
            presentation: parseFloat(document.getElementById('modal-presentation').value),
            qa: parseFloat(document.getElementById('modal-qa').value)
        };
        const comment = document.getElementById('modal-comment').value;

        try {
            const res = await fetch('/teacher/council/submitScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId, criteria, comment })
            });
            const data = await res.json();
            if (data.success) {
                closeModal();
                fetchStudents();
                alert(data.message);
            }
        } catch (err) { console.error(err); }
    });

    fetchStudents();
</script>
{{/section}}
