<div class="space-y-10 animate-in">
    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3.005 3.005 0 013.75-2.906z"></path></svg>
                Council Panel
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Hội đồng Bảo vệ</h1>
            <p class="text-slate-500 font-medium italic">Chào mừng {{#if (eq councilPosition 'Chairman')}}Chủ tịch{{else if (eq councilPosition 'Secretary')}}Thư ký{{else}}Thành viên{{/if}} Hội đồng.</p>
        </div>
    </div>

    <!-- STATISTICS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm group hover:shadow-xl transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Tổng sinh viên</p>
            <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black text-slate-900">{{stats.total}}</span>
                <span class="text-xs font-bold text-slate-400">Sinh viên đủ điều kiện</span>
            </div>
        </div>
        <div class="bg-indigo-600 p-8 rounded-[2.5rem] shadow-xl shadow-indigo-100 text-white group hover:-translate-y-1 transition-all">
            <p class="text-[10px] font-black text-indigo-200 uppercase tracking-[0.2em] mb-4">Đã chấm điểm</p>
            <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black">{{stats.graded}}</span>
                <span class="text-xs font-bold text-indigo-300">Hoàn thành</span>
            </div>
        </div>
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm group hover:shadow-xl transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Chưa chấm</p>
            <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black text-rose-500">{{stats.pending}}</span>
                <span class="text-xs font-bold text-slate-400">Đang chờ</span>
            </div>
        </div>
    </div>

    <!-- ACTION CARDS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/teacher/council/grading" class="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm flex flex-col items-center text-center group hover:bg-indigo-600 transition-all duration-500">
            <div class="w-20 h-20 bg-indigo-50 text-indigo-600 rounded-[2rem] flex items-center justify-center text-3xl mb-6 group-hover:bg-white/20 group-hover:text-white transition-all">
                ✍️
            </div>
            <h3 class="text-xl font-black text-slate-900 group-hover:text-white transition-colors">Chấm điểm</h3>
            <p class="text-slate-500 text-xs font-medium mt-2 group-hover:text-indigo-100 transition-colors">Nhập điểm và nhận xét cho từng sinh viên bảo vệ.</p>
        </a>

        {{#if (eq councilPosition 'Chairman')}}
        <a href="/teacher/council/defense" class="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm flex flex-col items-center text-center group hover:bg-slate-900 transition-all duration-500">
            <div class="w-20 h-20 bg-slate-50 text-slate-900 rounded-[2rem] flex items-center justify-center text-3xl mb-6 group-hover:bg-white/10 group-hover:text-white transition-all">
                ⚖️
            </div>
            <h3 class="text-xl font-black text-slate-900 group-hover:text-white transition-colors">Điều hành</h3>
            <p class="text-slate-500 text-xs font-medium mt-2 group-hover:text-slate-400 transition-colors">Quản lý trạng thái phiên bảo vệ và duyệt kết quả cuối.</p>
        </a>
        {{/if}}

        {{#if (eq councilPosition 'Secretary')}}
        <a href="/teacher/council/minutes" class="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm flex flex-col items-center text-center group hover:bg-emerald-600 transition-all duration-500">
            <div class="w-20 h-20 bg-emerald-50 text-emerald-600 rounded-[2rem] flex items-center justify-center text-3xl mb-6 group-hover:bg-white/20 group-hover:text-white transition-all">
                📝
            </div>
            <h3 class="text-xl font-black text-slate-900 group-hover:text-white transition-colors">Ghi biên bản</h3>
            <p class="text-slate-500 text-xs font-medium mt-2 group-hover:text-emerald-100 transition-colors">Tổng hợp câu hỏi, câu trả lời và kết luận của hội đồng.</p>
        </a>
        {{/if}}
    </div>
</div>
