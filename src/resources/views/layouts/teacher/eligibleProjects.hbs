<div class="animate-in pb-20">
    <!-- PAGE HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-blue-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>
                Hệ thống Phê duyệt Bảo vệ
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Duyệt đủ ĐK Bảo vệ</h1>
            <p class="text-slate-500 font-medium italic">Xác nhận sinh viên đã hoàn thành lộ trình thực hiện và đủ tiêu chuẩn để bước vào vòng phản biện & bảo vệ.</p>
        </div>
        
        <div class="flex items-center gap-3 px-6 py-4 bg-white rounded-3xl border border-slate-100 shadow-sm">
             <div class="w-3 h-3 bg-blue-500 rounded-full animate-bounce"></div>
             <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Yêu cầu: Tiến độ ≥ 80%</span>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-8">
        <button onclick="switchTab('waiting')" id="tab-waiting" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            Chờ phê duyệt
            <span id="count-waiting" class="ml-2 px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('completed')" id="tab-completed" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
            Đã duyệt xong
            <span id="count-completed" class="ml-2 px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('notready')" id="tab-notready" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-amber-400"></span>
            Chưa đủ tiến độ
            <span id="count-notready" class="ml-2 px-2 py-0.5 bg-amber-100 text-amber-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- DATA TABLE CONTAINER -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div id="tab-indicator" class="absolute top-0 left-0 h-1.5 bg-gradient-to-r transition-all duration-500"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-7 bg-slate-50/50">Sinh viên</th>
                        <th class="px-8 py-7 bg-slate-50/50">Đồ án đăng ký</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Tiến độ (%)</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Kết quả GVHD</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="eligibleTableBody" class="divide-y divide-slate-50">
                    <!-- Data loaded via JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const projectsData = {{{json projects}}};
    let currentTab = 'waiting';

    function fetchAndRender() {
        const counts = {
            waiting: projectsData.filter(p => !p.isAdvisorApproved && p.percent >= 80).length,
            completed: projectsData.filter(p => p.isAdvisorApproved).length,
            notready: projectsData.filter(p => !p.isAdvisorApproved && p.percent < 80).length
        };

        document.getElementById('count-waiting').innerText = counts.waiting;
        document.getElementById('count-completed').innerText = counts.completed;
        document.getElementById('count-notready').innerText = counts.notready;

        renderTable();
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-white', 'border-blue-500', 'text-blue-600', 'bg-slate-50', 'border-slate-100', 'text-slate-400');
            btn.classList.add('bg-slate-50', 'border-slate-50', 'text-slate-400');
        });

        const activeBtn = document.getElementById(`tab-${tab}`);
        activeBtn.classList.remove('bg-slate-50', 'border-slate-50', 'text-slate-400');
        const colorClass = tab === 'waiting' ? 'border-emerald-500 text-emerald-600' : 
                          tab === 'completed' ? 'border-indigo-500 text-indigo-600' : 
                          'border-amber-400 text-amber-600';
        activeBtn.classList.add('bg-white', ...colorClass.split(' '));

        const indicator = document.getElementById('tab-indicator');
        if (tab === 'waiting') {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-emerald-400 to-teal-500 transition-all duration-500';
            indicator.style.width = '100%';
        } else if (tab === 'completed') {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-indigo-400 to-blue-500 transition-all duration-500';
            indicator.style.width = '100%';
        } else {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-amber-400 to-orange-500 transition-all duration-500';
            indicator.style.width = '100%';
        }

        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById('eligibleTableBody');
        let filtered = [];

        if (currentTab === 'waiting') {
            filtered = projectsData.filter(p => !p.isAdvisorApproved && p.percent >= 80);
        } else if (currentTab === 'completed') {
            filtered = projectsData.filter(p => p.isAdvisorApproved);
        } else {
            filtered = projectsData.filter(p => !p.isAdvisorApproved && p.percent < 80);
        }

        if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-24 text-center">
                <div class="flex flex-col items-center gap-4 opacity-30">
                    <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center text-3xl">📂</div>
                    <p class="font-black text-slate-400 uppercase tracking-[0.2em] text-xs">Không có dữ liệu trong mục này</p>
                </div>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = filtered.map(p => {
            const isCompleted = p.isAdvisorApproved || p.status === 'FAILED_PROGRESS';
            const isEligible = p.percent >= 80;
            
            return `
            <tr class="hover:bg-slate-50/50 transition-all duration-300">
                <td class="px-8 py-7">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-black shadow-sm uppercase">
                            ${p.studentName.charAt(0)}
                        </div>
                        <div>
                            <p class="font-black text-slate-900 text-sm leading-tight uppercase">${p.studentName}</p>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">${p.studentCode}</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7 max-w-sm">
                    <p class="font-black text-slate-800 text-xs uppercase leading-relaxed line-clamp-1" title="${p.projectName}">${p.projectName}</p>
                    <div class="flex items-center gap-2 mt-2">
                         <span class="px-2 py-0.5 bg-slate-100 text-slate-400 rounded text-[8px] font-black uppercase tracking-tighter italic">Status: ${p.status}</span>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <div class="flex items-center gap-3">
                        <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                            <div class="h-full ${p.percent >= 80 ? 'bg-emerald-500' : 'bg-amber-400'} rounded-full" style="width: ${p.percent}%"></div>
                        </div>
                        <span class="text-[10px] font-black ${p.percent >= 80 ? 'text-emerald-600' : 'text-amber-500'}">${p.percent}%</span>
                    </div>
                </td>
                <td class="px-8 py-7 text-center">
                    ${p.isAdvisorApproved ? (
                        '<span class="px-3 py-1.5 bg-emerald-50 text-emerald-600 rounded-xl text-[9px] font-black uppercase border border-emerald-100">✅ Đủ ĐK Bảo vệ</span>'
                    ) : (
                        isEligible ? 
                        '<span class="px-3 py-1.5 bg-blue-50 text-blue-600 rounded-xl text-[9px] font-black uppercase border border-blue-100 animate-pulse">⏳ Chờ phê duyệt</span>' :
                        '<span class="px-3 py-1.5 bg-slate-50 text-slate-400 rounded-xl text-[9px] font-black uppercase border border-slate-100 italic">🚧 Chưa đủ tiến độ</span>'
                    )}
                </td>
                <td class="px-8 py-7 text-right">
                    ${p.isAdvisorApproved ? `
                        <button disabled class="px-8 py-4 bg-slate-50 text-slate-400 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] border border-slate-100 cursor-not-allowed">
                            Đã chốt dữ liệu
                        </button>
                    ` : (
                        isEligible ? `
                            <div class="flex items-center justify-end gap-2">
                                <button onclick="handleAction('${p.projectId}', 'approve')" class="px-6 py-4 bg-emerald-600 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-700 hover:shadow-lg hover:shadow-emerald-100 transition-all">Duyệt Đạt</button>
                                <button onclick="handleAction('${p.projectId}', 'reject')" class="px-4 py-4 bg-white border border-slate-200 text-slate-400 rounded-2xl hover:text-rose-600 hover:border-rose-100 transition-all">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                </button>
                            </div>
                        ` : `
                            <button disabled class="px-8 py-4 bg-slate-50 text-slate-300 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] border border-slate-50 cursor-not-allowed italic">
                                Trạng thái khóa
                            </button>
                        `
                    )}
                </td>
            </tr>
            `;
        }).join('');
    }

    async function handleAction(projectId, action) {
        const title = action === 'approve' ? 'Xác nhận Đủ điều kiện?' : 'Xác nhận KHÔNG đạt?';
        const text = action === 'approve' 
            ? 'Sinh viên sẽ được xác nhận đủ điều kiện và chuyển sang bước Phản biện.' 
            : 'Sinh viên sẽ bị đánh dấu không đạt tiến độ bảo vệ đợt này.';
        
        const result = await Swal.fire({
            title: `<span class="uppercase tracking-tight font-black">${title}</span>`,
            html: `<p class="text-sm font-medium text-slate-500">${text}</p>`,
            icon: action === 'approve' ? 'success' : 'warning',
            showCancelButton: true,
            confirmButtonColor: action === 'approve' ? '#059669' : '#e11d48',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Xác nhận',
            cancelButtonText: 'Hủy',
            borderRadius: '2rem',
            padding: '3rem'
        });

        if (result.isConfirmed) {
            try {
                const res = await fetch('/teacher/request/approve-eligible', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projectId, action })
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire({
                        title: 'Thành công!',
                        text: data.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Lỗi!', data.message, 'error');
                }
            } catch (err) { console.error(err); }
        }
    }

    // Init
    fetchAndRender();
    switchTab('waiting');
</script>

<style>
    .animate-in {
        animation: animate-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes animate-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
</style>
