<div class="space-y-12 animate-in fade-in slide-in-from-bottom-5 duration-700 pb-20 font-sans text-slate-900 bg-slate-50/50 -m-8 p-8 min-h-screen">

    <!-- REFINED HEADER -->
    <div class="flex flex-col xl:flex-row xl:items-end justify-between gap-8 pb-10 border-b border-slate-200">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-50 text-blue-700 rounded-full text-[10px] font-black uppercase tracking-widest border border-blue-100">
                <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
                Strategic Configuration
            </div>
            <h1 class="text-5xl font-black text-slate-900 tracking-tight leading-none uppercase">
                Cấu hình <span class="text-blue-600">Quy chuẩn</span>
            </h1>
            <p class="text-slate-400 font-medium text-lg tracking-tight">Thiết lập lộ trình 12 bước, quản trị mốc thời gian và điều kiện tiên quyết cho toàn chuyên ngành.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
        <!-- MILESTONE FORM (LEFT 4 COLS) -->
        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm sticky top-8">
                <h3 class="text-xl font-black text-slate-900 uppercase tracking-tighter mb-6">Thiết lập Mốc mới</h3>
                <form action="/teacher/leader/createMilestone" method="POST" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên mốc báo cáo</label>
                        <input type="text" name="title" required placeholder="Báo cáo tiến độ..." class="w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-bold shadow-sm outline-none focus:bg-white focus:border-blue-400 transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Hạn chót</label>
                        <input type="date" name="deadline" required class="w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-bold shadow-sm outline-none focus:bg-white focus:border-blue-400 transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Yêu cầu chi tiết</label>
                        <textarea name="description" rows="3" placeholder="Ghi chú yêu cầu..." class="w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-bold shadow-sm outline-none focus:bg-white focus:border-blue-400 transition-all resize-none"></textarea>
                    </div>
                    <button type="submit" class="w-full py-5 bg-blue-600 text-white rounded-[1.8rem] font-black text-xs uppercase tracking-widest shadow-lg shadow-blue-100 hover:bg-blue-700 hover:-translate-y-1 transition-all">Kích hoạt Mốc →</button>
                </form>
            </div>
        </div>

        <!-- MILESTONE LIST (RIGHT 8 COLS) -->
        <div class="lg:col-span-8 space-y-8">
            <div class="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm min-h-[600px]">
                <div class="flex items-center justify-between mb-10 pb-6 border-b border-slate-50">
                    <h3 class="text-xl font-black text-slate-900 uppercase tracking-tighter">Timeline Quy chuẩn hiện hành</h3>
                    <span class="px-4 py-1 bg-slate-50 text-slate-400 rounded-full text-[9px] font-black uppercase tracking-widest border border-slate-100">{{milestones.length}} Mốc</span>
                </div>
                
                <div class="relative space-y-6 before:absolute before:inset-0 before:ml-5 before:-translate-x-px before:h-full before:w-[1px] before:bg-slate-100">
                    {{#each milestones}}
                    <div class="relative flex items-start group">
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-white border border-slate-200 z-10 shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 transition-all group-hover:scale-110">
                            <span class="text-[10px] font-black text-slate-400 group-hover:text-white uppercase">{{sum @index 1}}</span>
                        </div>
                        <div class="flex-1 ml-8 p-6 bg-slate-50/50 rounded-3xl border border-slate-100 group-hover:bg-white group-hover:shadow-xl group-hover:border-blue-100 transition-all flex justify-between items-start gap-6">
                            <div class="space-y-3 flex-1">
                                <div class="flex items-center justify-between">
                                    <h4 class="text-sm font-black text-slate-900 uppercase tracking-tight">{{this.title}}</h4>
                                    <div class="px-3 py-1 bg-white rounded-full text-[9px] font-black text-blue-600 border border-slate-100 shadow-sm">
                                        Deadline: {{dateFormat this.deadline 'DD/MM/YYYY'}}
                                    </div>
                                </div>
                                <p class="text-[11px] text-slate-500 font-medium leading-relaxed">{{this.description}}</p>
                            </div>
                            <button onclick="deleteMilestone('{{this._id}}')" class="p-3 text-slate-300 hover:text-rose-600 hover:bg-rose-50 rounded-2xl transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v2m3 4s5 5 1 1H1z"></path></svg>
                            </button>
                        </div>
                    </div>
                    {{/each}}

                    {{#unless milestones}}
                    <div class="flex flex-col items-center justify-center py-20 text-slate-300">
                        <div class="w-20 h-20 bg-slate-50 rounded-2xl flex items-center justify-center mb-4">
                            <svg class="w-10 h-10 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                        <p class="font-black uppercase text-[10px] tracking-widest">Hệ thống chưa thiết lập Quy trình</p>
                    </div>
                    {{/unless}}
                </div>
            </div>
        </div>
    </div>
</div>

{{#section 'script'}}
<script>
    async function deleteMilestone(id) {
        if (!confirm('Xác nhận xóa mốc báo cáo này khỏi lộ trình quy chuẩn?')) return;
        try {
            const res = await fetch(`/teacher/leader/deleteMilestone/${id}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) window.location.reload();
        } catch (err) { console.error(err); }
    }
</script>
{{/section}}
