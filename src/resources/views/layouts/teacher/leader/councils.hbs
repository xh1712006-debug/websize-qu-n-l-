<div class="space-y-12 animate-in fade-in slide-in-from-bottom-5 duration-700 pb-20 font-sans text-slate-900 bg-slate-50/50 -m-8 p-8 min-h-screen">

    <!-- REFINED HEADER -->
    <div class="flex flex-col xl:flex-row xl:items-end justify-between gap-8 pb-6 border-b border-slate-200">
        <div class="space-y-4">
            <h1 class="text-5xl font-black text-slate-900 tracking-tight leading-none uppercase">
                Hội đồng <span class="text-blue-600">Phòng vệ</span>
            </h1>
            <p class="text-slate-400 font-medium text-lg tracking-tight">Trung tâm chỉ huy điều phối và quản lý hội đồng bảo vệ đồ án.</p>
        </div>
        
        <div class="flex items-center gap-4">
            <button onclick="openCreateModal()" class="px-8 py-4 bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-blue-700 hover:-translate-y-1 transition-all shadow-lg shadow-blue-100">
                Thành lập Hội đồng mới +
            </button>
        </div>
    </div>

    <!-- STATS COMMAND BAR -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex items-center gap-5">
            <div class="w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tổng Hội đồng</p>
                <h4 id="stat-councils" class="text-2xl font-black text-slate-900 leading-tight">0</h4>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex items-center gap-5">
            <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Nhân sự huy động</p>
                <h4 id="stat-teachers" class="text-2xl font-black text-slate-900 leading-tight">0</h4>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex items-center gap-5">
            <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Phòng bảo vệ</p>
                <h4 id="stat-rooms" class="text-2xl font-black text-slate-900 leading-tight">0</h4>
            </div>
        </div>
        <div class="bg-slate-900 p-6 rounded-[2rem] shadow-xl flex items-center gap-5 text-white">
            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-blue-300 backdrop-blur-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <div class="flex-1">
                <input type="text" id="council-search" placeholder="Tìm hội đồng/phòng..." oninput="renderCouncils()" class="w-full bg-transparent border-none text-white placeholder-slate-500 font-bold text-sm focus:ring-0 outline-none">
            </div>
        </div>
    </div>

    <!-- COUNCIL NEXUS: HIGH-DENSITY LEDGER -->
    <div class="space-y-4">
        <div class="flex items-center justify-between px-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">
            <div class="flex-1">Thông tin & Vị trí</div>
            <div class="w-48 text-center">Ban quản trị</div>
            <div class="w-48 text-center">Ủy viên</div>
            <div class="w-48 text-right pr-4">Trạng thái / Thao tác</div>
        </div>
        <div id="councils-nexus-list" class="space-y-3">
            <!-- Rendered by JS as Nexus Strips -->
        </div>
    </div>

    <!-- CREATE/EDIT MODAL (REFINED ARCHITECT STYLE) -->
    <div id="create-council-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300" onclick="closeCreateModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative bg-white w-full max-w-5xl rounded-[3rem] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-500 border border-slate-100 flex flex-col xl:flex-row max-h-[95vh] z-10">
            
            <!-- Universal Close Button -->
            <button onclick="closeCreateModal()" class="absolute top-6 right-6 w-12 h-12 rounded-2xl bg-white/10 hover:bg-white/20 xl:bg-slate-50 xl:text-slate-400 xl:hover:bg-slate-100 flex items-center justify-center text-white xl:text-slate-400 transition-all z-[60] shadow-xl xl:shadow-none border border-white/10 xl:border-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <!-- LEFT: CONFIGURATION FORM -->
            <div class="flex-1 p-10 overflow-y-auto no-scrollbar border-r border-slate-50">
                <div class="mb-10">
                    <h3 id="modal-title" class="text-3xl font-black text-slate-900 uppercase tracking-tighter">Thiết lập Hội đồng</h3>
                    <p class="text-[10px] text-blue-600 font-bold uppercase tracking-[0.2em] mt-1 italic">Council Structure Architecture</p>
                </div>

                <form id="create-council-form" class="space-y-8">
                    <input type="hidden" id="editing-id">
                    
                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-3">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên Hội đồng</label>
                            <input type="text" id="council-name" required placeholder="Hội đồng Chuyên ngành 01..." oninput="updateLivePreview()" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-bold focus:bg-white focus:border-blue-400 outline-none transition-all shadow-sm">
                        </div>
                        <div class="space-y-3">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Địa điểm / Phòng</label>
                            <input type="text" id="council-room" required placeholder="Phòng P.102 v.v..." oninput="updateLivePreview()" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-bold focus:bg-white focus:border-blue-400 outline-none transition-all shadow-sm">
                        </div>
                    </div>

                    <!-- KEY ROLES -->
                    <div class="p-8 bg-slate-50/50 rounded-[2.5rem] border border-slate-100 space-y-6">
                        <div class="flex items-center gap-3 mb-2">
                             <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center text-white shadow-lg shadow-blue-100">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                             </div>
                             <h4 class="text-[11px] font-black text-slate-900 uppercase tracking-widest">Ban quản trị Hội đồng</h4>
                        </div>
                        <div class="grid grid-cols-2 gap-6">
                            <div class="space-y-3">
                                <label class="text-[9px] font-black text-slate-400 uppercase tracking-tight ml-1">Chủ tịch</label>
                                <select id="chairman-select" required onchange="updateLivePreview()" class="teacher-select w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl text-xs font-black uppercase outline-none focus:border-blue-400 shadow-sm transition-all">
                                    <!-- Options -->
                                </select>
                            </div>
                            <div class="space-y-3">
                                <label class="text-[9px] font-black text-slate-400 uppercase tracking-tight ml-1">Thư ký</label>
                                <select id="secretary-select" required onchange="updateLivePreview()" class="teacher-select w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl text-xs font-black uppercase outline-none focus:border-blue-400 shadow-sm transition-all">
                                    <!-- Options -->
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- MEMBER SELECTOR -->
                    <div class="space-y-4">
                        <div class="flex items-center justify-between px-1">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Ủy viên Hội đồng</label>
                            <div class="flex items-center gap-3">
                                <input type="text" id="member-search" placeholder="Lọc theo tên..." oninput="filterMembersList()" class="px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-[10px] font-bold focus:bg-white outline-none">
                            </div>
                        </div>
                        <div id="members-list" class="grid grid-cols-2 gap-4 max-h-64 overflow-y-auto p-2 no-scrollbar">
                            <!-- Teacher cards rendered by JS -->
                        </div>
                    </div>

                    <div class="pt-6">
                        <button type="submit" id="submit-btn" class="w-full py-5 bg-blue-600 text-white rounded-3xl font-black text-[12px] uppercase tracking-[0.2em] shadow-2xl shadow-blue-200 hover:bg-blue-700 hover:-translate-y-1 transition-all flex items-center justify-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            Chốt sơ đồ Hội đồng
                        </button>
                    </div>
                </form>
            </div>

            <!-- RIGHT: LIVE PREVIEW SIDEBAR -->
            <div class="w-full xl:w-[380px] bg-slate-900 p-10 flex flex-col justify-between relative group/preview overflow-hidden">
                <div class="absolute top-0 right-0 p-8">
                     <button onclick="closeCreateModal()" class="hidden xl:flex w-12 h-12 rounded-2xl bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <div class="relative z-10">
                    <p class="text-[10px] font-black text-blue-300 uppercase tracking-[0.3em] mb-8">Live Blueprint</p>
                    <div id="live-preview-container" class="scale-105 origin-top-left transition-all duration-500">
                        <!-- Preview Card mirrored here -->
                    </div>
                </div>

                <div class="relative z-10 pt-10 border-t border-white/5">
                    <p class="text-[9px] text-slate-500 font-bold uppercase tracking-widest leading-relaxed">
                        Thiết kế hội đồng dựa trên nhân sự bộ môn. Mỗi giảng viên chỉ được tham gia tối đa 01 hội đồng bảo vệ trong cùng chuyên ngành.
                    </p>
                </div>

                <!-- Abstract Decorations -->
                <div class="absolute bottom-0 right-0 w-64 h-64 bg-blue-600/10 rounded-full blur-[100px] -mb-32 -mr-32"></div>
                <div class="absolute top-0 left-0 w-32 h-32 bg-indigo-600/10 rounded-full blur-[80px] -mt-16 -ml-16"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .nexus-strip {
        transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        border-left: 4px solid transparent;
    }
    .nexus-strip:hover {
        transform: translateX(8px);
        background: white;
        box-shadow: 20px 20px 60px -15px rgba(0, 0, 0, 0.05);
        border-left-color: #2563eb;
    }
    
    .avatar-stack {
        display: inline-flex;
        flex-direction: row-reverse;
    }
    .avatar-stack > div {
        margin-right: -12px;
        transition: transform 0.3s;
    }
    .avatar-stack > div:hover {
        transform: translateY(-4px) scale(1.1);
        z-index: 20;
    }
    
    /* MODAL LOCKING & CENTERING */
    body.modal-open { 
        overflow: hidden !important; 
        height: 100vh;
    }

    /* CUSTOM SCROLLBAR FOR MODAL CONTENT */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    #members-list::-webkit-scrollbar { width: 4px; }
    #members-list::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
</style>

{{#section 'script'}}
<script>
    let allTeachers = [];
    let allCouncils = [];
    let currentEditCouncil = null;

    async function init() {
        await reloadData();
        setupConstraints();
    }

    async function reloadData() {
        const [tRes, cRes] = await Promise.all([
            fetch('/teacher/leader/getTeachers'),
            fetch('/teacher/leader/api/councils')
        ]);
        allTeachers = await tRes.json();
        allCouncils = await cRes.json();
        renderCouncils();
    }

    function setupConstraints() {
        const chairman = document.getElementById('chairman-select');
        const secretary = document.getElementById('secretary-select');
        const update = () => updateRoleConstraints();
        chairman.addEventListener('change', update);
        secretary.addEventListener('change', update);
        document.getElementById('members-list').addEventListener('change', update);
    }

    function updateRoleConstraints() {
        const chairmanId = document.getElementById('chairman-select').value;
        const secretaryId = document.getElementById('secretary-select').value;
        const memberCheckboxes = document.querySelectorAll('input[name="member-ids"]');
        
        const secretaryOptions = document.getElementById('secretary-select').options;
        for (let opt of secretaryOptions) {
            opt.disabled = (opt.value && opt.value === chairmanId);
        }
        
        const chairmanOptions = document.getElementById('chairman-select').options;
        for (let opt of chairmanOptions) {
            opt.disabled = (opt.value && opt.value === secretaryId);
        }

        memberCheckboxes.forEach(cb => {
            const card = cb.closest('.teacher-select-card');
            const isSelectedAbove = (cb.value === chairmanId || cb.value === secretaryId);
            
            if (isSelectedAbove) {
                cb.checked = false;
                cb.disabled = true;
                if (card) {
                    card.classList.add('opacity-40', 'pointer-events-none');
                    card.classList.remove('border-blue-600', 'bg-blue-50/30');
                    card.querySelector('.selection-indicator').style.opacity = '0';
                }
            } else {
                const teacher = allTeachers.find(t => t._id === cb.value);
                const isBusyElsewhere = teacher?.subRoles?.isCouncil && (!currentEditCouncil || !isCurrentCouncilMember(cb.value));
                
                if (isBusyElsewhere) {
                    cb.disabled = true;
                    if (card) card.classList.add('opacity-40', 'pointer-events-none');
                } else {
                    cb.disabled = false;
                    if (card) card.classList.remove('opacity-40', 'pointer-events-none');
                }
            }
        });
        updateLivePreview();
    }

    function isCurrentCouncilMember(teacherId) {
        if (!currentEditCouncil) return false;
        return currentEditCouncil.chairmanId._id === teacherId || 
               currentEditCouncil.secretaryId._id === teacherId || 
               currentEditCouncil.memberIds.some(m => m._id === teacherId);
    }

    function renderTeacherSelections() {
        const selects = document.querySelectorAll('.teacher-select');
        const membersList = document.getElementById('members-list');
        
        let selectHtml = '<option value="">Chọn giảng viên...</option>';
        
        const sortedTeachers = [...allTeachers].sort((a, b) => {
            const aBusy = a.subRoles?.isCouncil && !isCurrentCouncilMember(a._id);
            const bBusy = b.subRoles?.isCouncil && !isCurrentCouncilMember(b._id);
            return aBusy - bBusy;
        });

        selectHtml += sortedTeachers.map(t => {
            const isBusy = t.subRoles?.isCouncil && !isCurrentCouncilMember(t._id);
            const label = isBusy ? `${t.fullName} (Đã có HĐ)` : t.fullName;
            return `<option value="${t._id}" ${isBusy ? 'disabled class="text-slate-300"' : ''}>${label}</option>`;
        }).join('');
        
        selects.forEach(s => s.innerHTML = selectHtml);
        
        membersList.innerHTML = sortedTeachers.map(t => {
            const isBusy = t.subRoles?.isCouncil && !isCurrentCouncilMember(t._id);
            return `
                <div class="teacher-select-card group/teacher relative flex items-center gap-4 p-4 bg-white border border-slate-100 rounded-[1.5rem] cursor-pointer hover:border-blue-300 transition-all shadow-sm ${isBusy ? 'opacity-40 grayscale cursor-not-allowed' : ''}" onclick="toggleMemberSelection(this, '${t._id}')">
                    <input type="checkbox" name="member-ids" value="${t._id}" ${isBusy ? 'disabled' : ''} class="hidden">
                    <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-black text-[10px] text-slate-500 group-hover/teacher:bg-blue-600 group-hover/teacher:text-white transition-all">
                        ${t.fullName.split(' ').pop().charAt(0)}
                    </div>
                    <div class="flex flex-col flex-1 overflow-hidden">
                        <span class="text-[10px] font-black text-slate-800 uppercase truncate">${t.fullName}</span>
                        ${isBusy ? '<span class="text-[7px] text-rose-500 font-bold uppercase">Bận hội đồng khác</span>' : '<span class="text-[7px] text-emerald-500 font-bold uppercase">Sẵn sàng</span>'}
                    </div>
                    <div class="selection-indicator opacity-0 group-hover/teacher:opacity-30 transition-all">
                        <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    </div>
                </div>
            `;
        }).join('');

        updateLivePreview();
    }

    function toggleMemberSelection(el, id) {
        const input = el.querySelector('input[type="checkbox"]');
        if (input.disabled) return;
        input.checked = !input.checked;
        el.classList.toggle('border-blue-600', input.checked);
        el.classList.toggle('bg-blue-50/30', input.checked);
        el.querySelector('.selection-indicator').style.opacity = input.checked ? '1' : '0.3';
        updateRoleConstraints();
        updateLivePreview();
    }

    function filterMembersList() {
        const query = (document.getElementById('member-search').value || '').toLowerCase();
        document.querySelectorAll('.teacher-select-card').forEach(card => {
            const name = card.querySelector('.truncate').textContent.toLowerCase();
            card.classList.toggle('hidden', !name.includes(query));
        });
    }

    function updateLivePreview() {
        const name = document.getElementById('council-name').value || 'Tên Hội đồng';
        const room = document.getElementById('council-room').value || 'Phòng';
        const chairman = document.getElementById('chairman-select').options[document.getElementById('chairman-select').selectedIndex]?.text || 'N/A';
        const secretary = document.getElementById('secretary-select').options[document.getElementById('secretary-select').selectedIndex]?.text || 'N/A';
        const selectedMembers = Array.from(document.querySelectorAll('input[name="member-ids"]:checked'));
        const memberCount = selectedMembers.length;

        const previewContainer = document.getElementById('live-preview-container');
        previewContainer.innerHTML = `
            <div class="bg-white p-10 rounded-[2.5rem] shadow-2xl border border-white/20 w-full animate-in fade-in zoom-in duration-300">
                <div class="flex items-center justify-between mb-8">
                    <span class="px-4 py-1.5 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest">${room}</span>
                    <span class="flex items-center gap-1.5 font-bold text-[9px] uppercase text-emerald-500 tracking-widest">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> Blueprint
                    </span>
                </div>
                <h4 class="text-xl font-black text-slate-900 uppercase tracking-tight mb-8 leading-tight min-h-[56px]">${name}</h4>
                <div class="space-y-5">
                    <div class="flex items-center gap-4 p-3 bg-indigo-50/30 border border-indigo-100/50 rounded-2xl">
                        <div class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center text-white font-black text-sm">${chairman.split(' ').pop().charAt(0)}</div>
                        <div class="flex flex-col">
                            <span class="text-[8px] font-black text-slate-400 uppercase leading-none mb-1">Chủ tịch Hội đồng</span>
                            <span class="text-xs font-black text-slate-800 uppercase truncate">${chairman.split(' (')[0]}</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 p-3 bg-emerald-50/30 border border-emerald-100/50 rounded-2xl">
                        <div class="w-10 h-10 rounded-xl bg-emerald-600 flex items-center justify-center text-white font-black text-sm">${secretary.split(' ').pop().charAt(0)}</div>
                        <div class="flex flex-col">
                            <span class="text-[8px] font-black text-slate-400 uppercase leading-none mb-1">Thư ký Hội đồng</span>
                            <span class="text-xs font-black text-slate-800 uppercase truncate">${secretary.split(' (')[0]}</span>
                        </div>
                    </div>
                    <div class="pt-2 px-1">
                        <div class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-4">Ủy viên Hội đồng (${memberCount})</div>
                        <div class="flex -space-x-3 overflow-hidden">
                            ${selectedMembers.map(cb => {
                                const teacher = allTeachers.find(t => t._id === cb.value);
                                return `
                                    <div class="inline-block h-9 w-9 rounded-full ring-4 ring-white bg-slate-100 flex items-center justify-center text-[11px] font-black text-slate-600 border border-slate-200" title="${teacher?.fullName}">
                                        ${teacher?.fullName.split(' ').pop().charAt(0)}
                                    </div>
                                `;
                            }).join('')}
                            ${memberCount === 0 ? '<div class="text-[10px] text-slate-300 font-bold uppercase italic py-2">Chưa chọn ủy viên...</div>' : ''}
                        </div>
                    </div>
                </div>
            </div>
        `;
    }

    function renderCouncils() {
        const query = document.getElementById('council-search')?.value.toLowerCase() || '';
        const listContainer = document.getElementById('councils-nexus-list');
        
        let filteredCouncils = allCouncils.filter(c => 
            c.councilName.toLowerCase().includes(query) || 
            c.room.toLowerCase().includes(query)
        );

        // Update Stats
        document.getElementById('stat-councils').textContent = allCouncils.length;
        document.getElementById('stat-rooms').textContent = new Set(allCouncils.map(c => c.room)).size;
        let totalAssigned = 0;
        allCouncils.forEach(c => {
            totalAssigned += 2 + (c.memberIds?.length || 0);
        });
        document.getElementById('stat-teachers').textContent = totalAssigned;

        if (filteredCouncils.length === 0 && query !== '') {
            listContainer.innerHTML = `
                <div class="py-32 flex flex-col items-center justify-center text-center bg-white rounded-[3rem] border border-slate-100">
                    <div class="w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center text-slate-200 mb-6 font-black text-4xl">?</div>
                    <h3 class="text-lg font-black text-slate-900 uppercase tracking-tight">Không tìm thấy hội đồng phù hợp</h3>
                </div>`;
            return;
        }

        listContainer.innerHTML = filteredCouncils.map(c => {
            const members = c.memberIds || [];
            const isActive = c.status === 'active';
            
            return `
            <div class="nexus-strip bg-white/60 p-6 rounded-[2rem] border border-slate-100 flex items-center gap-8 group relative overflow-hidden backdrop-blur-sm">
                <!-- Info Section -->
                <div class="flex-1 flex items-center gap-6">
                    <div class="w-16 h-16 rounded-2xl bg-slate-900 text-white flex flex-col items-center justify-center shrink-0 shadow-xl shadow-slate-200">
                        <span class="text-[8px] font-black uppercase opacity-60">Phòng</span>
                        <span class="text-lg font-black tracking-tighter">${c.room}</span>
                    </div>
                    <div>
                        <h4 class="text-lg font-black text-slate-900 uppercase tracking-tight group-hover:text-blue-600 transition-colors">${c.councilName}</h4>
                        <div class="flex items-center gap-3 mt-2 text-[10px] font-bold text-slate-400 tracking-widest uppercase">
                            <span class="flex items-center gap-1.5 ${isActive ? 'text-emerald-500' : 'text-slate-300'}">
                                <span class="w-1.5 h-1.5 rounded-full ${isActive ? 'bg-emerald-500 animate-pulse' : 'bg-slate-300'}"></span>
                                ${isActive ? 'Active Nexus' : 'Archived'}
                            </span>
                            <span class="w-1 h-1 bg-slate-200 rounded-full"></span>
                            <span>${members.length + 2} Giảng viên</span>
                        </div>
                    </div>
                </div>

                <!-- Admin Section (Chairman/Secretary) -->
                <div class="w-48 flex flex-col gap-2 shrink-0 border-x border-slate-50 px-4">
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center text-[10px] font-black text-white">${c.chairmanId?.fullName?.charAt(0)}</div>
                        <span class="text-[10px] font-black text-slate-800 uppercase truncate">${c.chairmanId?.fullName || '--'}</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-emerald-600 flex items-center justify-center text-[10px] font-black text-white">${c.secretaryId?.fullName?.charAt(0)}</div>
                        <span class="text-[10px] font-black text-slate-800 uppercase truncate">${c.secretaryId?.fullName || '--'}</span>
                    </div>
                </div>

                <!-- Members Section -->
                <div class="w-48 shrink-0 flex justify-center">
                    <div class="avatar-stack">
                        ${members.slice(0, 5).map(m => `
                            <div class="w-9 h-9 rounded-full ring-4 ring-white bg-slate-100 flex items-center justify-center text-[11px] font-black text-slate-600 border border-slate-200" title="${m.fullName}">
                                ${m.fullName?.charAt(0)}
                            </div>
                        `).reverse().join('')}
                        ${members.length > 5 ? `<div class="w-9 h-9 rounded-full ring-4 ring-white bg-slate-900 flex items-center justify-center text-[9px] font-black text-white z-10">+${members.length - 5}</div>` : ''}
                        ${members.length === 0 ? '<span class="text-[9px] text-slate-300 font-bold uppercase italic">No members</span>' : ''}
                    </div>
                </div>

                <!-- Actions Section -->
                <div class="w-48 text-right flex items-center justify-end gap-3 z-10">
                    <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-all scale-95 group-hover:scale-100">
                        <button onclick="handleEditCouncil('${c._id}')" class="w-10 h-10 rounded-xl bg-slate-100 text-slate-600 hover:bg-blue-600 hover:text-white flex items-center justify-center transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        </button>
                        <button onclick="handleDeleteCouncil('${c._id}')" class="w-10 h-10 rounded-xl bg-slate-100 text-rose-600 hover:bg-rose-600 hover:text-white flex items-center justify-center transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </div>
                    <button onclick="openScoringModal('${c._id}', '${c.councilName}')" class="px-5 py-3 bg-slate-900 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 transition-all shadow-lg active:scale-95 bg-gradient-to-br from-slate-900 to-slate-800">
                        HĐ Điểm
                    </button>
                </div>
            </div>`;
        }).join('');
    }

    // --- SCORING MODAL LOGIC ---
    let currentScoringCouncilId = null;
    let scoringProjects = [];

    async function openScoringModal(id, name) {
        currentScoringCouncilId = id;
        document.getElementById('scoring-modal-title').innerText = `Kết quả: ${name}`;
        document.getElementById('scoring-modal').classList.remove('hidden');
        document.body.classList.add('modal-open');
        
        const list = document.getElementById('scoring-project-list');
        list.innerHTML = `<div class="p-20 text-center animate-pulse text-slate-400 font-bold uppercase text-[10px]">Đang tải danh sách đồ án...</div>`;

        try {
            const res = await fetch(`/teacher/leader/api/council-projects/${id}`);
            scoringProjects = await res.json();
            renderScoringList();
        } catch (err) { console.error(err); }
    }

    function closeScoringModal() {
        document.getElementById('scoring-modal').classList.add('hidden');
        document.body.classList.remove('modal-open');
    }

    function renderScoringList() {
        const list = document.getElementById('scoring-project-list');
        if (scoringProjects.length === 0) {
            list.innerHTML = `<div class="p-20 text-center text-slate-400 font-bold">Hội đồng này chưa được phân công đồ án nào.</div>`;
            return;
        }

        list.innerHTML = scoringProjects.map((p, idx) => {
            const grade = p.grade || {};
            const scores = grade.councilScores?.[0]?.criteria || { content: 0, presentation: 0, qa: 0 };
            const status = grade.status || 'pending';
            const isLocked = status === 'waiting_approval' || status === 'approved';

            return `
                <div class="p-6 bg-white border border-slate-100 rounded-[2rem] space-y-4 ${isLocked ? 'opacity-75' : ''}">
                    <div class="flex justify-between items-start">
                        <div class="flex flex-col">
                            <span class="text-[9px] font-black text-blue-600 uppercase tracking-widest mb-1">${p.studentCode}</span>
                            <h5 class="text-sm font-black text-slate-900 uppercase">${p.fullName}</h5>
                            <p class="text-[10px] font-medium text-slate-400 mt-1 italic">"${p.projectName}"</p>
                        </div>
                        <div class="text-right">
                             <div class="px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-widest border ${getStatusStyles(status)}">
                                ${status}
                             </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-4 gap-4 pt-2">
                        <div class="space-y-1">
                            <label class="text-[8px] font-black text-slate-400 uppercase">Nội dung (40%)</label>
                            <input type="number" step="0.1" min="0" max="10" ${isLocked ? 'disabled' : ''} 
                                oninput="calcFinal(${idx})"
                                class="score-attr w-full p-2 bg-slate-50 border border-slate-100 rounded-xl text-xs font-black text-center" 
                                data-attr="content" value="${scores.content}">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[8px] font-black text-slate-400 uppercase">H.Thức (20%)</label>
                            <input type="number" step="0.1" min="0" max="10" ${isLocked ? 'disabled' : ''}
                                oninput="calcFinal(${idx})"
                                class="score-attr w-full p-2 bg-slate-50 border border-slate-100 rounded-xl text-xs font-black text-center" 
                                data-attr="presentation" value="${scores.presentation}">
                        </div>
                        <div class="space-y-1">
                            <label class="text-[8px] font-black text-slate-400 uppercase">P.Biện (40%)</label>
                            <input type="number" step="0.1" min="0" max="10" ${isLocked ? 'disabled' : ''}
                                oninput="calcFinal(${idx})"
                                class="score-attr w-full p-2 bg-slate-50 border border-slate-100 rounded-xl text-xs font-black text-center" 
                                data-attr="qa" value="${scores.qa}">
                        </div>
                        <div class="bg-slate-900 rounded-2xl flex flex-col items-center justify-center -my-1 shadow-lg shadow-slate-200">
                            <span class="text-[7px] font-black text-blue-300 uppercase tracking-tighter">Tổng kết</span>
                            <span class="final-val text-sm font-black text-white">${grade.finalScore || 0}</span>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    function getStatusStyles(status) {
        switch(status) {
            case 'approved': return 'bg-emerald-50 text-emerald-600 border-emerald-100';
            case 'waiting_approval': return 'bg-amber-50 text-amber-600 border-amber-100';
            case 'rejected': return 'bg-rose-50 text-rose-600 border-rose-100';
            default: return 'bg-slate-50 text-slate-600 border-slate-100';
        }
    }

    window.calcFinal = function(idx) {
        const row = document.querySelectorAll('#scoring-project-list > div')[idx];
        const c = parseFloat(row.querySelector('[data-attr="content"]').value) || 0;
        const p = parseFloat(row.querySelector('[data-attr="presentation"]').value) || 0;
        const q = parseFloat(row.querySelector('[data-attr="qa"]').value) || 0;
        
        const final = (c * 0.4 + p * 0.2 + q * 0.4).toFixed(2);
        row.querySelector('.final-val').innerText = final;
    }

    async function handleSaveDraft() {
        const grades = scoringProjects.map((p, idx) => {
            const row = document.querySelectorAll('#scoring-project-list > div')[idx];
            const c = parseFloat(row.querySelector('[data-attr="content"]').value) || 0;
            const pres = parseFloat(row.querySelector('[data-attr="presentation"]').value) || 0;
            const q = parseFloat(row.querySelector('[data-attr="qa"]').value) || 0;
            const final = parseFloat(row.querySelector('.final-val').innerText) || 0;
            
            return {
                projectId: p.projectId,
                studentId: p.studentId,
                councilScores: [{ criteria: { content: c, presentation: pres, qa: q }, finalScore: final }],
                finalScore: final
            };
        });

        const res = await fetch('/teacher/leader/api/save-council-grades', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ grades })
        });
        const data = await res.json();
        if (data.success) { alert(data.message); reloadData(); }
    }

    async function handleSubmitToAdmin() {
        if (!confirm('Bạn có chắc chắn muốn chốt điểm và gửi lên Ban quản lý chuyên ngành? Sau khi gửi bạn sẽ không thể chỉnh sửa nữa.')) return;
        
        await handleSaveDraft(); // Save first

        const res = await fetch('/teacher/leader/api/submit-to-admin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ councilId: currentScoringCouncilId })
        });
        const data = await res.json();
        if (data.success) { alert(data.message); closeScoringModal(); reloadData(); }
    }

    function openCreateModal(editId = null) {
        currentEditCouncil = editId ? allCouncils.find(c => c._id === editId) : null;
        document.getElementById('editing-id').value = editId || '';
        document.getElementById('modal-title').innerText = editId ? 'Kiến trúc lại Hội đồng' : 'Thiết lập Hội đồng mới';
        
        // Populate fields if editing
        if (currentEditCouncil) {
            document.getElementById('council-name').value = currentEditCouncil.councilName;
            document.getElementById('council-room').value = currentEditCouncil.room;
        } else {
            document.getElementById('create-council-form').reset();
        }

        // Reset search
        if(document.getElementById('member-search')) document.getElementById('member-search').value = '';

        renderTeacherSelections(); // Render with new busy logic
        
        if (currentEditCouncil) {
            document.getElementById('chairman-select').value = currentEditCouncil.chairmanId._id;
            document.getElementById('secretary-select').value = currentEditCouncil.secretaryId._id;
            const memberIds = currentEditCouncil.memberIds.map(m => m._id);
            document.querySelectorAll('input[name="member-ids"]').forEach(cb => {
                if (memberIds.includes(cb.value)) {
                    cb.checked = true;
                    cb.closest('.teacher-select-card').classList.add('border-blue-600', 'bg-blue-50/30');
                    cb.closest('.teacher-select-card').querySelector('.selection-indicator').style.opacity = '1';
                }
            });
        }

        updateRoleConstraints();
        document.getElementById('create-council-modal').classList.remove('hidden');
        document.body.classList.add('modal-open');
    }

    function closeCreateModal() { 
        document.getElementById('create-council-modal').classList.add('hidden'); 
        document.body.classList.remove('modal-open'); 
        currentEditCouncil = null;
    }

    async function handleEditCouncil(id) {
        openCreateModal(id);
    }

    async function handleDeleteCouncil(id) {
        if (!confirm('Bạn có chắc chắn muốn giải tán hội đồng này? Tất cả vai trò của giáo viên sẽ được reset.')) return;
        
        try {
            const res = await fetch(`/teacher/leader/api/delete-council/${id}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) await reloadData();
            else alert(data.message);
        } catch (err) { console.error(err); }
    }

    document.getElementById('create-council-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const editingId = document.getElementById('editing-id').value;
        const body = {
            councilName: document.getElementById('council-name').value,
            room: document.getElementById('council-room').value,
            chairmanId: document.getElementById('chairman-select').value,
            secretaryId: document.getElementById('secretary-select').value,
            memberIds: Array.from(document.querySelectorAll('input[name="member-ids"]:checked')).map(el => el.value)
        };

        const url = editingId ? `/teacher/leader/api/update-council/${editingId}` : '/teacher/leader/api/create-council';

        try {
            const res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (data.success) { closeCreateModal(); await reloadData(); }
            else alert(data.message);
        } catch (err) { console.error(err); }
    });

    init();
</script>
{{/section}}

<!-- SCORING MODAL (CRYSTAL BLUE STYLE) -->
<div id="scoring-modal" class="hidden fixed inset-0 z-[110] flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300" onclick="closeScoringModal()"></div>
    
    <div class="relative bg-white w-full max-w-4xl rounded-[3rem] shadow-2xl overflow-hidden animate-in slide-in-from-bottom-10 duration-500 border border-slate-100 flex flex-col max-h-[90vh] z-10">
        <div class="p-8 border-b border-slate-50 flex items-center justify-between shrink-0">
            <div>
                <h3 id="scoring-modal-title" class="text-2xl font-black text-slate-900 uppercase tracking-tighter">Bảng điểm Hội đồng</h3>
                <p class="text-[10px] text-blue-600 font-bold uppercase tracking-[0.2em] mt-1">Kết quả bảo vệ & Tổng kết học thuật</p>
            </div>
            <button onclick="closeScoringModal()" class="w-12 h-12 rounded-full hover:bg-slate-50 flex items-center justify-center text-slate-400 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div id="scoring-project-list" class="p-8 overflow-y-auto space-y-4 bg-slate-50/50 flex-grow no-scrollbar">
            <!-- Project cards rendered by JS -->
        </div>

        <div class="p-8 border-t border-slate-50 bg-white shrink-0 flex items-center justify-between gap-6">
            <div class="flex items-center gap-4 text-slate-400">
                <span class="text-[10px] font-bold uppercase tracking-widest italic">Workflow: Chấm điểm → Lưu nháp → Gửi Admin phê duyệt</span>
            </div>
            <div class="flex items-center gap-4">
                <button onclick="handleSaveDraft()" class="px-8 py-4 bg-white border-2 border-slate-100 text-slate-900 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-slate-50 transition-all">Lưu nháp</button>
                <button onclick="handleSubmitToAdmin()" class="px-10 py-4 bg-blue-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-xl shadow-blue-100 hover:bg-blue-700 hover:-translate-y-1 transition-all">Gửi toàn bộ lên Admin →</button>
            </div>
        </div>
    </div>
</div>
