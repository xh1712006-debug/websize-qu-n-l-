<script>
    function setGreeting() {
        const hour = new Date().getHours();
        const text = document.getElementById('greeting-text');
        if (hour < 5) text.innerText = "Làm việc đêm khuya,";
        else if (hour < 11) text.innerText = "Chào buổi sáng,";
        else if (hour < 11) text.innerText = "Chào buổi trưa,";
        else if (hour < 18) text.innerText = "Chào buổi chiều,";
        else text.innerText = "Chào buổi tối,";
    }

    document.addEventListener('DOMContentLoaded', () => {
        setGreeting();
    });
</script>

