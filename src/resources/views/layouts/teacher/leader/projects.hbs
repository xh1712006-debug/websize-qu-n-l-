<div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700 pb-20 font-sans text-slate-900 bg-slate-50/50 -m-8 p-8 min-h-screen">

    <!-- STRATEGIC HEADER -->
    <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-8 pb-4">
        <div class="space-y-3">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-white border border-slate-200 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm">
                <span class="w-2 h-2 bg-indigo-600 rounded-full animate-pulse"></span>
                <span class="text-slate-500">Project Command Center</span>
            </div>
            <h1 class="text-4xl font-black text-slate-900 tracking-tight leading-none uppercase">
                Giám sát <span class="text-indigo-600">Lộ trình</span> Đồ án
            </h1>
            <p class="text-slate-400 font-medium text-sm tracking-tight italic">Theo dõi tiến độ thời gian thực, điều phối hội đồng và phê duyệt kết quả cuối cùng.</p>
        </div>
        
        <div class="flex items-center gap-4">
            <div class="relative group">
                <input type="text" id="project-search" oninput="renderProjects()" placeholder="Tìm SV, mã hoặc tên đồ án..." class="pl-12 pr-6 py-4 bg-white border border-slate-200 rounded-2xl text-xs font-bold w-full md:w-[360px] focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-400 transition-all outline-none shadow-sm placeholder:text-slate-300">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
            </div>
            <button onclick="fetchProjects()" class="w-12 h-12 bg-white border border-slate-200 text-slate-400 rounded-2xl hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            </button>
        </div>
    </div>

    <!-- METRIC CARDS -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-indigo-600 p-8 rounded-[2.5rem] shadow-xl shadow-indigo-100 flex items-center justify-between group hover:-translate-y-1 transition-all text-white">
            <div>
                <p class="text-[9px] font-black text-indigo-100/60 uppercase tracking-widest mb-2">Tổng số đồ án</p>
                <h4 id="stat-total" class="text-3xl font-black leading-none counter">0</h4>
            </div>
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">📚</div>
        </div>
        <div class="bg-rose-500 p-8 rounded-[2.5rem] shadow-xl shadow-rose-100 flex items-center justify-between group hover:-translate-y-1 transition-all text-white">
            <div>
                <p class="text-[9px] font-black text-rose-100/60 uppercase tracking-widest mb-2">Chưa đủ ĐK</p>
                <h4 id="stat-not-eligible" class="text-3xl font-black leading-none counter">0</h4>
            </div>
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">⚠️</div>
        </div>
        <div class="bg-amber-500 p-8 rounded-[2.5rem] shadow-xl shadow-amber-100 flex items-center justify-between group hover:-translate-y-1 transition-all text-white">
            <div>
                <p class="text-[9px] font-black text-amber-100/60 uppercase tracking-widest mb-2">Đủ ĐK chờ gán</p>
                <h4 id="stat-eligible-pending" class="text-3xl font-black leading-none counter">0</h4>
            </div>
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">⚖️</div>
        </div>
        <div class="bg-emerald-500 p-8 rounded-[2.5rem] shadow-xl shadow-emerald-100 flex items-center justify-between group hover:-translate-y-1 transition-all text-white">
            <div>
                <p class="text-[9px] font-black text-emerald-100/60 uppercase tracking-widest mb-2">Đã hoàn thành</p>
                <h4 id="stat-completed" class="text-3xl font-black leading-none counter">0</h4>
            </div>
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">✅</div>
        </div>
    </div>

    <!-- MAIN DATA HUB -->
    <div class="bg-white rounded-[3.5rem] border border-slate-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-indigo-500 via-violet-500 to-indigo-500 animate-gradient-x"></div>
        
        <!-- TOOLBAR / TABS -->
        <div class="px-10 py-8 border-b border-slate-50 flex items-center justify-between bg-slate-50/20">
            <div class="flex flex-wrap gap-2">
                <button onclick="setFilter('not_eligible', this)" id="tab-not_eligible" class="tab-btn px-6 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-slate-900 bg-slate-900 text-white flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
                    Chưa đủ ĐK
                    <span id="badge-not_eligible" class="ml-1 opacity-60">0</span>
                </button>
                <button onclick="setFilter('eligible_pending', this)" id="tab-eligible_pending" class="tab-btn px-6 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-transparent bg-white text-slate-400 hover:bg-slate-50 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                    Đủ ĐK chờ gán
                    <span id="badge-eligible_pending" class="ml-1 opacity-60">0</span>
                </button>
                <button onclick="setFilter('ongoing_council', this)" id="tab-ongoing_council" class="tab-btn px-6 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-transparent bg-white text-slate-400 hover:bg-slate-50 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-blue-500 animate-bounce"></span>
                    Đang thực hiện
                    <span id="badge-ongoing_council" class="ml-1 opacity-60">0</span>
                </button>
                <button onclick="setFilter('completed', this)" id="tab-completed" class="tab-btn px-6 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-transparent bg-white text-slate-400 hover:bg-slate-50 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                    Hoàn thành
                    <span id="badge-completed" class="ml-1 opacity-60">0</span>
                </button>
                <button onclick="setFilter('all', this)" id="tab-all" class="tab-btn px-6 py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-transparent bg-white text-slate-400 hover:bg-slate-50">
                    Tất cả
                </button>
            </div>
            
            <div class="hidden md:flex items-center gap-3">
                <div class="flex items-center gap-1.5 px-4 py-2 bg-indigo-50 border border-indigo-100 rounded-xl">
                    <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
                    <span class="text-[9px] font-black text-indigo-600 uppercase tracking-widest">Thời gian thực</span>
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="text-left bg-slate-50/10 border-b border-slate-50">
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Sinh viên & Đồ án</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-center">Tiến độ Pipeline</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Cặp đôi Hướng dẫn</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-center">Hội đồng & Điểm</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right">Quản trị</th>
                    </tr>
                </thead>
                <tbody id="projects-table-body" class="divide-y divide-slate-50/60">
                    <!-- Data will be rendered here -->
                </tbody>
            </table>
        </div>

        <!-- EMPTY STATE -->
        <div id="empty-state" class="hidden py-40 flex flex-col items-center justify-center text-center animate-in fade-in zoom-in-95 duration-500">
            <div class="w-24 h-24 bg-slate-50 rounded-[2.5rem] flex items-center justify-center text-slate-100 mb-6 border border-slate-100 shadow-inner">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
            </div>
            <p class="text-[12px] font-black text-slate-300 uppercase tracking-[0.3em] font-mono">Empty Intelligence Hub</p>
        </div>
    </div>
</div>

<!-- MODAL: DEFENSE SCHEDULING (PREMIUM INDIGO) -->
<div id="schedule-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 animate-in fade-in duration-300">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-xl" onclick="closeScheduleModal()"></div>
    <div class="relative w-full max-w-2xl bg-white rounded-[3.5rem] shadow-2xl overflow-hidden border border-white/20 animate-in zoom-in-95 duration-300">
        <div class="bg-indigo-600 p-10 text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32"></div>
            <div class="relative z-10 flex items-center justify-between">
                <div class="space-y-2">
                    <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-200">Defense Logistics Command</p>
                    <h3 class="text-4xl font-black uppercase tracking-tight">Thiết lập <span class="text-white/70">Hội đồng</span></h3>
                </div>
                <div class="w-16 h-16 bg-white/10 rounded-[2rem] flex items-center justify-center backdrop-blur-xl border border-white/10 shadow-2xl">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
            </div>
        </div>

        <form id="schedule-form" onsubmit="handleScheduleSubmit(event)" class="p-12 space-y-10 bg-white">
            <input type="hidden" id="modal-project-id" name="projectId">
            
            <div class="space-y-8">
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Chọn Hội đồng bảo vệ & Phòng máy</label>
                    <select name="councilId" id="modal-council-id" onchange="onCouncilChange(this.value)" class="w-full px-8 py-5 bg-slate-50 border-2 border-slate-50 rounded-3xl text-sm font-black text-slate-700 outline-none focus:bg-white focus:border-indigo-500 transition-all shadow-inner appearance-none cursor-pointer">
                        <option value="">-- Lựa chọn Hội đồng --</option>
                    </select>
                </div>

                <input type="hidden" name="defenseRoom" id="modal-defense-room">

                <div class="grid grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Ngày ấn định</label>
                        <input type="date" name="defenseDate" id="modal-defense-date" required class="w-full px-8 py-5 bg-slate-50 border-2 border-slate-50 rounded-3xl text-sm font-black text-slate-700 outline-none focus:bg-white focus:border-indigo-500 transition-all shadow-inner">
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Khung giờ (Slot)</label>
                        <select name="defenseTime" id="modal-defense-time" class="w-full px-8 py-5 bg-slate-50 border-2 border-slate-50 rounded-3xl text-sm font-black text-slate-700 outline-none focus:bg-white focus:border-indigo-500 transition-all shadow-inner">
                            <option value="07:30">07:30 AM</option>
                            <option value="08:30">08:30 AM</option>
                            <option value="09:30">09:30 AM</option>
                            <option value="10:30">10:30 AM</option>
                            <option value="13:30">01:30 PM</option>
                            <option value="14:30">02:30 PM</option>
                            <option value="15:30">03:30 PM</option>
                            <option value="16:30">04:30 PM</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="pt-10 flex gap-6">
                <button type="button" onclick="closeScheduleModal()" class="flex-1 py-6 bg-slate-100 text-slate-500 rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.2em] hover:bg-slate-200 transition-all active:scale-95">Hủy bỏ</button>
                <button type="submit" class="flex-[2] py-6 bg-indigo-600 text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.2em] shadow-2xl shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-1 transition-all active:scale-95">
                    Xác nhận Hội đồng →
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    @keyframes gradient-x {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .animate-gradient-x {
        background-size: 200% 200%;
        animation: gradient-x 5s ease infinite;
    }
    .tr-project { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
    .tr-project:hover { transform: scale(1.005) translateY(-2px); background-color: rgba(248, 250, 252, 0.9) !important; box-shadow: 0 10px 30px -10px rgba(79, 70, 229, 0.1); }
    body.modal-open { overflow: hidden; }
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
</style>

{{#section 'script'}}
<script>
    let allProjects = [];
    let allCouncils = [];
    let currentFilter = 'not_eligible';

    async function fetchCouncils() {
        try {
            const res = await fetch('/teacher/leader/api/councils');
            allCouncils = await res.json();
            const select = document.getElementById('modal-council-id');
            select.innerHTML = '<option value="" disabled selected>-- Lựa chọn Hội đồng --</option>' + 
                allCouncils.map(c => `<option value="${c._id}" data-room="${c.room}">${c.councilName} (Room ${c.room})</option>`).join('');
        } catch (err) { console.error(err); }
    }

    async function fetchProjects() {
        try {
            const res = await fetch('/teacher/leader/api/projects-detailed');
            allProjects = await res.json();
            updateStats();
            renderProjects();
        } catch (err) { console.error(err); }
    }

    function updateStats() {
        const stats = {
            total: allProjects.length,
            not_eligible: 0,
            eligible_pending: 0,
            ongoing_council: 0,
            completed: 0
        };

        allProjects.forEach(p => {
            if (p.gradeStatus === 'waiting_approval' || p.gradeStatus === 'approved') {
                stats.completed++;
            } else if (p.councilId) {
                stats.ongoing_council++;
            } else if (p.status === 'ELIGIBLE_DEFENSE') {
                stats.eligible_pending++;
            } else {
                stats.not_eligible++;
            }
        });

        document.getElementById('stat-total').textContent = stats.total;
        document.getElementById('stat-not-eligible').textContent = stats.not_eligible;
        document.getElementById('stat-eligible-pending').textContent = stats.eligible_pending;
        document.getElementById('stat-completed').textContent = stats.completed;

        // Update Badges
        document.getElementById('badge-not_eligible').textContent = stats.not_eligible;
        document.getElementById('badge-eligible_pending').textContent = stats.eligible_pending;
        document.getElementById('badge-ongoing_council').textContent = stats.ongoing_council;
        document.getElementById('badge-completed').textContent = stats.completed;
    }

    function setFilter(filter, el) {
        currentFilter = filter;
        document.querySelectorAll('.tab-btn').forEach(tab => {
            tab.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
            tab.classList.add('bg-white', 'text-slate-400', 'border-transparent');
        });
        el.classList.remove('bg-white', 'text-slate-400', 'border-transparent');
        el.classList.add('bg-slate-900', 'text-white', 'border-slate-900');
        renderProjects();
    }

    function renderProjects() {
        const query = document.getElementById('project-search').value.toLowerCase();
        
        let filtered = allProjects.filter(p => 
            p.projectName.toLowerCase().includes(query) || 
            p.fullName.toLowerCase().includes(query) ||
            p.studentCode.toLowerCase().includes(query)
        );

        if (currentFilter === 'not_eligible') {
            filtered = filtered.filter(p => p.status !== 'ELIGIBLE_DEFENSE' && p.gradeStatus === 'none');
        } else if (currentFilter === 'eligible_pending') {
            filtered = filtered.filter(p => p.status === 'ELIGIBLE_DEFENSE' && !p.councilId);
        } else if (currentFilter === 'ongoing_council') {
            filtered = filtered.filter(p => p.councilId && p.gradeStatus === 'pending');
        } else if (currentFilter === 'completed') {
            filtered = filtered.filter(p => p.gradeStatus === 'waiting_approval' || p.gradeStatus === 'approved');
        }

        const tbody = document.getElementById('projects-table-body');
        const empty = document.getElementById('empty-state');
        
        if (filtered.length === 0) {
            tbody.innerHTML = '';
            empty.classList.remove('hidden');
            return;
        }
        empty.classList.add('hidden');

        tbody.innerHTML = filtered.map(p => {
            const pl = p.pipeline;
            const hasCouncil = !!p.councilId;
            const isCompleted = p.gradeStatus === 'waiting_approval' || p.gradeStatus === 'approved';
            
            return `
            <tr class="tr-project group">
                <td class="px-10 py-7">
                    <div class="flex items-center gap-5">
                        <div class="w-12 h-12 bg-white border border-slate-100 rounded-2xl flex items-center justify-center font-black text-indigo-600 text-[13px] shadow-sm group-hover:bg-indigo-600 group-hover:text-white transition-all ring-4 ring-slate-50/50">
                            ${p.fullName.charAt(0)}
                        </div>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                <h4 class="font-black text-slate-900 uppercase text-[11px] tracking-tight truncate max-w-[150px]">${p.fullName}</h4>
                                <span class="px-2 py-0.5 bg-${pl.color}-50 text-${pl.color}-600 text-[7px] font-black uppercase rounded-lg border border-${pl.color}-100">${pl.label}</span>
                            </div>
                            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-[0.2em] mb-1.5">${p.studentCode}</p>
                            <p class="text-[10px] font-black text-slate-600 line-clamp-1 italic max-w-[260px]" title="${p.projectName}">${p.projectName}</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <div class="flex flex-col items-center gap-3">
                        <div class="flex items-center gap-1.5">
                            ${[1, 2, 3, 4, 5].map(step => `
                                <div class="w-7 h-1.5 rounded-full ${pl.step >= step ? `bg-${pl.color}-500 shadow-sm` : 'bg-slate-100'} transition-all"></div>
                            `).join('')}
                        </div>
                        <div class="flex items-center gap-3 w-full max-w-[150px]">
                            <div class="flex-1 h-1 bg-slate-100 rounded-full overflow-hidden">
                                <div class="h-full bg-indigo-500 transition-all duration-1000" style="width: ${p.progressPercent}%"></div>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 italic">${p.progressPercent}%</span>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <div class="space-y-3">
                        <div class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center text-[8px] font-black shadow-sm border border-indigo-10 ring-2 ring-white">HD</div>
                            <span class="text-[10px] font-bold text-slate-700 uppercase truncate max-w-[100px]">${p.supervisorName}</span>
                            <div class="ml-auto w-2 h-2 rounded-full ${p.isAdvisorApproved ? 'bg-emerald-500 shadow-md animate-pulse' : 'bg-slate-200'}"></div>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-lg bg-violet-50 text-violet-600 flex items-center justify-center text-[8px] font-black shadow-sm border border-violet-10 ring-2 ring-white">PB</div>
                            <span class="text-[10px] font-bold text-slate-700 uppercase truncate max-w-[100px]">${p.reviewerName}</span>
                            <div class="ml-auto w-2 h-2 rounded-full ${p.isReviewerApproved ? 'bg-emerald-500 shadow-md animate-pulse' : 'bg-slate-200'}"></div>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7 text-center">
                    ${hasCouncil ? `
                        <div class="inline-flex flex-col items-center gap-2 px-6 py-3.5 bg-white border border-indigo-100 rounded-[1.5rem] shadow-sm group-hover:border-indigo-300 transition-all">
                             <span class="text-[10px] font-black text-indigo-600 uppercase tracking-widest flex items-center gap-2">
                                <span class="bg-indigo-600 text-white p-1 rounded-md text-[8px]">🏛️</span> 👨‍⚖️ HC-${p.defenseRoom}
                             </span>
                             <div class="flex items-center gap-2">
                                <span class="text-[8px] font-black ${p.gradeStatus === 'pending' ? 'text-amber-500' : 'text-emerald-500'} uppercase tracking-tight italic">
                                    ${p.gradeStatus === 'pending' ? 'Status: Draft Saved' : 'Status: Submitted to Admin'}
                                </span>
                             </div>
                        </div>
                    ` : `
                        <div class="inline-flex items-center gap-2 px-5 py-3 bg-slate-50 border border-slate-100 border-dashed rounded-2xl italic opacity-50">
                            <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Chưa gán Hội đồng</span>
                        </div>
                    `}
                </td>
                <td class="px-10 py-7 text-right">
                    <div class="flex items-center justify-end gap-3">
                        ${p.status === 'ELIGIBLE_DEFENSE' && !hasCouncil ? `
                            <button onclick='openScheduleModal("${p.projectId}")' class="px-5 py-3 bg-indigo-600 text-white rounded-2xl text-[9px] font-black uppercase tracking-[0.2em] shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all hover:-translate-y-0.5">
                                Gán Hội đồng
                            </button>
                        ` : ''}

                        ${hasCouncil && p.gradeStatus === 'pending' ? `
                             <a href="/teacher/leader/councils" class="px-5 py-3 bg-amber-500 text-white rounded-2xl text-[9px] font-black uppercase tracking-[0.2em] shadow-lg shadow-amber-100 hover:bg-amber-600 transition-all hover:-translate-y-0.5">
                                Nhập / Nộp Điểm
                            </a>
                        ` : ''}

                        ${p.reportUrl ? `
                            <a href="${p.reportUrl}" target="_blank" class="w-10 h-10 bg-white border border-slate-200 rounded-xl text-slate-400 hover:text-emerald-600 hover:border-emerald-200 transition-all shadow-sm flex items-center justify-center group/btn relative" title="Xem Báo cáo">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                            </a>
                        ` : ''}
                        ${p.codeUrl ? `
                            <a href="${p.codeUrl}" target="_blank" class="w-10 h-10 bg-white border border-slate-200 rounded-xl text-slate-400 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm flex items-center justify-center group/btn relative" title="Xem Mã nguồn">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                            </a>
                        ` : ''}
                    </div>
                </td>
            </tr>
            `;
        }).join('');
    }

    function openScheduleModal(id) {
        document.getElementById('modal-project-id').value = id;
        document.getElementById('schedule-modal').classList.remove('hidden');
        document.getElementById('schedule-modal').classList.add('flex');
        document.body.classList.add('modal-open');
    }

    function closeScheduleModal() {
        document.getElementById('schedule-modal').classList.add('hidden');
        document.getElementById('schedule-modal').classList.remove('flex');
        document.body.classList.remove('modal-open');
    }

    function onCouncilChange(councilId) {
        const select = document.getElementById('modal-council-id');
        const room = select.options[select.selectedIndex].getAttribute('data-room');
        document.getElementById('modal-defense-room').value = room || '';
    }

    async function handleScheduleSubmit(e) {
        e.preventDefault();
        const formData = new FormData(e.target);
        const jsonData = Object.fromEntries(formData.entries());

        try {
            const res = await fetch('/teacher/leader/updateDefenseSchedule', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(jsonData)
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({ title: 'Thành công!', text: 'Hội đồng đã được kết nối.', icon: 'success', customClass: { popup: 'rounded-[2rem]' } });
                closeScheduleModal();
                fetchProjects();
            } else Swal.fire('Lỗi', data.message, 'error');
        } catch (err) { console.error(err); }
    }

    async function init() {
        await Promise.all([fetchCouncils(), fetchProjects()]);
    }

    init();
</script>
{{/section}}
