<div class="animate-in pb-20">
    <!-- REFINED HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider border border-indigo-100">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Trung tâm Điều phối Học thuật
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Phân công <span class="text-indigo-600">Phản biện</span></h1>
            <p class="text-slate-500 font-medium italic">Quản lý và chỉ định Giảng viên Phản biện cho các đồ án trong chuyên ngành.</p>
        </div>

        <div class="flex items-center gap-4">
            <div class="hidden sm:flex items-center gap-4 px-6 py-4 bg-white rounded-3xl border border-slate-100 shadow-sm transition-all hover:shadow-md">
                <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
                <div>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block leading-none mb-1">Trạng thái</span>
                    <span class="text-xs font-black text-slate-900 uppercase tracking-tight leading-none" id="stats-percentage">Đang tải...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI TILES -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10 text-white">
        <div class="bg-indigo-600 p-8 rounded-[2.5rem] shadow-xl shadow-indigo-200 flex items-center gap-6 group hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">📚</div>
            <div>
                <span class="text-[10px] font-black text-indigo-100/60 uppercase tracking-widest block mb-1">Tổng Số Đồ Án</span>
                <span class="text-3xl font-black leading-none" id="total-projects-count">0</span>
            </div>
        </div>
        <div class="bg-emerald-500 p-8 rounded-[2.5rem] shadow-xl shadow-emerald-100 flex items-center gap-6 group hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">✅</div>
            <div>
                <span class="text-[10px] font-black text-emerald-50/60 uppercase tracking-widest block mb-1">Đã Phân Công</span>
                <span class="text-3xl font-black leading-none" id="assigned-count">0</span>
            </div>
        </div>
        <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-xl shadow-slate-200 flex items-center gap-6 group hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl backdrop-blur-md">⏳</div>
            <div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-1">Chờ Phân Công</span>
                <span class="text-3xl font-black leading-none" id="pending-count">0</span>
            </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-8">
        <button onclick="switchTab('unassigned')" id="tab-unassigned" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-slate-900 bg-slate-900 text-white">
            <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
            Chưa phân công
            <span id="badge-unassigned" class="ml-2 px-2 py-0.5 bg-rose-100 text-rose-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('assigned')" id="tab-assigned" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 border-transparent bg-white text-slate-400 hover:bg-slate-50">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            Đã phân công
            <span id="badge-assigned" class="ml-2 px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- MAIN TABLE CONTAINER -->
    <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-indigo-500 to-violet-500"></div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-7 bg-slate-50/50">Sinh viên & Đồ án</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">GV Hướng dẫn</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">GV Phản biện hiện tại</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-right">Điều hành</th>
                    </tr>
                </thead>
                <tbody id="assignment-table-body" class="divide-y divide-slate-50">
                    <!-- Data loaded via JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- COMPACT ASSIGN MODAL (INDIGO STYLE) -->
<div id="assign-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-300">
    <div class="bg-white w-full max-w-xl rounded-[3rem] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300 border border-slate-100">
        <div class="p-10 border-b border-slate-50 flex items-center justify-between bg-indigo-50/30">
            <div>
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Chỉ định Phản biện</h3>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Phân bổ nguồn lực giảng viên tối ưu</p>
            </div>
            <button onclick="closeModal()" class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-500 transition-all shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        
        <div class="p-10 space-y-8">
            <div class="p-6 bg-indigo-50/50 rounded-3xl border border-indigo-100 flex gap-4">
                <div class="text-2xl">⚖️</div>
                <div class="space-y-1">
                    <p class="text-xs font-black text-indigo-900 leading-none">Quy tắc bắt buộc</p>
                    <p class="text-[10px] text-indigo-700 font-medium leading-relaxed italic">Giảng viên Phản biện không được trùng với Giảng viên Hướng dẫn để đảm bảo tính khách quan.</p>
                </div>
            </div>

            <div class="space-y-3">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Lựa chọn Giảng viên (Kèm tải công việc)</label>
                <div class="relative group">
                    <select id="reviewer-select" class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] text-sm font-bold shadow-inner outline-none focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all appearance-none cursor-pointer">
                        <!-- Options -->
                    </select>
                    <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </div>
                </div>
                <div class="flex items-center gap-2 px-2">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest">Gợi ý: Ưu tiên giảng viên có tải công việc thấp nhất.</p>
                </div>
            </div>

            <button onclick="submitAssignment()" class="w-full py-6 bg-gradient-to-r from-indigo-600 to-violet-600 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.3em] shadow-xl shadow-indigo-200 hover:scale-[1.02] active:scale-95 transition-all">
                Xác nhận Phân công →
            </button>
        </div>
    </div>
</div>

<style>
    body.modal-open { overflow: hidden; }
    .animate-in { animation: animate-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes animate-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .bg-indigo-gradient { background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); }
</style>

{{#section 'script'}}
<script>
    let currentData = null;
    let selectedProject = null;
    let currentTab = 'unassigned';

    async function fetchData() {
        try {
            const res = await fetch('/teacher/leader/getReviewerAssignments');
            currentData = await res.json();
            updateStats();
            renderTable();
        } catch (err) { console.error(err); }
    }

    function switchTab(tab) {
        currentTab = tab;
        
        // Update UI Tabs
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-slate-900', 'text-white', 'border-slate-900', 'bg-white', 'text-slate-400', 'border-transparent');
            btn.classList.add('bg-white', 'text-slate-400', 'border-transparent');
        });

        const activeBtn = document.getElementById(`tab-${tab}`);
        activeBtn.classList.remove('bg-white', 'text-slate-400', 'border-transparent');
        activeBtn.classList.add('bg-slate-900', 'text-white', 'border-slate-900');

        renderTable();
    }

    function updateStats() {
        const total = currentData.projects.length;
        const assigned = currentData.projects.filter(p => p.reviewerId).length;
        const unassigned = total - assigned;

        document.getElementById('total-projects-count').innerText = total;
        document.getElementById('assigned-count').innerText = assigned;
        document.getElementById('pending-count').innerText = unassigned;
        document.getElementById('stats-percentage').innerText = total > 0 ? `Đã hoàn thành ${Math.round((assigned/total)*100)}%` : '0%';

        // Update Badges
        document.getElementById('badge-unassigned').innerText = unassigned;
        document.getElementById('badge-assigned').innerText = assigned;
    }

    function renderTable() {
        const tbody = document.getElementById('assignment-table-body');
        
        let filteredProjects = [];
        if (currentTab === 'unassigned') {
            filteredProjects = currentData.projects.filter(p => !p.reviewerId);
        } else {
            filteredProjects = currentData.projects.filter(p => p.reviewerId);
        }

        if (filteredProjects.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" class="px-8 py-24 text-center">
                <div class="flex flex-col items-center gap-4 opacity-30">
                    <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center text-3xl">
                        ${currentTab === 'unassigned' ? '🎉' : '📂'}
                    </div>
                    <p class="font-black text-slate-400 uppercase tracking-[0.2em] text-xs">
                        ${currentTab === 'unassigned' ? 'Tuyệt vời! Tất cả đồ án đã được phân công' : 'Chưa có đồ án nào được phân công'}
                    </p>
                </div>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = filteredProjects.map(p => `
            <tr class="hover:bg-slate-50/50 transition-all duration-300 group">
                <td class="px-8 py-8">
                    <div class="flex items-center gap-5">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-black text-sm border border-indigo-100 group-hover:bg-indigo-600 group-hover:text-white transition-all shadow-sm">
                            ${p.fullName.charAt(0)}
                        </div>
                        <div class="min-w-0">
                            <p class="font-black text-slate-900 text-sm leading-tight uppercase tracking-tight group-hover:text-indigo-600 transition-colors">${p.fullName}</p>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest">${p.studentCode}</span>
                                <span class="w-1 h-1 bg-slate-300 rounded-full"></span>
                                <span class="text-[10px] text-slate-500 font-medium truncate max-w-[200px]" title="${p.projectName}">${p.projectName}</span>
                            </div>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-8 text-center">
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-50 text-slate-400 rounded-xl border border-slate-100 font-black text-[10px] uppercase tracking-tighter italic">
                        ${p.supervisorName || 'N/A'}
                    </div>
                </td>
                <td class="px-8 py-8 text-center">
                    ${p.reviewerId ? `
                        <div class="inline-flex items-center px-4 py-2.5 bg-indigo-50 text-indigo-700 border border-indigo-100 rounded-xl shadow-sm">
                            <span class="text-[10px] font-black uppercase tracking-widest">
                                👨‍🏫 ${p.reviewerName}
                            </span>
                        </div>
                    ` : `
                        <div class="inline-flex items-center px-4 py-2.5 bg-slate-50 text-slate-300 border border-slate-100 border-dashed rounded-xl italic">
                            <span class="text-[10px] font-bold uppercase tracking-widest leading-none">Chưa có GVPB</span>
                        </div>
                    `}
                </td>
                <td class="px-8 py-8 text-right">
                    <button onclick="openModal('${p.studentId}', '${p.projectId}')" class="px-6 py-3 bg-white border-2 border-indigo-600 text-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-indigo-600 hover:text-white transition-all shadow-sm group-hover:shadow-indigo-100 overflow-hidden relative">
                        ${p.reviewerId ? 'Đổi Phản biện' : 'Phân công ngay'}
                    </button>
                </td>
            </tr>
        `).join('');
    }

    function openModal(studentId, projectId) {
        selectedProject = { studentId, projectId };
        const project = currentData.projects.find(p => p.projectId === projectId);
        const reviewerSelect = document.getElementById('reviewer-select');
        
        // Filter out advisor: gv.fullName !== project.supervisorName (already handled by backend check but UI cleanup is better)
        const availableReviewers = currentData.gvpbs.filter(gv => gv.fullName !== project.supervisorName);
        
        reviewerSelect.innerHTML = '<option value="">-- Lựa chọn Giảng viên --</option>' + 
            availableReviewers.map(gv => `
                <option value="${gv._id}" ${project && project.reviewerId === gv._id ? 'selected' : ''}>
                    ${gv.fullName} (Đang phản biện: ${gv.currentReviews} đồ án)
                </option>
            `).join('');
        
        document.getElementById('assign-modal').classList.remove('hidden');
        document.body.classList.add('modal-open');
    }

    function closeModal() {
        document.getElementById('assign-modal').classList.add('hidden');
        document.body.classList.remove('modal-open');
    }

    async function submitAssignment() {
        const teacherId = document.getElementById('reviewer-select').value;
        if(!teacherId) return;

        try {
            const res = await fetch('/teacher/leader/assignReviewer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ...selectedProject, teacherId })
            });
            const data = await res.json();
            if(data.success) {
                closeModal();
                fetchData();
                // Show success alert using a minimal custom style if Swal not available
                alert('🎉 Cập nhật phân công Phản biện thành công!');
            }
        } catch (err) { console.error(err); }
    }

    fetchData();
</script>
{{/section}}
