                <!-- LỊCH NỘP BÁO CÁO -->
                <div class="space-y-6 pt-4">
                    <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                        <div class="flex items-center gap-2">
                            <span class="text-lg">⚡</span>
                            <label class="text-[11px] font-black text-indigo-600 uppercase tracking-[0.1em]">Lộ trình báo cáo đặc biệt</label>
                        </div>
                        <button type="button" onclick="addReportMilestone()" class="text-[10px] font-black bg-indigo-50 text-indigo-600 px-5 py-2.5 rounded-xl hover:bg-indigo-600 hover:text-white transition-all shadow-sm border border-indigo-100">
                            + Thêm tiêu mốc
                        </button>
                    </div>
                    <div id="milestones-container" class="space-y-4 max-h-60 overflow-y-auto pr-3 custom-scrollbar">
                        <!-- Milestones here -->
                    </div>
                </div>
            </form>
        </div>

        <!-- Footer -->
        <div class="px-12 py-10 border-t border-slate-50 bg-slate-50/50 flex-shrink-0">
            <button type="button" onclick="submitDirectRegister()" class="group w-full py-6 bg-slate-900 text-white rounded-[2.5rem] font-black text-[13px] uppercase tracking-[0.4em] shadow-2xl hover:bg-indigo-600 transition-all duration-500 hover:-translate-y-1 active:translate-y-0 flex items-center justify-center gap-4">
                <span>Khởi tạo lộ trình</span>
                <svg class="w-5 h-5 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
            </button>
        </div>
    </div>
</div>

<style>
    body.modal-open { overflow: hidden; }
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    .animate-in { animation: animate-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes animate-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

{{#section 'script'}}
<script>
    let allStudents = [];
    let currentTab = 'waiting';

    async function fetchStudents() {
        try {
            const res = await fetch('/teacher/leader/api/projects-detailed');
            allStudents = await res.json();
            updateStats();
            renderTable();
        } catch (err) { console.error(err); }
    }

    function updateStats() {
        const total = allStudents.length;
        const waiting = allStudents.filter(s => s.pipeline.step === 0 && !s.isSpecialCase).length;
        const ongoing = allStudents.filter(s => s.pipeline.step > 0 && s.pipeline.step < 5).length;
        const special = allStudents.filter(s => s.isSpecialCase).length;
        const completed = allStudents.filter(s => s.pipeline.step === 5).length;

        document.getElementById('stats-total').innerText = total;
        document.getElementById('stats-waiting').innerText = waiting;
        document.getElementById('stats-ongoing').innerText = ongoing;
        document.getElementById('stats-special').innerText = special;

        document.getElementById('badge-waiting').innerText = waiting;
        document.getElementById('badge-ongoing').innerText = ongoing;
        document.getElementById('badge-special').innerText = special;
        document.getElementById('badge-completed').innerText = completed;
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-white', 'text-indigo-600', 'shadow-sm', 'border-slate-100', 'text-slate-500');
            btn.classList.add('text-slate-500');
        });
        const activeBtn = document.getElementById(`tab-${tab}`);
        activeBtn.classList.add('bg-white', 'text-indigo-600', 'shadow-sm', 'border-slate-100');
        activeBtn.classList.remove('text-slate-500');
        renderTable();
    }

    function renderTable() {
        const query = document.getElementById('student-search').value.toLowerCase();
        let filtered = allStudents;

        // Apply Tab Filter
        if (currentTab === 'waiting') filtered = allStudents.filter(s => s.pipeline.step === 0 && !s.isSpecialCase);
        else if (currentTab === 'ongoing') filtered = allStudents.filter(s => s.pipeline.step > 1 && s.pipeline.step < 5);
        else if (currentTab === 'special') filtered = allStudents.filter(s => s.isSpecialCase);
        else if (currentTab === 'completed') filtered = allStudents.filter(s => s.pipeline.step === 5);

        // Apply Search Filter
        if (query) {
            filtered = filtered.filter(s => s.fullName.toLowerCase().includes(query) || s.studentCode.toLowerCase().includes(query));
        }

        const tbody = document.getElementById('student-table-body');
        if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-24 text-center text-slate-400 font-bold uppercase tracking-widest italic opacity-40">
                <div class="flex flex-col items-center gap-4">
                    <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center text-3xl">🏜️</div>
                    <p class="text-xs">Không tìm thấy dữ liệu phù hợp</p>
                </div>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = filtered.map(s => {
            let badgeClass = 'bg-slate-100 text-slate-500';
            if (s.pipeline.color === 'amber') badgeClass = 'bg-amber-50 text-amber-600 border border-amber-100';
            else if (s.pipeline.color === 'blue') badgeClass = 'bg-blue-50 text-blue-600 border border-blue-100';
            else if (s.pipeline.color === 'indigo') badgeClass = 'bg-indigo-50 text-indigo-600 border border-indigo-100';
            else if (s.pipeline.color === 'emerald') badgeClass = 'bg-emerald-50 text-emerald-600 border border-emerald-100';
            else if (s.pipeline.color === 'teal') badgeClass = 'bg-teal-50 text-teal-600 border border-teal-100';

            return `
            <tr class="hover:bg-slate-50/50 transition-all duration-300 group">
                <td class="px-8 py-7">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-black text-sm border border-indigo-100 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                            ${s.fullName.charAt(0)}
                        </div>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 mb-0.5">
                                <p class="font-black text-slate-900 uppercase text-[11px] tracking-tight group-hover:text-indigo-600 transition-colors">${s.fullName}</p>
                                <span class="px-2 py-0.5 ${badgeClass} rounded-lg text-[8px] font-black uppercase tracking-tighter">${s.pipeline.label}</span>
                            </div>
                            <p class="text-[10px] text-slate-400 font-bold tracking-widest">${s.studentCode}</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <div class="max-w-[240px] space-y-2.5">
                        <p class="text-[10px] font-black text-slate-700 truncate uppercase tracking-tight" title="${s.projectName}">${s.projectName}</p>
                        <div class="flex items-center gap-3">
                            <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden shadow-inner">
                                <div class="h-full bg-indigo-500 rounded-full transition-all duration-700" style="width: ${s.progressPercent}%"></div>
                            </div>
                            <span class="text-[10px] font-black text-indigo-600">${s.progressPercent}%</span>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <div class="space-y-1.5">
                        <div class="flex items-center gap-2">
                            <span class="w-4 text-[9px] font-black text-slate-300 uppercase tracking-tighter">HD</span>
                            <span class="text-[10px] font-bold text-slate-600 uppercase group-hover:text-slate-900">${s.supervisorName}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-4 text-[9px] font-black text-slate-300 uppercase tracking-tighter">PB</span>
                            <span class="text-[10px] font-bold text-indigo-500/70 uppercase group-hover:text-indigo-600">${s.reviewerName}</span>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <div class="flex items-center justify-center gap-6">
                        <div class="flex flex-col items-center gap-1.5 opacity-60 hover:opacity-100 transition-all cursor-help" title="Báo cáo cuối">
                            <div class="w-2.5 h-2.5 rounded-full ${s.hasReport ? 'bg-emerald-500 shadow-sm shadow-emerald-200' : 'bg-slate-200'}"></div>
                            <span class="text-[8px] font-black text-slate-400 uppercase tracking-[0.1em]">BC</span>
                        </div>
                        <div class="flex flex-col items-center gap-1.5 opacity-60 hover:opacity-100 transition-all cursor-help" title="Mã nguồn">
                            <div class="w-2.5 h-2.5 rounded-full ${s.hasCode ? 'bg-indigo-500 shadow-sm shadow-indigo-200' : 'bg-slate-200'}"></div>
                            <span class="text-[8px] font-black text-slate-400 uppercase tracking-[0.1em]">SRC</span>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7 text-right">
                    ${s.isSpecialCase ? `
                    <button onclick="openRegisterModal('${s.studentId}', '${s.fullName}')" class="px-5 py-2.5 bg-rose-600 text-white rounded-xl text-[9px] font-black uppercase tracking-widest hover:bg-rose-700 hover:-translate-y-0.5 transition-all shadow-lg shadow-rose-100">
                        Đăng ký đặc biệt
                    </button>
                    ` : `
                    <button class="w-10 h-10 flex items-center justify-center text-slate-300 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all border border-transparent hover:border-indigo-100 shadow-sm hover:shadow-none bg-white">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                    `}
                </td>
            </tr>
            `;
        }).join('');
    }

    function filterStudents() {
        renderTable();
    }

    async function openRegisterModal(studentId, fullName) {
        document.getElementById('reg-student-id').value = studentId;
        document.getElementById('reg-student-name').value = fullName;
        document.getElementById('milestones-container').innerHTML = '';
        
        const modal = document.getElementById('direct-register-modal');
        modal.classList.remove('hidden');
        document.body.classList.add('modal-open');
        
        try {
            const response = await fetch('/teacher/leader/api/teachers-slots');
            const teachers = await response.json();
            
            const selectAdvisor = document.getElementById('reg-teacher-id');
            const selectReviewer = document.getElementById('reg-reviewer-id');
            
            selectAdvisor.innerHTML = '<option value="" disabled selected>-- Chọn GV Hướng dẫn --</option>' + 
                teachers.filter(t => t.isGVHD).map(t => {
                    const isFull = t.currentStudents >= t.maxStudents;
                    return `<option value="${t._id}" ${isFull ? 'class="text-rose-500 font-black"' : ''}>
                        ${t.fullName} (${t.currentStudents}/${t.maxStudents}) ${isFull ? '- ĐÃ ĐỦ CHỈ TIÊU' : ''}
                    </option>`;
                }).join('');
                
            selectReviewer.innerHTML = '<option value="" disabled selected>-- Chọn GV Phản biện --</option>' + 
                teachers.filter(t => t.isGVPB).map(t => `<option value="${t._id}">${t.fullName} (${t.teacherCode})</option>`).join('');
        } catch (e) { console.error(e); }
    }

    function closeRegisterModal() {
        document.getElementById('direct-register-modal').classList.add('hidden');
        document.body.classList.remove('modal-open');
        document.getElementById('direct-register-form').reset();
    }

    function addReportMilestone() {
        const container = document.getElementById('milestones-container');
        const count = container.children.length + 1;
        const div = document.createElement('div');
        div.className = 'group/milestone relative grid grid-cols-12 gap-4 p-5 bg-white border border-slate-100 rounded-3xl shadow-sm hover:shadow-md hover:border-indigo-100 transition-all animate-in slide-in-from-top-2 duration-300';
        div.innerHTML = `
            <div class="col-span-7 space-y-1.5">
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block ml-1">Tên tiêu mốc</span>
                <input type="text" name="milestone-name" value="Báo cáo Đợt ${count}" class="w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl text-[10px] font-black uppercase focus:bg-white focus:border-indigo-500 outline-none transition-all">
            </div>
            <div class="col-span-4 space-y-1.5">
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block ml-1">Hạn nộp</span>
                <input type="date" name="milestone-date" class="w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl text-[10px] font-bold focus:bg-white focus:border-indigo-500 outline-none transition-all">
            </div>
            <div class="col-span-1 flex items-end justify-center pb-2">
                <button type="button" onclick="this.parentElement.parentElement.remove()" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-300 hover:text-rose-500 hover:bg-rose-50 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
            </div>
        `;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
    }

    async function submitDirectRegister() {
        const studentId = document.getElementById('reg-student-id').value;
        const teacherId = document.getElementById('reg-teacher-id').value;
        const reviewerId = document.getElementById('reg-reviewer-id').value;
        const projectName = document.getElementById('reg-project-name').value;
        const objective = document.getElementById('reg-objective').value;
        const scope = document.getElementById('reg-scope').value;
        const technology = document.getElementById('reg-technology').value;
        
        if (!teacherId || !reviewerId || !projectName) {
            alert('⚠️ Vui lòng cung cấp đầy đủ thông tin giảng viên và tên đề tài.');
            return;
        }

        const milestoneNames = Array.from(document.getElementsByName('milestone-name')).map(el => el.value);
        const milestoneDates = Array.from(document.getElementsByName('milestone-date')).map(el => el.value);
        const milestones = milestoneNames.map((name, i) => ({ name, deadline: milestoneDates[i] }));

        try {
            const res = await fetch('/teacher/leader/api/direct-register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId, teacherId, reviewerId, projectName, objective, scope, technology, milestones })
            });
            const data = await res.json();
            if (data.success) {
                alert('🎉 Cấp tài khoản đồ án đặc biệt thành công!');
                closeRegisterModal();
                fetchStudents();
            } else alert(data.message);
        } catch (e) { alert('Lỗi máy chủ!'); }
    }

    fetchStudents();
</script>
