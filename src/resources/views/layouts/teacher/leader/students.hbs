<div class="animate-in pb-20">
    <!-- HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider border border-indigo-100">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
                Student Matrix Center
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Quản lý <span class="text-indigo-600">Sinh viên</span></h1>
            <p class="text-slate-500 font-medium italic">Theo dõi tiến độ, giảng viên và điều phối các trường hợp đặc biệt.</p>
        </div>

        <div class="flex items-center gap-4">
            <div class="relative group">
                <input type="text" id="student-search" oninput="filterStudents()" placeholder="Tìm tên hoặc mã SV..." class="pl-12 pr-6 py-4 bg-white border border-slate-100 rounded-2xl text-sm font-bold w-64 md:w-80 shadow-sm focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all outline-none group-hover:shadow-md">
                <svg class="w-5 h-5 text-slate-300 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
        </div>
    </div>

    <!-- KPI SUMMARY -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-10 text-white">
        <div class="bg-indigo-600 p-6 rounded-[2rem] shadow-xl shadow-indigo-100 flex flex-col gap-4">
            <div class="text-xl">👩‍🎓</div>
            <div>
                <span class="text-[9px] font-black text-indigo-100/50 uppercase tracking-widest block mb-1">Tổng sinh viên</span>
                <span class="text-2xl font-black leading-none" id="stats-total">0</span>
            </div>
        </div>
        <div class="bg-amber-500 p-6 rounded-[2rem] shadow-xl shadow-amber-100 flex flex-col gap-4">
            <div class="text-xl">⏳</div>
            <div>
                <span class="text-[9px] font-black text-amber-50/50 uppercase tracking-widest block mb-1">Chưa có đồ án</span>
                <span class="text-2xl font-black leading-none" id="stats-waiting">0</span>
            </div>
        </div>
        <div class="bg-blue-500 p-6 rounded-[2rem] shadow-xl shadow-blue-100 flex flex-col gap-4">
            <div class="text-xl">🚀</div>
            <div>
                <span class="text-[9px] font-black text-blue-50/50 uppercase tracking-widest block mb-1">Đang thực hiện</span>
                <span class="text-2xl font-black leading-none" id="stats-ongoing">0</span>
            </div>
        </div>
        <div class="bg-rose-500 p-6 rounded-[2rem] shadow-xl shadow-rose-100 flex flex-col gap-4">
            <div class="text-xl">⚠️</div>
            <div>
                <span class="text-[9px] font-black text-rose-50/50 uppercase tracking-widest block mb-1">Trường hợp đặc biệt</span>
                <span class="text-2xl font-black leading-none" id="stats-special">0</span>
            </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-2 mb-8 p-1.5 bg-slate-100/50 rounded-[2rem] w-fit shadow-inner">
        <button onclick="switchTab('waiting')" id="tab-waiting" class="tab-btn px-6 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all bg-white text-indigo-600 shadow-sm border border-slate-100">
            Chưa có đồ án <span id="badge-waiting" class="ml-2 px-1.5 py-0.5 bg-indigo-50 text-indigo-600 rounded text-[8px]">0</span>
        </button>
        <button onclick="switchTab('ongoing')" id="tab-ongoing" class="tab-btn px-6 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-500 hover:bg-white/50">
            Đang thực hiện <span id="badge-ongoing" class="ml-2 px-1.5 py-0.5 bg-slate-200 text-slate-500 rounded text-[8px]">0</span>
        </button>
        <button onclick="switchTab('special')" id="tab-special" class="tab-btn px-6 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-500 hover:bg-white/50">
            Trường hợp đặc biệt <span id="badge-special" class="ml-2 px-1.5 py-0.5 bg-slate-200 text-slate-500 rounded text-[8px]">0</span>
        </button>
        <button onclick="switchTab('completed')" id="tab-completed" class="tab-btn px-6 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-500 hover:bg-white/50">
            Hoàn thành <span id="badge-completed" class="ml-2 px-1.5 py-0.5 bg-slate-200 text-slate-500 rounded text-[8px]">0</span>
        </button>
        <button onclick="switchTab('all')" id="tab-all" class="tab-btn px-6 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all text-slate-500 hover:bg-white/50">
            Tất cả
        </button>
    </div>

    <!-- DATA TABLE -->
    <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-indigo-500 to-violet-500"></div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/30 border-b border-slate-50">
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Thông tin Sinh viên</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Đồ án & Tiến độ</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Đội ngũ hướng dẫn</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-center">Tài liệu</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="student-table-body" class="divide-y divide-slate-50">
                    <!-- Data rendered by JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ELITE DIRECT REGISTER MODAL -->
<div id="direct-register-modal" class="fixed inset-0 z-[100] hidden bg-slate-900/40 backdrop-blur-md animate-in fade-in duration-300 p-4 flex items-center justify-center">
    <div class="w-full max-w-2xl bg-white rounded-[3.5rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)] overflow-hidden flex flex-col max-h-[90vh] animate-in zoom-in-95 duration-500 border border-white">
        <!-- Header -->
        <div class="px-12 py-10 border-b border-slate-50 flex items-center justify-between flex-shrink-0 bg-gradient-to-br from-indigo-50/50 to-transparent">
            <div class="space-y-1.5">
                <div class="inline-flex items-center gap-2 px-2.5 py-1 bg-rose-50 text-rose-600 rounded-lg text-[9px] font-black uppercase tracking-widest mb-1 border border-rose-100">
                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse"></span>
                    Hệ thống can thiệp đặc biệt
                </div>
                <h3 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Đăng ký <span class="text-indigo-600">Đặc biệt</span></h3>
                <p class="text-[10px] text-slate-400 font-bold tracking-[0.2em] uppercase italic">Quản trị lộ trình đồ án cho các trường hợp ngoại lệ</p>
            </div>
            <button onclick="closeRegisterModal()" class="w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 hover:text-rose-500 hover:bg-rose-50 transition-all flex items-center justify-center group">
                <svg class="w-6 h-6 transform group-hover:rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <!-- Body (Scrollable) -->
        <div class="p-12 overflow-y-auto custom-scrollbar flex-1 space-y-10">
            <form id="direct-register-form" class="space-y-8">
                <input type="hidden" id="reg-student-id">
                
                <div class="space-y-2.5">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Họ tên Sinh viên</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
                            <span class="text-lg">👩‍🎓</span>
                        </div>
                        <input type="text" id="reg-student-name" class="w-full pl-14 pr-6 py-5 bg-slate-50 border-2 border-slate-50 rounded-2xl font-black text-sm text-indigo-600 cursor-not-allowed shadow-inner" readonly>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Giảng viên hướng dẫn</label>
                        <select id="reg-teacher-id" class="w-full px-6 py-5 bg-white border-2 border-slate-100 rounded-2xl focus:border-indigo-500 transition-all outline-none font-bold text-sm shadow-sm hover:border-slate-200" required>
                            <option value="">Đang tải danh sách...</option>
                        </select>
                    </div>
                    <div class="space-y-2.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Giảng viên phản biện</label>
                        <select id="reg-reviewer-id" class="w-full px-6 py-5 bg-white border-2 border-slate-100 rounded-2xl focus:border-indigo-500 transition-all outline-none font-bold text-sm shadow-sm hover:border-slate-200" required>
                            <option value="">Đang tải danh sách...</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-2.5">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên Đề tài (Chính thức)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
                            <span class="text-lg">📚</span>
                        </div>
                        <input type="text" id="reg-project-name" class="w-full pl-14 pr-6 py-5 bg-white border-2 border-slate-100 rounded-2xl focus:border-indigo-500 transition-all outline-none font-black text-sm shadow-sm hover:border-slate-200" placeholder="VD: Ứng dụng AI trong quản lý rủi ro..." required>
                    </div>
                </div>

                <div class="space-y-2.5">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Công nghệ sử dụng</label>
                    <input type="text" id="reg-technology" class="w-full px-6 py-5 bg-white border-2 border-slate-100 rounded-2xl focus:border-indigo-500 transition-all outline-none font-bold text-sm shadow-sm hover:border-slate-200" placeholder="VD: ReactJS, NodeJS, MongoDB...">
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mục tiêu & Yêu cầu</label>
                        <textarea id="reg-objective" rows="3" class="w-full px-6 py-5 bg-white border-2 border-slate-100 rounded-2xl focus:border-indigo-500 transition-all outline-none font-medium text-[13px] leading-relaxed resize-none shadow-sm hover:border-slate-200" placeholder="Mục tiêu chính của đề tài..."></textarea>
                    </div>
                    <div class="space-y-2.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Phạm vi nghiên cứu</label>
                        <textarea id="reg-scope" rows="3" class="w-full px-6 py-5 bg-white border-2 border-slate-100 rounded-2xl focus:border-indigo-500 transition-all outline-none font-medium text-[13px] leading-relaxed resize-none shadow-sm hover:border-slate-200" placeholder="Phạm vi ứng dụng..."></textarea>
                    </div>
