<div class="animate-in">
    <!-- HERO SECTION -->
    <div class="relative mb-12 p-12 bg-slate-900 rounded-[3.5rem] overflow-hidden shadow-2xl shadow-indigo-500/20">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-indigo-500/10 to-transparent"></div>
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8">
            <div class="space-y-4">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 backdrop-blur-md border border-white/10 rounded-xl text-[10px] font-black text-white uppercase tracking-[0.2em]">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                    Human Resources Command
                </div>
                <h1 class="text-5xl font-black text-white uppercase tracking-tighter leading-none">
                    Đội ngũ <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-teal-400">Chuyên gia</span>
                </h1>
                <p class="text-indigo-100/60 font-medium text-lg max-w-xl italic">Xây dựng nền tảng chuyên môn vững mạnh thông qua việc điều phối vai trò và giám sát hiệu năng giảng dạy.</p>
            </div>

            <div class="flex items-center gap-4">
                 <div class="relative group">
                    <input type="text" id="teacher-search" oninput="filterTeachers()" placeholder="Danh tính giảng viên..." 
                        class="pl-14 pr-8 py-5 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl text-sm font-bold text-white shadow-inner focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-400/50 transition-all outline-none w-64 md:w-80 placeholder:text-white/20">
                    <svg class="w-6 h-6 text-white/20 group-focus-within:text-indigo-400 absolute left-5 top-1/2 -translate-y-1/2 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- TEACHERS GRID -->
    <div id="teachers-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-8">
        <!-- RENDERED BY REDESIGNED JS -->
    </div>
</div>

<style>
    .card-glass {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    
    .switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 26px;
    }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #f1f5f9;
        transition: .4s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 34px;
        border: 1px solid #e2e8f0;
    }
    .slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 2px;
        bottom: 2px;
        background-color: white;
        transition: .4s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 50%;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    input:checked + .slider {
        background-color: #4f46e5;
        border-color: #4f46e5;
    }
    input:checked + .slider:before {
        transform: translateX(22px);
    }

    .shimmer {
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        background-size: 200% 100%;
        animation: shimmer 2s infinite;
    }
    @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }
</style>

{{#section 'script'}}
<script>
    let allTeachers = [];

    async function fetchTeachers() {
        const grid = document.getElementById('teachers-grid');
        grid.innerHTML = Array(4).fill(0).map(() => `
            <div class="h-[500px] bg-slate-50 rounded-[3rem] animate-pulse"></div>
        `).join('');

        try {
            const res = await fetch('/teacher/leader/getTeachers');
            allTeachers = await res.json();
            renderTeachers(allTeachers);
        } catch (err) { 
            console.error(err);
            showNotify('Lỗi kết nối bộ máy dữ liệu', 'error');
        }
    }

    function renderTeachers(data) {
        const grid = document.getElementById('teachers-grid');
        if (data.length === 0) {
            grid.innerHTML = `
                <div class="col-span-full py-32 text-center card-glass rounded-[4rem]">
                    <div class="w-32 h-32 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-8 border-4 border-white shadow-xl">
                        <svg class="w-16 h-16 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-black text-slate-400 uppercase tracking-[0.3em]">Kho dữ liệu trống</h3>
                    <p class="text-slate-400 mt-2 font-medium italic">Không phát hiện chuyên gia thuộc bộ môn của bạn.</p>
                </div>
            `;
            return;
        }

        grid.innerHTML = data.map(t => {
            const isFull = t.currentStudents >= t.maxStudents;
            const loadPercent = Math.min((t.currentStudents / t.maxStudents) * 100, 100);
            
            return `
            <div class="card-glass rounded-[3.5rem] p-1 shadow-sm hover:shadow-2xl hover:shadow-indigo-500/10 hover:-translate-y-2 transition-all duration-700 group">
                <div class="bg-white rounded-[3.25rem] overflow-hidden flex flex-col h-full">
                    <!-- Top Info -->
                    <div class="px-8 pt-10 pb-6 text-center border-b border-slate-50 relative">
                        <div class="absolute top-8 right-8">
                             <div class="w-3 h-3 rounded-full bg-emerald-500 shadow-lg shadow-emerald-500/50"></div>
                        </div>

                        <div class="w-24 h-24 rounded-[2.5rem] bg-slate-50 mx-auto mb-6 flex items-center justify-center text-3xl font-black text-slate-300 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-700 shadow-inner group-hover:rotate-6 group-hover:scale-110">
                            ${t.fullName.charAt(0)}
                        </div>
                        
                        <h4 class="text-lg font-black text-slate-900 uppercase tracking-tight leading-tight">${t.fullName}</h4>
                        <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.2em] mt-1">${t.teacherCode}</p>
                        
                        <div class="flex flex-wrap justify-center gap-2 mt-4">
                            <span class="px-3 py-1 bg-slate-50 text-slate-500 rounded-lg text-[8px] font-bold uppercase tracking-widest border border-slate-100">${t.teacherDegree || 'Thạc sĩ'}</span>
                            ${t.subRoles?.isGVHD ? '<span class="px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[8px] font-bold uppercase tracking-widest border border-indigo-100">Advisor</span>' : ''}
                            ${t.subRoles?.isGVPB ? '<span class="px-3 py-1 bg-teal-50 text-teal-600 rounded-lg text-[8px] font-bold uppercase tracking-widest border border-teal-100 font-medium">Reviewer</span>' : ''}
                        </div>
                    </div>

                    <!-- Metrics -->
                    <div class="grid grid-cols-2 split-border p-6 bg-slate-50/50">
                        <div class="flex flex-col items-center text-center">
                            <span class="text-[20px] font-black text-slate-900">${t.currentStudents || 0}</span>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Đang hướng dẫn</span>
                        </div>
                        <div class="flex flex-col items-center text-center border-l border-slate-200/50">
                            <span class="text-[20px] font-black text-rose-600">${t.pendingReports || 0}</span>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Chờ duyệt bài</span>
                        </div>
                    </div>

                    <!-- Workflow Switches -->
                    <div class="p-8 space-y-6 flex-1">
                        <div class="flex items-center justify-between">
                            <div class="space-y-0.5">
                                <label class="text-[11px] font-black text-slate-900 uppercase tracking-wide">Chế độ Hướng dẫn</label>
                                <p class="text-[9px] text-slate-400 font-medium italic leading-none">Cấp quyền nhận sinh viên</p>
                            </div>
                            <label class="switch">
                                <input type="checkbox" ${t.subRoles?.isGVHD ? 'checked' : ''} onchange="toggleRole('${t._id}', 'isGVHD', this.checked, this)">
                                <span class="slider"></span>
                            </label>
                        </div>

                        <div class="flex items-center justify-between">
                            <div class="space-y-0.5">
                                <label class="text-[11px] font-black text-slate-900 uppercase tracking-wide">Chế độ Phản biện</label>
                                <p class="text-[9px] text-slate-400 font-medium italic leading-none">Cấp quyền chấm phản biện</p>
                            </div>
                            <label class="switch">
                                <input type="checkbox" ${t.subRoles?.isGVPB ? 'checked' : ''} onchange="toggleRole('${t._id}', 'isGVPB', this.checked, this)">
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>

                    <!-- Footer Action -->
                    <div class="p-8 pt-0 mt-auto">
                        <div class="w-full bg-slate-50 rounded-2xl p-4 flex items-center justify-between border border-slate-100">
                             <div class="flex-1 mr-4">
                                <div class="flex justify-between text-[9px] font-black uppercase mb-1.5">
                                    <span class="text-slate-400">Tải trọng:</span>
                                    <span class="${isFull ? 'text-rose-600' : 'text-indigo-600'}">${t.currentStudents}/${t.maxStudents}</span>
                                </div>
                                <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                                    <div class="h-full ${isFull ? 'bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]' : 'bg-indigo-500'} transition-all duration-1000" style="width: ${loadPercent}%"></div>
                                </div>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
            `;
        }).join('');
    }

    async function toggleRole(teacherId, roleKey, value, el) {
        const switchParent = el.parentElement;
        switchParent.classList.add('opacity-50', 'pointer-events-none');
        
        try {
            const body = { teacherId, roles: {} };
            body.roles[roleKey] = value;

            const res = await fetch('/teacher/leader/assignRole', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            const result = await res.json();
            if (result.success) {
                showNotify(`Đã kích hoạt chế độ ${roleKey === 'isGVHD' ? 'Hướng dẫn' : 'Phản biện'}`, 'success');
                // Optional: Re-fetch silently to sync all data
                const refresh = await fetch('/teacher/leader/getTeachers');
                allTeachers = await refresh.json();
                renderTeachers(allTeachers);
            } else {
                showNotify(result.message || 'Lỗi xử lý vai trò', 'error');
                el.checked = !value;
            }
        } catch (err) {
            console.error(err);
            showNotify('Mất kết nối trung tâm điều khiển', 'error');
            el.checked = !value;
        } finally {
            switchParent.classList.remove('opacity-50', 'pointer-events-none');
        }
    }

    function filterTeachers() {
        const query = document.getElementById('teacher-search').value.toLowerCase();
        const filtered = allTeachers.filter(t => 
            t.fullName.toLowerCase().includes(query) || 
            t.teacherCode.toLowerCase().includes(query)
        );
        renderTeachers(filtered);
    }

    fetchTeachers();

    function showNotify(msg, type = 'success') {
        const toast = document.createElement('div');
        toast.className = `fixed bottom-10 left-1/2 -translate-x-1/2 px-10 py-5 ${type === 'success' ? 'bg-slate-900 shadow-indigo-500/20' : 'bg-rose-600 shadow-rose-500/20'} text-white text-[11px] font-black uppercase tracking-[0.2em] rounded-[2rem] shadow-2xl z-[100] animate-in fade-in slide-in-from-bottom-5 duration-300 flex items-center gap-4 border border-white/10 backdrop-blur-md`;
        toast.innerHTML = `
            <div class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center">
                ${type === 'success' ? '✓' : '✕'}
            </div>
            ${msg}
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
            toast.classList.add('fade-out', 'translate-y-4');
            toast.style.transition = 'all 0.5s ease';
            setTimeout(() => toast.remove(), 500);
        }, 3000);
    }
</script>
{{/section}}
