<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Giảng viên - Premium</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .menu-item.active { background: rgba(79, 70, 229, 0.1); border-right: 4px solid #4f46e5; color: #4f46e5; }
        .sidebar-collapsed { width: 88px; }
        .sidebar-collapsed .sidebar-text { display: none; }
        .sidebar-collapsed .sidebar-logo { justify-content: center; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
    </style>
</head>

<body class="bg-[#F8FAFC] text-slate-900 overflow-hidden text-[13px]">

<div class="flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <aside id="sidebar" class="w-72 bg-white border-r border-slate-200 transition-all duration-300 flex-shrink-0 flex flex-col z-50">
        
        <!-- LOGO -->
        <div class="sidebar-logo flex items-center gap-3 p-8 border-b border-slate-50">
            <div class="w-10 h-10 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-500/20">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332 0.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332 0.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332 0.477-4.5 1.253"></path></svg>
            </div>
            <div class="sidebar-text">
                <span class="font-black text-lg tracking-tight text-slate-900 uppercase">Teacher</span>
                <span class="block text-[9px] font-bold text-indigo-500 uppercase tracking-widest -mt-1">Portal System</span>
            </div>
        </div>

        <!-- MENU -->
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto custom-scrollbar">
            <a href="/teacher/dashboard" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'dashboard')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Dashboard</span>
            </a>

            <div class="py-4 sidebar-text">
                <span class="px-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Nghiệp vụ hướng dẫn</span>
            </div>


            <a href="/teacher/request" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'request')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Duyệt Đăng ký</span>
            </a>

            <a href="/teacher/student" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'student')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Sinh viên của tôi</span>
            </a>

            <a href="/teacher/report" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'report')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Báo cáo tuần</span>
            </a>

            <a href="/teacher/feedback" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'feedback')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Trao đổi SV</span>
            </a>

            <div class="py-4 sidebar-text">
                <span class="px-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Hội đồng & Chấm điểm</span>
            </div>

            {{#if subRoles.isGVPB}}
            <a href="/teacher/council/review" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'council/review')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Chấm Phản biện</span>
            </a>
            {{/if}}

            {{#if subRoles.isCouncil}}
            <a href="/teacher/council/grade" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'council/grade')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Chấm Hội đồng</span>
            </a>
            {{/if}}

            {{#if subRoles.isLeader}}
            <a href="/teacher/leader/assign" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'leader/assign')}} active {{else}} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Phân vai Hội đồng</span>
            </a>
            {{/if}}

            <div class="h-px bg-slate-100 my-3 mx-2"></div>
            
            <a href="/teacher/account" class="menu-item group flex items-center px-4 py-3.5 rounded-2xl transition-all duration-200 {{#if (eq active 'account')}} active {{else} text-slate-500 hover:bg-slate-50 {{/if}}">
                <svg class="w-5 h-5 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <span class="ml-4 font-bold sidebar-text">Hồ sơ cá nhân</span>
            </a>
        </nav>

        <!-- FOOTER / USER -->
        <div class="p-6 border-t border-slate-50">
            <div class="user-profile p-4 bg-slate-50 rounded-2xl flex items-center gap-3 border border-slate-100 group">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white font-bold text-sm shadow-inner overflow-hidden">
                    {{#if userT.fullName}}{{substring userT.fullName 0 1}}{{else}}T{{/if}}
                </div>
                <div class="user-info flex-1 min-w-0">
                    <p class="text-xs font-black truncate text-slate-900">{{#if userT.fullName}}{{userT.fullName}}{{else}}Giảng viên{{/if}}</p>
                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-wider">{{#if userT.teacherCode}}{{userT.teacherCode}}{{else}}DUE{{/if}}</p>
                </div>
                <a href="/loggin/logout?role=teacher" class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </a>
            </div>
        </div>
    </aside>

    <!-- CONTENT AREA -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden relative">
        <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-10 z-10">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="p-2.5 bg-slate-50 text-slate-600 rounded-xl hover:bg-slate-100 transition-all border border-slate-100">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
                </button>
                <div class="h-4 w-px bg-slate-200 mx-2"></div>
                <span class="text-slate-900 font-bold uppercase tracking-widest text-[11px]">{{active}}</span>
            </div>

            <div class="flex items-center gap-5">
                <div class="hidden md:flex flex-col items-end mr-2">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Học kỳ 1</span>
                    <span class="text-indigo-600 font-bold text-[11px] leading-none mt-1">2023 - 2024</span>
                </div>
                <div class="w-px h-10 bg-slate-200"></div>
                <div class="relative">
                    <button class="w-12 h-12 flex items-center justify-center rounded-2xl bg-slate-50 border border-slate-100 text-slate-400 hover:bg-indigo-600 hover:text-white transition-all shadow-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 01-6 0v-1m6 0H9"></path></svg>
                    </button>
                    <span class="absolute top-0 right-0 w-3 h-3 bg-red-500 rounded-full border-2 border-white animate-bounce"></span>
                </div>
            </div>
        </header>

        <main id="content" class="flex-1 overflow-y-auto p-10 custom-scrollbar bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px]">
            <div class="max-w-7xl mx-auto animate-in fade-in slide-in-from-bottom-4 duration-700">
                {{{body}}}
            </div>
        </main>
    </div>

</div>

<script>
    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('sidebar-collapsed');
    }
</script>

</body>
</html>
