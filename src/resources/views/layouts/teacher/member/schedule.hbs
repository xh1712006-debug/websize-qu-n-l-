<div class="animate-in">
    <!-- HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path></svg>
                Phòng quan sát & Đánh giá
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Kế hoạch Bảo vệ</h1>
            <p class="text-slate-500 font-medium italic">Danh sách lịch bảo vệ của sinh viên thuộc các hội đồng bạn tham gia với tư cách Ủy viên.</p>
        </div>
        
        {{#if schedules.length}}
        <div class="flex items-center gap-3">
            <div class="px-6 py-3 bg-white border border-slate-200 rounded-2xl shadow-sm">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block leading-none mb-1">Số lượng đồ án</span>
                <span class="text-xl font-black text-indigo-600 leading-none">{{schedules.length}}</span>
            </div>
        </div>
        {{/if}}
    </div>

    {{#if noCouncil}}
    <div class="bg-white rounded-[3rem] border border-slate-100 p-20 text-center shadow-sm">
        <div class="w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center text-slate-300 mx-auto mb-6">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight">Chưa có lịch phân công</h3>
        <p class="text-slate-400 font-medium mt-2">Bạn hiện không phải là Ủy viên của hội đồng nào đang hoạt động.</p>
    </div>
    {{else}}
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {{#each schedules}}
        <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-indigo-200/30 transition-all duration-500 overflow-hidden group">
            <div class="p-8 space-y-6">
                <!-- TOP INFO -->
                <div class="flex items-start justify-between">
                    <div class="space-y-1">
                        <div class="flex items-center gap-2">
                             <div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div>
                             <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{this.councilName}}</span>
                        </div>
                        <h4 class="text-lg font-black text-slate-900 uppercase tracking-tight line-clamp-1 group-hover:text-indigo-600 transition-colors">{{this.projectName}}</h4>
                    </div>
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    </div>
                </div>

                <!-- DATE & ROOM -->
                <div class="bg-indigo-50/50 rounded-2xl p-5 flex items-center justify-between border border-indigo-50">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-sm">
                            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                        <div>
                            <p class="text-xs font-black text-slate-900 uppercase">
                                {{#if this.defenseDate}}{{dateFormat this.defenseDate "DD/MM/YYYY"}}{{else}}Chưa có ngày{{/if}}
                            </p>
                            <p class="text-[10px] font-bold text-indigo-400 uppercase tracking-wider">{{#if this.defenseTime}}{{this.defenseTime}}{{else}}--:--{{/if}}</p>
                        </div>
                    </div>
                    <div class="text-right border-l border-indigo-100 pl-4">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Phòng</p>
                        <p class="text-sm font-black text-slate-900">{{#if this.defenseRoom}}{{this.defenseRoom}}{{else}}--{{/if}}</p>
                    </div>
                </div>

                <!-- STUDENT & ADVISOR -->
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-[10px] font-black text-slate-500 bg-gradient-to-br from-slate-50 to-slate-100">{{substring this.studentName 0 1}}</div>
                        <div class="min-w-0">
                            <p class="text-xs font-black text-slate-900 uppercase truncate leading-none mb-1">{{this.studentName}}</p>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">{{this.studentCode}}</p>
                        </div>
                    </div>
                    <div class="pt-4 border-t border-slate-50 flex items-center justify-between">
                         <div class="flex items-center gap-2">
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">GVHD:</span>
                            <span class="text-[10px] font-bold text-slate-600 truncate max-w-[120px]">{{this.advisorName}}</span>
                         </div>
                         <a href="/teacher/council/grading?councilId={{this.councilId}}" class="inline-flex items-center gap-1.5 text-xs font-black text-indigo-600 hover:text-indigo-700 transition-colors uppercase tracking-wider">
                            Chấm điểm
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                         </a>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}
</div>
