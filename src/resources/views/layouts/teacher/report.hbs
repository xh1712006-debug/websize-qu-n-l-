<div class="animate-in pb-20">
    <!-- PAGE HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                Hệ thống Quản lý Báo cáo
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Trung tâm <span class="text-indigo-600">Kiểm định Tiến độ</span></h1>
            <p class="text-slate-500 font-medium italic">Đánh giá chuyên môn và phản hồi các bản báo cáo định kỳ từ sinh viên hướng dẫn.</p>
        </div>
        
        <div class="flex items-center gap-3 px-6 py-4 bg-white rounded-3xl border border-slate-100 shadow-sm">
             <div class="w-3 h-3 bg-amber-500 rounded-full animate-pulse"></div>
             <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Cần xử lý: <span id="header-pending-count">0</span> Báo cáo</span>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-8">
        <button onclick="switchTab('chờ duyệt')" id="tab-waiting" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-amber-400"></span>
            Chờ xét duyệt
            <span id="count-waiting" class="ml-2 px-2 py-0.5 bg-amber-100 text-amber-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('đã duyệt')" id="tab-approved" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            Đã đủ điều kiện
            <span id="count-approved" class="ml-2 px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('yêu cầu nộp lại')" id="tab-rejected" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-rose-500"></span>
            Yêu cầu sửa đổi
            <span id="count-rejected" class="ml-2 px-2 py-0.5 bg-rose-100 text-rose-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- DATA TABLE CONTAINER -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div id="tab-indicator" class="absolute top-0 left-0 h-1.5 bg-gradient-to-r transition-all duration-500"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-7 bg-slate-50/50">Sinh viên</th>
                        <th class="px-8 py-7 bg-slate-50/50">Đồ án / Tiếu đề báo cáo</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Thời gian nộp</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Trạng thái</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-right">Phản hồi & Duyệt</th>
                    </tr>
                </thead>
                <tbody id="reportList" class="divide-y divide-slate-50">
                    <!-- Dynamic from JS -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- EMPTY STATE -->
    <div id="emptyReport" class="hidden py-40 text-center bg-white rounded-[3rem] border border-dashed border-slate-200 mt-8">
        <div class="w-32 h-32 bg-slate-50 rounded-[3rem] flex items-center justify-center mx-auto mb-8 text-6xl opacity-30">📦</div>
        <h3 class="text-2xl font-black text-slate-300 uppercase tracking-widest">Hộp thư trống</h3>
        <p class="text-slate-400 font-medium mt-3 italic">Hiện không có bản báo cáo nào trong mục này.</p>
    </div>
</div>

<!-- PREMIUM MODAL OVERLAY -->
<div id="modal" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center p-4">
    <!-- Injected by JS -->
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .animate-in {
        animation: animate-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes animate-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    #modal.flex { background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); }
</style>

{{#section 'script'}}
<script src="/js/teacher/report.js"></script>
{{/section}}
