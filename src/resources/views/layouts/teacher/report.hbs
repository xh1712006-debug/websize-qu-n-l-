{{!-- <script>

/* ================= DATA ================= */
let reports = [
  {
    id: 1,
    name: "Nguyễn Văn A",
    code: "SV00123",
    project: "Website quản lý đồ án",
    type: "Báo cáo tuần 5",
    date: "20/02/2026",
    status: "pending"
  },
  {
    id: 2,
    name: "Trần Thị B",
    code: "SV00456",
    project: "App quản lý sinh viên",
    type: "Báo cáo cuối kỳ",
    date: "18/02/2026",
    status: "approved"
  }
];

let requirements = [
  { id: 1, name: "CRUD sinh viên", status: "pending" },
  { id: 2, name: "Đăng ký đề tài", status: "pending" },
  { id: 3, name: "Quản lý tiến độ", status: "pending" },
  { id: 4, name: "Chấm điểm", status: "pending" }
];

let currentReportId = null;

/* ================= RENDER ================= */
function renderReports() {
  const container = document.getElementById("reportList");
  container.innerHTML = "";

  reports.forEach(r => {
    const div = document.createElement("div");

    div.className = "grid grid-cols-6 items-center text-sm py-3 border-b";

    div.innerHTML = `
      <div>
        <p class="font-medium">${r.name}</p>
        <p class="text-gray-500 text-xs">${r.code}</p>
      </div>

      <span>${r.project}</span>
      <span>${r.type}</span>
      <span>${r.date}</span>

      <span class="px-2 py-1 text-xs rounded w-fit ${getStatusColor(r.status)}">
        ${getStatusText(r.status)}
      </span>

      <div class="flex justify-center gap-2">
        <button onclick="viewReport()"
          class="px-3 py-1 bg-blue-600 text-white rounded text-xs">
          Xem
        </button>

        ${r.status === "pending" ? `
        <button onclick="openModal(${r.id})"
          class="px-3 py-1 bg-green-600 text-white rounded text-xs">
          Duyệt
        </button>

        <button onclick="rejectReport(${r.id})"
          class="px-3 py-1 bg-red-600 text-white rounded text-xs">
          Từ chối
        </button>
        ` : ""}
      </div>
    `;

    container.appendChild(div);
  });
}

/* ================= STATUS ================= */
function getStatusText(status) {
  if (status === "approved") return "Đã duyệt";
  if (status === "rejected") return "Từ chối";
  return "Chờ duyệt";
}

function getStatusColor(status) {
  if (status === "approved") return "bg-green-100 text-green-700";
  if (status === "rejected") return "bg-red-100 text-red-600";
  return "bg-yellow-100 text-yellow-700";
}

/* ================= ACTION ================= */
function viewReport() {
  alert("Mở file báo cáo (sau này link PDF)");
}

function rejectReport(id) {
  const r = reports.find(x => x.id === id);
  r.status = "rejected";
  renderReports();
}

/* ================= MODAL ================= */
function openModal(id) {
  currentReportId = id;
  document.getElementById("modal").classList.remove("hidden");
  document.getElementById("modal").classList.add("flex");
  renderRequirements();
}

function closeModal() {
  document.getElementById("modal").classList.add("hidden");
}

function renderRequirements() {
  const container = document.getElementById("requirementContainer");
  container.innerHTML = "";

  requirements.forEach(req => {
    const div = document.createElement("div");

    div.className = "flex items-center justify-between border p-3 rounded-xl";

    div.innerHTML = `
      <p>${req.name}</p>
      <input type="checkbox"
        onchange="toggleRequirement(${req.id}, this.checked)">
    `;

    container.appendChild(div);
  });
}

function toggleRequirement(id, checked) {
  const req = requirements.find(r => r.id === id);
  req.status = checked ? "pass" : "fail";
}

/* ================= SUBMIT ================= */
function submitReview() {
  const passed = requirements.filter(r => r.status === "pass").length;
  const total = requirements.length;

  const percent = Math.round((passed / total) * 100);

  const report = reports.find(r => r.id === currentReportId);
  report.status = "approved";

  alert(`Đã duyệt!\nTiến độ: ${percent}%`);

  closeModal();
  renderReports();
}

/* INIT */
renderReports();

</script>
 --}}
