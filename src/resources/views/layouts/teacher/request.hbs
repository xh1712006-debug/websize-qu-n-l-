<div class="animate-in pb-20">
    <!-- PAGE HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                Trung tâm Phê duyệt Đề tài
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Phê duyệt <span class="text-emerald-600">Đăng ký Đồ án</span></h1>
            <p class="text-slate-500 font-medium italic">Kịp thời xem xét và xác nhận các ý tưởng nghiên cứu từ sinh viên được bạn hướng dẫn.</p>
        </div>
        
        <div class="flex items-center gap-3 px-6 py-4 bg-white rounded-3xl border border-slate-100 shadow-sm">
             <div class="w-3 h-3 bg-emerald-500 rounded-full animate-bounce"></div>
             <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Cần xử lý: {{requests.length}} Yêu cầu</span>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-8">
        <button onclick="switchTab('waiting')" id="tab-waiting" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            Chờ phê duyệt
            <span id="count-waiting" class="ml-2 px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('approved')" id="tab-approved" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
            Đã duyệt
            <span id="count-approved" class="ml-2 px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('rejected')" id="tab-rejected" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-rose-500"></span>
            Đã từ chối
            <span id="count-rejected" class="ml-2 px-2 py-0.5 bg-rose-100 text-rose-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- DATA TABLE CONTAINER -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden relative">
        <div id="tab-indicator" class="absolute top-0 left-0 h-1.5 bg-gradient-to-r transition-all duration-500"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-7 bg-slate-50/50">Sinh viên</th>
                        <th class="px-8 py-7 bg-slate-50/50">Đề tài đăng ký</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Ngày nộp</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Trạng thái</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="requestTableBody" class="divide-y divide-slate-50">
                    <!-- Data loaded via JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const requestsData = {{{json requests}}};
    let currentTab = 'waiting';

    function fetchAndRender() {
        const counts = {
            waiting: requestsData.filter(r => r.status === 'REGISTERED' || r.status === 'WAITING_STUDENT_CONFIRM').length,
            approved: requestsData.filter(r => r.status !== 'REGISTERED' && r.status !== 'WAITING_STUDENT_CONFIRM' && r.status !== 'REJECTED').length,
            rejected: requestsData.filter(r => r.status === 'REJECTED').length
        };

        document.getElementById('count-waiting').innerText = counts.waiting;
        document.getElementById('count-approved').innerText = counts.approved;
        document.getElementById('count-rejected').innerText = counts.rejected;

        renderTable();
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-white', 'border-blue-500', 'text-blue-600', 'bg-slate-50', 'border-slate-100', 'text-slate-400');
            btn.classList.add('bg-slate-50', 'border-slate-50', 'text-slate-400');
        });

        const activeBtn = document.getElementById(`tab-${tab}`);
        activeBtn.classList.remove('bg-slate-50', 'border-slate-50', 'text-slate-400');
        const colorClass = tab === 'waiting' ? 'border-emerald-500 text-emerald-600' : 
                          tab === 'approved' ? 'border-indigo-500 text-indigo-600' : 
                          'border-rose-500 text-rose-600';
        activeBtn.classList.add('bg-white', ...colorClass.split(' '));

        const indicator = document.getElementById('tab-indicator');
        if (tab === 'waiting') {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-emerald-400 to-teal-500 transition-all duration-500';
            indicator.style.width = '100%';
        } else if (tab === 'approved') {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-indigo-400 to-blue-500 transition-all duration-500';
            indicator.style.width = '100%';
        } else {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-rose-400 to-pink-500 transition-all duration-500';
            indicator.style.width = '100%';
        }

        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById('requestTableBody');
        let filtered = [];

        if (currentTab === 'waiting') {
            filtered = requestsData.filter(r => r.status === 'REGISTERED' || r.status === 'WAITING_STUDENT_CONFIRM');
        } else if (currentTab === 'approved') {
            filtered = requestsData.filter(r => r.status !== 'REGISTERED' && r.status !== 'WAITING_STUDENT_CONFIRM' && r.status !== 'REJECTED');
        } else {
            filtered = requestsData.filter(r => r.status === 'REJECTED');
        }

        if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-24 text-center">
                <div class="flex flex-col items-center gap-4 opacity-30">
                    <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center text-3xl">📂</div>
                    <p class="font-black text-slate-400 uppercase tracking-[0.2em] text-xs">Không có yêu cầu trong mục này</p>
                </div>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = filtered.map(r => {
            const isCompleted = currentTab !== 'waiting';
            
            return `
            <tr class="hover:bg-slate-50/50 transition-all duration-300">
                <td class="px-8 py-7">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-black shadow-sm uppercase italic">
                            ${r.studentName.charAt(0)}
                        </div>
                        <div>
                            <p class="font-black text-slate-900 text-sm leading-tight uppercase">${r.studentName}</p>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">${r.studentCode}</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7 max-w-sm">
                    <p class="font-black text-slate-800 text-xs uppercase leading-relaxed line-clamp-1" title="${r.projectName}">${r.projectName}</p>
                    <div class="flex items-center gap-2 mt-2">
                         <span class="px-2 py-0.5 bg-slate-100 text-slate-400 rounded text-[8px] font-black uppercase tracking-tighter italic">Status: ${r.status}</span>
                    </div>
                </td>
                <td class="px-8 py-7 text-center">
                    <div class="flex flex-col items-center gap-1">
                        <span class="text-xs font-bold text-slate-500">${r.date}</span>
                    </div>
                </td>
                <td class="px-8 py-7 text-center">
                    ${r.status === 'REGISTERED' ? 
                        '<span class="px-3 py-1.5 bg-amber-50 text-amber-600 rounded-xl text-[9px] font-black uppercase border border-amber-100 animate-pulse">⏳ Chờ duyệt</span>' :
                      r.status === 'WAITING_STUDENT_CONFIRM' ?
                        '<span class="px-3 py-1.5 bg-blue-50 text-blue-600 rounded-xl text-[9px] font-black uppercase border border-blue-100 italic">🔄 SV Xác nhận</span>' :
                      r.status === 'REJECTED' ?
                        '<span class="px-3 py-1.5 bg-rose-50 text-rose-600 rounded-xl text-[9px] font-black uppercase border border-rose-100">❌ Từ chối</span>' :
                        '<span class="px-3 py-1.5 bg-emerald-50 text-emerald-600 rounded-xl text-[9px] font-black uppercase border border-emerald-100">✅ Đã duyệt</span>'
                    }
                </td>
                <td class="px-8 py-7 text-right">
                    ${isCompleted ? `
                        <button disabled class="px-8 py-4 bg-slate-50 text-slate-400 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] border border-slate-100 cursor-not-allowed italic">
                            Xem chi tiết →
                        </button>
                    ` : (
                        r.status === 'WAITING_STUDENT_CONFIRM' ? `
                            <button disabled class="px-8 py-4 bg-slate-50 text-slate-300 rounded-2xl text-[10px] font-black uppercase border border-slate-50 cursor-not-allowed">
                                Đang chờ phản hồi...
                            </button>
                        ` : `
                            <div class="flex items-center justify-end gap-2">
                                <a href="/teacher/request/approve/${r.projectId}" class="px-6 py-4 bg-emerald-600 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-700 hover:shadow-lg hover:shadow-emerald-100 transition-all flex items-center justify-center">Phê duyệt</a>
                                <button onclick="rejectRequest('${r.projectId}')" class="px-4 py-4 bg-white border border-slate-200 text-slate-400 rounded-2xl hover:text-rose-600 hover:border-rose-100 transition-all">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                </button>
                            </div>
                        `
                    )}
                </td>
            </tr>
            `;
        }).join('');
    }

    async function rejectRequest(projectId) {
        const { value: reason } = await Swal.fire({
            title: '<span class="uppercase font-black text-rose-600">Từ chối Đề tài</span>',
            input: 'textarea',
            inputLabel: 'Lý do từ chối đồ án này:',
            inputPlaceholder: 'Nhập lý do chi tiết để sinh viên có thể sửa đổi...',
            inputAttributes: { 'aria-label': 'Lý do từ chối' },
            showCancelButton: true,
            confirmButtonText: 'Gửi từ chối',
            cancelButtonText: 'Hủy bỏ',
            confirmButtonColor: '#e11d48',
            borderRadius: '2rem',
            inputValidator: (value) => {
                if (!value) return 'Bạn cần nhập lý do từ chối!'
            }
        });

        if (reason) {
            try {
                const response = await fetch('/teacher/request/reject', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projectId, rejectionReason: reason })
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({
                        title: 'Đã từ chối!',
                        text: data.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Lỗi!', data.message, 'error');
                }
            } catch(err) { console.error(err); }
        }
    }

    // Init
    fetchAndRender();
    switchTab('waiting');
</script>

<style>
    .animate-in {
        animation: animate-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes animate-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
