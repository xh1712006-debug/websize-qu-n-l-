<div class="animate-in">
    <!-- PAGE HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-6">
            <div class="w-20 h-20 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-[2rem] flex items-center justify-center text-3xl shadow-2xl shadow-blue-200">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight">Thẩm định Phản biện</h1>
                <p class="text-slate-500 font-medium mt-1 italic">Nghiên cứu báo cáo và quyết định điều kiện bảo vệ chính thức.</p>
            </div>
        </div>
        
        <div class="flex items-center gap-3 px-6 py-4 bg-white rounded-3xl border border-slate-100 shadow-sm">
             <div class="w-3 h-3 bg-blue-500 rounded-full animate-pulse"></div>
             <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Quyền hạn: Thẩm định & Phê duyệt (Bước 9)</span>
        </div>
    </div>

    <!-- MAIN TABLE CONTAINER -->
    <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden relative group">
        <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-r from-blue-600 to-indigo-600"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-6">Sinh viên</th>
                        <th class="px-8 py-6">Nội dung đồ án</th>
                        <th class="px-8 py-6 text-center">Báo cáo</th>
                        <th class="px-8 py-6 text-center">Mã nguồn</th>
                        <th class="px-8 py-6 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="assignedReviewTable" class="divide-y divide-slate-50">
                    <!-- Data loaded via JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- REVIEW MODAL -->
<div id="review-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-300">
    <div class="bg-white w-full max-w-2xl rounded-[3rem] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300">
        <div class="p-10 border-b border-slate-100 flex items-center justify-between bg-slate-50/30">
            <div>
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Đánh giá Phản biện</h3>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Gửi kết luận cuối cùng cho sinh viên</p>
            </div>
            <button onclick="closeReviewModal()" class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-500 transition-all shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <form id="review-form" class="p-10 space-y-8">
            <input type="hidden" id="modal-student-id">
            
            <div class="space-y-4">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Kết luận chuyên môn</label>
                <div class="grid grid-cols-2 gap-4">
                    <label class="relative flex flex-col p-6 bg-slate-50 rounded-3xl border-2 border-transparent cursor-pointer hover:bg-white hover:border-indigo-100 transition-all group">
                        <input type="radio" name="reviewResult" value="Đạt" required class="absolute top-4 right-4 w-5 h-5 text-indigo-600 focus:ring-indigo-500 border-slate-300">
                        <span class="text-2xl mb-2">✅</span>
                        <span class="font-black text-slate-800 uppercase text-xs">Phê duyệt Bảo vệ</span>
                        <span class="text-[10px] text-slate-400 font-medium mt-1 italic">Đồ án đủ chất lượng.</span>
                    </label>
                    <label class="relative flex flex-col p-6 bg-slate-50 rounded-3xl border-2 border-transparent cursor-pointer hover:bg-white hover:border-rose-100 transition-all group">
                        <input type="radio" name="reviewResult" value="Không đạt" required class="absolute top-4 right-4 w-5 h-5 text-rose-600 focus:ring-rose-500 border-slate-300">
                        <span class="text-2xl mb-2">❌</span>
                        <span class="font-black text-slate-800 uppercase text-xs">Từ chối Bảo vệ</span>
                        <span class="text-[10px] text-slate-400 font-medium mt-1 italic">Cần chỉnh sửa thêm.</span>
                    </label>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nhận xét chi tiết</label>
                <textarea id="modal-feedback" required placeholder="Nhập những điểm sinh viên cần lưu ý hoặc giải trình trong phiên bảo vệ..." class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] text-sm font-medium focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all min-h-[150px]"></textarea>
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full py-5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-[2rem] font-black text-sm uppercase tracking-[0.2em] shadow-2xl shadow-blue-200 hover:scale-[1.02] active:scale-95 transition-all">Gửi Bản thẩm định</button>
            </div>
        </form>
    </div>
</div>

{{#section 'script'}}
<script>
    async function fetchAssignedStudents() {
        try {
            const res = await fetch('/teacher/review/getAssignedStudents');
            const data = await res.json();
            const tbody = document.getElementById('assignedReviewTable');
            
            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-24 text-center">
                    <div class="flex flex-col items-center gap-4 opacity-30">
                        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center text-3xl">📂</div>
                        <p class="font-black text-slate-400 uppercase tracking-[0.2em] text-xs">Chưa có đồ án được phân công</p>
                    </div>
                </td></tr>`;
                return;
            }

            tbody.innerHTML = data.map(p => `
                <tr class="hover:bg-slate-50/50 transition-all duration-300">
                    <td class="px-8 py-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-100 flex items-center justify-center font-black text-blue-600 shadow-sm leading-none">
                                ${p.fullName.charAt(0)}
                            </div>
                            <div>
                                <p class="font-black text-slate-900 text-sm leading-tight uppercase">${p.fullName}</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">${p.studentCode}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-8 py-6 max-w-md">
                        <p class="font-black text-slate-800 text-xs uppercase leading-relaxed line-clamp-1" title="${p.projectName}">${p.projectName}</p>
                        <button onclick='viewProjectDetail(${JSON.stringify(p).replace(/'/g, "&apos;")})' class="mt-2 text-[10px] font-black text-indigo-600 uppercase tracking-widest hover:text-indigo-800 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Chi tiết đề tài & Mục tiêu
                        </button>
                    </td>
                    <td class="px-8 py-6 text-center">
                        ${p.latestReport ? `
                            <a href="/student/report/upload/file/${p.latestReport}" target="_blank" class="inline-flex items-center gap-2 px-6 py-2.5 bg-emerald-50 text-emerald-700 rounded-xl text-[10px] font-black uppercase tracking-widest border border-emerald-100 hover:bg-emerald-600 hover:text-white shadow-sm shadow-emerald-100 transition-all">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                Đọc BC cuối kỳ
                            </a>
                            <p class="text-[8px] text-slate-400 font-bold uppercase mt-1 tracking-tighter">Nộp lúc: ${new Date(p.reportCreatedAt).toLocaleDateString('vi-VN')}</p>
                        ` : '<span class="text-[9px] font-bold text-slate-300 uppercase italic">Chưa nộp báo cáo</span>'}
                    </td>
                    <td class="px-8 py-6 text-center">
                         <span class="px-3 py-1 bg-slate-100 text-slate-500 rounded-lg text-[9px] font-black uppercase italic">
                            ${p.status}
                         </span>
                    </td>
                    <td class="px-8 py-6 text-right">
                        <button onclick="openReviewModal('${p.studentId}')" class="px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] shadow-xl shadow-blue-200 hover:scale-[1.05] active:scale-95 transition-all">
                            Thẩm định đạt
                        </button>
                    </td>
                </tr>
            `).join('');
        } catch (err) { console.error(err); }
    }

    function viewProjectDetail(p) {
        // Simple alert for detail (can be improved to a modal later)
        const detailHtml = `
            <div id="detail-modal" class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300">
                <div class="bg-white w-full max-w-3xl rounded-[3rem] shadow-2xl overflow-hidden p-10 space-y-8 animate-in zoom-in-95">
                    <div class="flex items-center justify-between">
                        <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Chi tiết đồ án</h3>
                        <button onclick="closeDetailModal()" class="w-10 h-10 rounded-full bg-slate-50 text-slate-400 hover:text-rose-500 transition-all flex items-center justify-center">✕</button>
                    </div>
                    <div class="space-y-6">
                        <div class="p-6 bg-indigo-50/50 rounded-3xl border border-indigo-100">
                            <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-2">Đề tài</p>
                            <p class="text-sm font-bold text-indigo-900 leading-relaxed">${p.projectName}</p>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Mục tiêu</p>
                                <p class="text-xs font-medium text-slate-700 leading-relaxed">${p.objective || 'N/A'}</p>
                            </div>
                            <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Phạm vi</p>
                                <p class="text-xs font-medium text-slate-700 leading-relaxed">${p.scope || 'N/A'}</p>
                            </div>
                        </div>
                        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Nội dung chi tiết</p>
                            <p class="text-xs font-medium text-slate-700 leading-relaxed">${p.contentProject || 'N/A'}</p>
                        </div>
                    </div>
                    <div class="pt-4 flex justify-end">
                        <button onclick="closeDetailModal()" class="px-8 py-4 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest">Đã hiểu</button>
                    </div>
                </div>
            </div>
        `;
        const wrapper = document.createElement('div');
        wrapper.id = 'detail-modal-wrapper';
        wrapper.innerHTML = detailHtml;
        document.body.appendChild(wrapper);
    }

    function closeDetailModal() {
        const modal = document.getElementById('detail-modal-wrapper');
        if (modal) modal.remove();
    }

    function openReviewModal(studentId) {
        document.getElementById('modal-student-id').value = studentId;
        document.getElementById('review-modal').classList.remove('hidden');
    }

    function closeReviewModal() {
        document.getElementById('review-modal').classList.add('hidden');
    }

    document.getElementById('review-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const studentId = document.getElementById('modal-student-id').value;
        const reviewResult = document.querySelector('input[name="reviewResult"]:checked').value;
        const feedback = document.getElementById('modal-feedback').value;

        try {
            const res = await fetch('/teacher/review/submitReview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId, reviewResult, feedback })
            });
            const data = await res.json();
            if (data.success) {
                closeReviewModal();
                fetchAssignedStudents();
                alert(data.message);
            }
        } catch (err) { console.error(err); }
    });

    fetchAssignedStudents();
</script>
{{/section}}
