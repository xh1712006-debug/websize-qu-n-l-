<div class="animate-in pb-20">
    <!-- HEADER -->
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-teal-50 text-teal-600 rounded-lg text-[10px] font-black uppercase tracking-wider border border-teal-100">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 011 1v1h5a1 1 0 110 2h-1v11a1 1 0 01-1 1H5a1 1 0 01-1-1V7H3a1 1 0 110-2h5V4a1 1 0 011-1h2zM9 5v1h2V5H9zM7 7v10h10V7H7z"></path></svg>
                Quản lý Thẩm định Phản biện
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Bảng điều khiển <span class="text-teal-600">(GVPB)</span></h1>
            <p class="text-slate-500 font-medium italic">Thực hiện thẩm định, phê duyệt và theo dõi tiến độ phản biện đồ án sinh viên.</p>
        </div>
        
        <div class="flex items-center gap-4">
            <div class="px-8 py-5 bg-white border border-slate-100 rounded-3xl shadow-sm hover:border-teal-100 transition-all group">
                <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest block leading-none mb-2">Tỉ lệ hoàn tất hồ sơ</span>
                <div class="flex items-center gap-4">
                    <span class="text-2xl font-black text-teal-600 leading-none">{{stats.overallProgress}}%</span>
                    <div class="w-24 h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="h-full bg-teal-500 transition-all duration-1000" style="width: {{stats.overallProgress}}%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{#if noAssignment}}
    <div class="bg-white rounded-[4rem] border border-slate-100 p-24 text-center shadow-sm">
        <div class="w-24 h-24 bg-slate-50 rounded-[2.5rem] flex items-center justify-center text-slate-200 mx-auto mb-8">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Chưa có đồ án phân công</h3>
        <p class="text-slate-400 font-medium mt-3 italic">Bạn hiện chưa được phân công phản biện cho bất kỳ đồ án nào.</p>
    </div>
    {{else}}

    <!-- KPI TILES (APP/REJ FOCUSED) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
        <!-- TOTAL -->
        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm flex items-center gap-6 group hover:shadow-xl hover:shadow-teal-900/5 transition-all">
            <div class="w-14 h-14 bg-slate-50 text-slate-400 rounded-2xl flex items-center justify-center group-hover:bg-slate-900 group-hover:text-white transition-all shadow-inner">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <div>
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-1">Hồ sơ phân công</span>
                <span class="text-3xl font-black text-slate-900 leading-none">{{stats.totalAssigned}}</span>
            </div>
        </div>

        <!-- APPROVED (ĐẠT) -->
        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm flex items-center gap-6 group hover:shadow-xl hover:shadow-emerald-900/5 transition-all">
            <div class="w-14 h-14 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-all shadow-inner">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <span class="text-[9px] font-black text-emerald-500 uppercase tracking-widest block mb-1">Đã Duyệt (Đạt)</span>
                <span class="text-3xl font-black text-slate-900 leading-none">{{stats.approvedReviews}}</span>
            </div>
        </div>

        <!-- REJECTED (KHÔNG ĐẠT) -->
        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm flex items-center gap-6 group hover:shadow-xl hover:shadow-rose-900/5 transition-all">
            <div class="w-14 h-14 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center group-hover:bg-rose-600 group-hover:text-white transition-all shadow-inner">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <span class="text-[9px] font-black text-rose-500 uppercase tracking-widest block mb-1">Đã Từ chối</span>
                <span class="text-3xl font-black text-slate-900 leading-none">{{stats.rejectedReviews}}</span>
            </div>
        </div>

        <!-- ACTION CALL -->
        <div class="bg-teal-600 p-8 rounded-[3rem] shadow-2xl shadow-teal-200 flex items-center gap-6 group hover:scale-105 active:scale-95 transition-all cursor-pointer" onclick="window.location.href='/teacher/review'">
            <div class="w-14 h-14 bg-white/20 text-white rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
            </div>
            <div>
                <span class="text-[9px] font-black text-white/60 uppercase tracking-widest block mb-1">Quy định</span>
                <span class="text-xl font-black text-white uppercase tracking-tight leading-none">Thẩm định ngay</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- FOCUS TASKS (REFINED) -->
        <div class="lg:col-span-2 space-y-10">
            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight border-l-4 border-teal-500 pl-4">Nhiệm vụ trọng tâm</h3>
            
            <div class="bg-white rounded-[3.5rem] border border-slate-100 p-12 shadow-sm relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-64 h-64 bg-teal-50 rounded-full blur-3xl -mr-32 -mt-32 opacity-40 group-hover:scale-110 transition-transform duration-1000"></div>
                
                <div class="relative space-y-12">
                    <div class="flex gap-8">
                        <div class="w-16 h-16 bg-teal-50 text-teal-600 rounded-2xl flex items-center justify-center shrink-0 shadow-inner">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        </div>
                        <div class="space-y-3">
                            <h4 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Đối soát Báo cáo & Hồ sơ</h4>
                            <p class="text-slate-500 font-medium leading-relaxed italic">Kiểm tra tính hợp lệ của báo cáo cuối kỳ. Đảm bảo sinh viên đã hoàn thành đầy đủ các yêu cầu chuyên môn trước khi phê duyệt ra hội đồng.</p>
                        </div>
                    </div>

                    <div class="flex gap-8">
                        <div class="w-16 h-16 bg-teal-50 text-teal-600 rounded-2xl flex items-center justify-center shrink-0 shadow-inner">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div class="space-y-3">
                            <h4 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Phê duyệt Điều kiện Bảo vệ</h4>
                            <p class="text-slate-500 font-medium leading-relaxed italic">Kết luận hồ sơ ở trạng thái **"Đạt"** (Đủ điều kiện ra hội đồng) hoặc **"Không đạt"**. Ghi nhận phản hồi chuyên môn để sinh viên cải thiện.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- DEFENSE CALENDAR -->
        <div class="space-y-10">
            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight border-l-4 border-slate-900 pl-4">Lịch SV được phân công</h3>
            
            <div class="space-y-4">
                {{#each upcomingDefenses}}
                <div class="bg-white p-6 rounded-[2.5rem] border border-slate-100 shadow-sm flex gap-6 hover:bg-slate-50 hover:-translate-x-2 transition-all cursor-pointer group">
                    <div class="w-14 h-16 bg-slate-900 text-white rounded-2xl flex flex-col items-center justify-center shrink-0 shadow-lg group-hover:bg-teal-600 transition-colors">
                        <span class="text-[9px] font-black uppercase mb-1">{{substring (dateFormat this.date "MMMM") 0 3}}</span>
                        <span class="text-xl font-black leading-none">{{dateFormat this.date "DD"}}</span>
                    </div>
                    <div class="min-w-0 flex-1">
                        <h5 class="text-xs font-black text-slate-900 uppercase truncate mb-1 group-hover:text-teal-600 transition-colors">{{this.studentName}}</h5>
                        <p class="text-[10px] text-slate-400 font-bold truncate mb-3 uppercase tracking-tighter">{{this.projectName}}</p>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-1.5 text-[10px] font-black text-teal-500 uppercase">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                {{this.time}}
                            </div>
                            <div class="flex items-center gap-1.5 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                🏛️ {{this.room}}
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
                
                {{#unless upcomingDefenses.length}}
                <div class="bg-slate-50/50 rounded-[3rem] p-10 text-center border-2 border-dashed border-slate-100">
                    <p class="text-xs font-bold text-slate-300 uppercase tracking-widest">Chưa có lịch bảo vệ</p>
                </div>
                {{/unless}}
            </div>
            
            <a href="/teacher/review/schedule" class="w-full h-16 bg-white border border-slate-200 text-slate-600 rounded-[2rem] flex items-center justify-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all shadow-sm">
                XEM TOÀN BỘ LỊCH PHẢN BIỆN
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
        </div>
    </div>
    {{/if}}
</div>

<style>
    .animate-in {
        animation: animate-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes animate-in {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
