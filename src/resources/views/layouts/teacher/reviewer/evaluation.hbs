<div class="animate-in pb-20">
    <!-- PAGE HEADER -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-teal-50 text-teal-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>
                Quy trình Phản biện
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Thẩm định đồ án Phản biện</h1>
            <p class="text-slate-500 font-medium italic">Thực hiện thẩm định hồ sơ, đánh giá chất lượng đồ án và phê duyệt điều kiện bảo vệ Hội đồng.</p>
        </div>
        
        <div class="flex items-center gap-3 px-6 py-4 bg-white rounded-3xl border border-slate-100 shadow-sm">
             <div class="w-3 h-3 bg-teal-500 rounded-full animate-pulse"></div>
             <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Vai trò: Phản biện (GVPB)</span>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-8">
        <button onclick="switchTab('eligible')" id="tab-eligible" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            Đủ điều kiện thẩm định
            <span id="count-eligible" class="ml-2 px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('completed')" id="tab-completed" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
            Đã thẩm định xong
            <span id="count-completed" class="ml-2 px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('pending')" id="tab-pending" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-slate-400"></span>
            Chưa đủ điều kiện
            <span id="count-pending" class="ml-2 px-2 py-0.5 bg-slate-100 text-slate-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- MAIN TABLE CONTAINER -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden relative group">
        <div id="tab-indicator" class="absolute top-0 left-0 h-1.5 bg-gradient-to-r transition-all duration-500"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-7 bg-slate-50/50">Sinh viên</th>
                        <th class="px-8 py-7 bg-slate-50/50">Nội dung đồ án</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Tài liệu đính kèm</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-center">Trạng thái / Nhận xét</th>
                        <th class="px-8 py-7 bg-slate-50/50 text-right">Hành động</th>
                    </tr>
                </thead>
                <tbody id="assignedReviewTable" class="divide-y divide-slate-50">
                    <!-- Data loaded via JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- REVIEW MODAL -->
<div id="review-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-300">
    <div class="bg-white w-full max-w-2xl rounded-[3rem] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300">
        <div class="p-10 border-b border-slate-100 flex items-center justify-between bg-teal-50/30">
            <div>
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight text-teal-600">Bản Thẩm định Phản biện</h3>
                <p id="modal-subtitle" class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Kết luận chất lượng đồ án & điều kiện bảo vệ</p>
            </div>
            <button onclick="closeReviewModal()" class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-500 transition-all shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <form id="review-form" class="p-10 space-y-8">
            <input type="hidden" id="modal-student-id">
            
            <div class="space-y-4">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Kết luận thẩm định</label>
                <div class="grid grid-cols-2 gap-4">
                    <label class="relative flex flex-col p-6 bg-slate-50 rounded-3xl border-2 border-transparent cursor-pointer hover:bg-white hover:border-teal-100 transition-all group has-[:checked]:bg-teal-50/50 has-[:checked]:border-teal-500">
                        <input type="radio" name="reviewResult" value="Đạt" required class="absolute top-4 right-4 w-5 h-5 text-teal-600 focus:ring-teal-500 border-slate-300">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-xl mb-3 shadow-sm group-hover:scale-110 transition-transform">✅</div>
                        <span class="font-black text-slate-800 uppercase text-xs">Biểu quyết Bảo vệ</span>
                        <span class="text-[10px] text-slate-400 font-medium mt-1 italic leading-tight">Đồ án đáp ứng các tiêu chuẩn chất lượng.</span>
                    </label>
                    <label class="relative flex flex-col p-6 bg-slate-50 rounded-3xl border-2 border-transparent cursor-pointer hover:bg-white hover:border-rose-100 transition-all group has-[:checked]:bg-rose-50/50 has-[:checked]:border-rose-500">
                        <input type="radio" name="reviewResult" value="Không đạt" required class="absolute top-4 right-4 w-5 h-5 text-rose-600 focus:ring-rose-500 border-slate-300">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-xl mb-3 shadow-sm group-hover:scale-110 transition-transform">❌</div>
                        <span class="font-black text-slate-800 uppercase text-xs">Không đủ điều kiện</span>
                        <span class="text-[10px] text-slate-400 font-medium mt-1 italic leading-tight">Cần sửa đổi thêm hoặc không đạt yêu cầu.</span>
                    </label>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nhận xét chuyên môn (Bắt buộc)</label>
                <textarea id="modal-feedback" required placeholder="Nêu rõ ưu điểm, nhược điểm và những điều cần bổ sung..." class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-[2rem] text-sm font-medium focus:ring-4 focus:ring-teal-500/10 focus:border-teal-500 outline-none transition-all min-h-[120px] shadow-inner"></textarea>
            </div>

            <div class="pt-6" id="modal-footer">
                <button type="submit" class="w-full py-5 bg-gradient-to-r from-teal-600 to-cyan-600 text-white rounded-[2rem] font-black text-sm uppercase tracking-[0.2em] shadow-xl shadow-teal-200 hover:scale-[1.02] active:scale-95 transition-all">Gửi kết quả thẩm định</button>
            </div>
        </form>
    </div>
</div>

{{#section 'script'}}
<script>
    let allData = [];
    let currentTab = 'eligible';

    async function fetchAssignedStudents() {
        try {
            const res = await fetch('/teacher/review/getAssignedStudents');
            allData = await res.json();
            
            // Calculate counts
            const counts = {
                eligible: allData.filter(p => (p.workflowState === 'ready' || p.isAdvisorApproved) && (p.reviewFeedback === null || p.reviewFeedback === '')).length,
                completed: allData.filter(p => p.reviewFeedback !== null && p.reviewFeedback !== '').length,
                pending: allData.filter(p => p.workflowState !== 'ready' && !p.isAdvisorApproved && (p.reviewFeedback === null || p.reviewFeedback === '')).length
            };

            document.getElementById('count-eligible').innerText = counts.eligible;
            document.getElementById('count-completed').innerText = counts.completed;
            document.getElementById('count-pending').innerText = counts.pending;

            renderTable();
        } catch (err) { console.error(err); }
    }

    function switchTab(tab) {
        currentTab = tab;
        
        // Update UI Tabs
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-white', 'border-teal-500', 'text-teal-600', 'bg-slate-50', 'border-slate-200', 'text-slate-400');
            btn.classList.add('bg-slate-50', 'border-slate-100', 'text-slate-400');
        });

        const activeBtn = document.getElementById(`tab-${tab}`);
        activeBtn.classList.remove('bg-slate-50', 'border-slate-100', 'text-slate-400');
        const colorClass = tab === 'eligible' ? 'border-emerald-500 text-emerald-600' : 
                          tab === 'completed' ? 'border-indigo-500 text-indigo-600' : 
                          'border-slate-400 text-slate-500';
        activeBtn.classList.add('bg-white', ...colorClass.split(' '));

        // Update Indicator
        const indicator = document.getElementById('tab-indicator');
        if (tab === 'eligible') {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-emerald-400 to-teal-500 transition-all duration-500';
            indicator.style.width = '100%';
        } else if (tab === 'completed') {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-indigo-400 to-blue-500 transition-all duration-500';
            indicator.style.width = '100%';
        } else {
            indicator.className = 'absolute top-0 left-0 h-1.5 bg-gradient-to-r from-slate-400 to-slate-500 transition-all duration-500';
            indicator.style.width = '100%';
        }

        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById('assignedReviewTable');
        let filteredData = [];

        if (currentTab === 'eligible') {
            filteredData = allData.filter(p => (p.workflowState === 'ready' || p.isAdvisorApproved) && (p.reviewFeedback === null || p.reviewFeedback === ''));
        } else if (currentTab === 'completed') {
            filteredData = allData.filter(p => p.reviewFeedback !== null && p.reviewFeedback !== '');
        } else {
            filteredData = allData.filter(p => p.workflowState !== 'ready' && !p.isAdvisorApproved && (p.reviewFeedback === null || p.reviewFeedback === ''));
        }

        if (filteredData.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-24 text-center">
                <div class="flex flex-col items-center gap-4 opacity-30">
                    <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center text-3xl">📂</div>
                    <p class="font-black text-slate-400 uppercase tracking-[0.2em] text-xs">Trống</p>
                </div>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = filteredData.map(p => {
            const isCompleted = p.reviewFeedback !== null && p.reviewFeedback !== '';
            const isLocked = p.workflowState === 'locked' && !isCompleted;
            const isRejected = p.workflowState === 'rejected';
            
            const rowClass = isLocked ? 'opacity-60 bg-slate-50/30' : 
                             isCompleted ? 'bg-indigo-50/5' : 
                             'hover:bg-slate-50 transition-all duration-300';
            
            return `
            <tr class="${rowClass}">
                <td class="px-8 py-7">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center font-black text-slate-400 border border-slate-100 shadow-sm">
                            ${p.fullName.charAt(0)}
                        </div>
                        <div>
                            <p class="font-black text-slate-900 text-sm leading-tight uppercase">${p.fullName}</p>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">${p.studentCode}</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-7">
                    <p class="font-black text-slate-800 text-xs uppercase leading-relaxed line-clamp-1" title="${p.projectName}">${p.projectName}</p>
                    <button onclick='viewProjectDetail(${JSON.stringify(p).replace(/'/g, "&apos;")})' class="mt-2 text-[9px] font-black text-teal-600 hover:underline uppercase tracking-widest">Nội dung đề tài</button>
                </td>
                <td class="px-8 py-7 text-center">
                    ${p.latestReport ? `
                        <a href="/student/report/upload/file/${p.latestReport}" target="_blank" class="inline-flex items-center gap-2 px-6 py-2.5 bg-white text-indigo-600 rounded-xl text-[10px] font-black uppercase tracking-widest border border-indigo-100 hover:bg-indigo-600 hover:text-white transition-all shadow-sm">
                            📄 Báo cáo Cuối kỳ
                        </a>
                    ` : '<span class="text-[9px] font-bold text-slate-300 uppercase italic">Chưa nộp</span>'}
                </td>
                <td class="px-8 py-7 text-center">
                    ${isCompleted ? `
                        <div class="flex flex-col items-center">
                            <span class="px-3 py-1 bg-${p.reviewVerdict === 1 ? 'emerald' : 'rose'}-50 text-${p.reviewVerdict === 1 ? 'emerald' : 'rose'}-600 rounded-lg text-[9px] font-black uppercase border border-${p.reviewVerdict === 1 ? 'emerald' : 'rose'}-100">
                                ${p.reviewVerdict === 1 ? '✅ Đạt' : '❌ Không đạt'}
                            </span>
                            <p class="text-[8px] text-slate-400 mt-1 italic font-medium max-w-[120px] truncate" title="${p.reviewFeedback}">"${p.reviewFeedback}"</p>
                        </div>
                    ` : `
                        <span class="text-[9px] font-bold text-slate-300 uppercase italic">Chưa có kết quả</span>
                    `}
                </td>
                <td class="px-8 py-7 text-right">
                    ${isCompleted ? `
                        <button onclick="openReviewModal('${p.studentId}', true)" class="px-8 py-4 bg-slate-50 text-slate-500 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200">
                            Xem kết quả
                        </button>
                    ` : currentTab === 'eligible' ? `
                        <button onclick="openReviewModal('${p.studentId}', false)" class="px-8 py-4 bg-white border-2 border-emerald-600 text-emerald-600 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-emerald-600 hover:text-white transition-all shadow-sm">
                            Thực hiện Thẩm định
                        </button>
                    ` : `
                        <span class="text-[9px] font-black text-rose-400 uppercase italic">Chưa thể thẩm định</span>
                    `}
                </td>
            </tr>
            `;
        }).join('');
    }

    function viewProjectDetail(p) {
        const detailHtml = `
            <div id="detail-modal" class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300">
                <div class="bg-white w-full max-w-3xl rounded-[3.5rem] shadow-2xl overflow-hidden p-12 space-y-10 animate-in zoom-in-95">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Chi tiết hồ sơ đồ án</h3>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mt-1">Thông tin nền tảng dùng cho thẩm định</p>
                        </div>
                        <button onclick="closeDetailModal()" class="w-12 h-12 rounded-full bg-slate-50 text-slate-400 hover:text-rose-500 transition-all flex items-center justify-center border border-slate-100 shadow-sm">✕</button>
                    </div>
                    <div class="space-y-8">
                        <div class="p-8 bg-teal-50/50 rounded-[2.5rem] border border-teal-50">
                            <p class="text-[10px] font-black text-teal-400 uppercase tracking-widest mb-3 leading-none">Tên đề tài đồ án</p>
                            <p class="text-base font-black text-teal-900 leading-relaxed uppercase">${p.projectName}</p>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 leading-none underline decoration-2 decoration-teal-200 underline-offset-4">Mục tiêu đề ra</p>
                                <p class="text-xs font-medium text-slate-600 leading-relaxed">${p.objective || 'N/A'}</p>
                            </div>
                            <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-200">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 leading-none underline decoration-2 decoration-teal-200 underline-offset-4">Phạm vi thực hiện</p>
                                <p class="text-xs font-medium text-slate-600 leading-relaxed">${p.scope || 'N/A'}</p>
                            </div>
                        </div>
                    </div>
                    <div class="pt-4 flex justify-center">
                        <button onclick="closeDetailModal()" class="px-12 py-5 bg-slate-900 text-white rounded-[2rem] font-black text-xs uppercase tracking-[0.3em] shadow-xl hover:bg-black transition-all">Đã rõ nội dung</button>
                    </div>
                </div>
            </div>
        `;
        const wrapper = document.createElement('div');
        wrapper.id = 'detail-modal-wrapper';
        wrapper.innerHTML = detailHtml;
        document.body.appendChild(wrapper);
    }

    function closeDetailModal() {
        const modal = document.getElementById('detail-modal-wrapper');
        if (modal) modal.remove();
    }

    function openReviewModal(studentId, isViewOnly) {
        const student = allData.find(s => s.studentId === studentId);
        document.getElementById('modal-student-id').value = studentId;
        
        // Reset form
        document.getElementById('review-form').reset();
        document.getElementById('modal-feedback').value = '';
        
        if (isViewOnly && student) {
            // Fill data and disable
            const verdict = student.reviewVerdict === 1 ? 'Đạt' : 'Không đạt';
            const radio = document.querySelector(`input[name="reviewResult"][value="${verdict}"]`);
            if (radio) radio.checked = true;
            document.getElementById('modal-feedback').value = student.reviewFeedback || '';
            
            // UI adjustments for View Only
            document.getElementById('modal-subtitle').innerText = 'Dữ liệu đã chốt - Không thể chỉnh sửa';
            document.getElementById('modal-footer').classList.add('hidden');
            document.querySelectorAll('input[name="reviewResult"]').forEach(r => r.disabled = true);
            document.getElementById('modal-feedback').disabled = true;
            document.getElementById('modal-feedback').classList.add('bg-slate-100', 'cursor-not-allowed');
        } else {
            // Enable for review
            document.getElementById('modal-subtitle').innerText = 'Kết luận chất lượng đồ án & điều kiện bảo vệ';
            document.getElementById('modal-footer').classList.remove('hidden');
            document.querySelectorAll('input[name="reviewResult"]').forEach(r => r.disabled = false);
            document.getElementById('modal-feedback').disabled = false;
            document.getElementById('modal-feedback').classList.remove('bg-slate-100', 'cursor-not-allowed');
        }

        document.getElementById('review-modal').classList.remove('hidden');
    }

    function closeReviewModal() {
        document.getElementById('review-modal').classList.add('hidden');
    }

    document.getElementById('review-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const studentId = document.getElementById('modal-student-id').value;
        const reviewResult = document.querySelector('input[name="reviewResult"]:checked').value;
        const feedback = document.getElementById('modal-feedback').value;

        try {
            const res = await fetch('/teacher/review/submitReview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId, reviewResult, feedback })
            });
            const data = await res.json();
            if (data.success) {
                closeReviewModal();
                fetchAssignedStudents();
                alert('🎉 Gửi kết quả thẩm định thành công!');
            }
        } catch (err) { console.error(err); }
    });

    // Initial fetch
    fetchAssignedStudents();
    switchTab('eligible'); // Default tab
</script>
{{/section}}
