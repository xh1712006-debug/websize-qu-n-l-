<div class="animate-in pb-20">
    <!-- PAGE HEADER -->
    <div class="mb-12 flex flex-col xl:flex-row xl:items-end justify-between gap-8">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-teal-50 text-teal-600 rounded-lg text-[10px] font-black uppercase tracking-wider border border-teal-100">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                Trung tâm Thẩm định Phản biện
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Lịch bảo vệ <span class="text-teal-600">(Phản biện)</span></h1>
            <p class="text-slate-500 font-medium italic">Theo dõi ngày giờ, hội đồng và hồ sơ các sinh viên được phân công thẩm định phản biện.</p>
        </div>

        {{#if activePeriod}}
        <div class="flex-1 max-w-xl">
             <div class="px-6 py-4 bg-gradient-to-r from-teal-500 to-emerald-600 rounded-[2rem] shadow-xl shadow-teal-100 flex items-center justify-between text-white overflow-hidden relative group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 relative z-10">
                    <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center text-xl backdrop-blur-md border border-white/20">
                        📅
                    </div>
                    <div>
                        <p class="text-[8px] font-black uppercase tracking-[0.2em] text-teal-100 mb-0.5">Đợt bảo vệ hiện tại</p>
                        <h4 class="text-sm font-black uppercase tracking-tight">{{activePeriod.name}}</h4>
                    </div>
                </div>
                <div class="flex items-center gap-2 relative z-10 bg-white/20 px-3 py-1.5 rounded-xl border border-white/20">
                    <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                    <span class="text-[9px] font-black uppercase tracking-widest">Active</span>
                </div>
             </div>
        </div>
        {{/if}}

        <div class="flex items-center gap-4">
             <div class="px-8 py-5 bg-white rounded-3xl border border-slate-100 shadow-sm transition-all hover:border-teal-100 flex items-center gap-6">
                <div class="text-center">
                    <p class="text-[9px] font-black text-slate-300 uppercase tracking-widest mb-1">Tổng Phân công</p>
                    <p class="text-xl font-black text-slate-900 leading-none">{{schedules.length}}</p>
                </div>
             </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-10">
        <button onclick="switchTab('scheduled')" id="tab-scheduled" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-teal-500 animate-pulse"></span>
            Lịch bảo vệ (Đã xếp)
            <span id="count-scheduled" class="ml-2 px-2 py-0.5 bg-teal-100 text-teal-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('pending')" id="tab-pending" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-amber-500"></span>
            Chờ xếp lịch
            <span id="count-pending" class="ml-2 px-2 py-0.5 bg-amber-100 text-amber-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- TIMELINE CONTAINER -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="scheduleTimeline">
        <!-- Injected by JS -->
    </div>

    <!-- EMPTY STATE -->
    <div id="emptySchedule" class="hidden py-40 text-center bg-white rounded-[4rem] border border-dashed border-slate-200">
        <div class="w-32 h-32 bg-slate-50 rounded-[3rem] flex items-center justify-center mx-auto mb-8 text-6xl opacity-30">🗓️</div>
        <h3 class="text-2xl font-black text-slate-300 uppercase tracking-widest">Không có lịch bảo vệ</h3>
        <p class="text-slate-400 font-medium mt-3 italic tracking-wide">Hiện không tìm thấy buổi bảo vệ nào trong mục này.</p>
    </div>

</div>

<!-- SCRIPTS -->
<script>
    const scheduleData = {{{json schedules}}};
    let currentTab = 'scheduled';

    function init() {
        const items = scheduleData.map(item => {
            return {
                ...item,
                category: item.defenseDate ? 'scheduled' : 'pending',
                sortDate: item.defenseDate ? new Date(item.defenseDate).getTime() : 0
            };
        });

        const categories = {
            scheduled: items.filter(i => i.category === 'scheduled').sort((a,b) => a.sortDate - b.sortDate),
            pending: items.filter(i => i.category === 'pending')
        };

        document.getElementById('count-scheduled').innerText = categories.scheduled.length;
        document.getElementById('count-pending').innerText = categories.pending.length;

        renderTimeline(categories);
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.className = 'tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 bg-slate-50 border-slate-50 text-slate-400';
        });

        const activeBtn = document.getElementById(`tab-${tab}`);
        const colorClass = tab === 'scheduled' ? 'border-teal-500 text-teal-600' : 
                          'border-amber-500 text-amber-600';
        activeBtn.className = `tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 bg-white ${colorClass}`;

        init();
    }

    function renderTimeline(categories) {
        const container = document.getElementById('scheduleTimeline');
        const emptyState = document.getElementById('emptySchedule');
        const data = categories[currentTab];

        if (data.length === 0) {
            container.classList.add('hidden');
            emptyState.classList.remove('hidden');
            return;
        }

        container.classList.remove('hidden');
        emptyState.classList.add('hidden');

        container.innerHTML = data.map((item, index) => {
            const dateStr = item.defenseDate ? new Date(item.defenseDate).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' }) : 'Chưa có ngày';
            const isPending = currentTab === 'pending';
            
            return `
            <div class="group relative bg-white p-10 rounded-[3.5rem] border border-slate-100 shadow-[0_10px_40px_rgba(0,0,0,0.02)] hover:shadow-[0_40px_80px_rgba(13,148,136,0.08)] hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">
                <!-- TOP DECORATION -->
                <div class="absolute top-0 right-0 w-32 h-32 bg-teal-50/40 rounded-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-700"></div>
                
                <!-- HEADER: STUDENT IDENTITY -->
                <div class="flex items-start justify-between mb-8 relative z-10">
                    <div class="flex items-center gap-5">
                        <div class="w-16 h-16 rounded-2xl bg-teal-600 text-white flex items-center justify-center font-black italic text-xl shadow-lg group-hover:rotate-[10deg] transition-transform duration-500 shadow-teal-100">
                            ${item.studentName.charAt(0)}
                        </div>
                        <div>
                            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight flex items-center gap-2 group-hover:text-teal-600 transition-colors">
                                ${item.studentName}
                            </h3>
                            <span class="inline-block mt-2 px-3 py-1 bg-slate-100 text-slate-500 text-[9px] font-black uppercase tracking-widest rounded-lg border border-slate-200/50">
                                MSSV: ${item.studentCode}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- PROJECT BOARD (REVIEWER STYLE) -->
                <div class="flex-1 space-y-6 relative z-10">
                    <div class="p-8 bg-slate-50/50 backdrop-blur-sm border border-slate-100 rounded-[2.5rem] group-hover:bg-white group-hover:border-teal-100 transition-all duration-500">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.3em] mb-4 leading-none italic border-l-4 border-teal-500 pl-3">Phân công Phản biện</p>
                        <h4 class="text-base font-black text-slate-800 leading-relaxed uppercase tracking-tight">${item.projectName}</h4>
                    </div>

                    <!-- ADVISOR INFO -->
                    <div class="flex items-center gap-4 px-4">
                        <div class="w-10 h-10 bg-teal-50 text-teal-600 rounded-xl flex items-center justify-center text-lg shadow-inner">
                            👨‍🏫
                        </div>
                        <div class="flex-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">GVHD Hướng dẫn</p>
                            <p class="text-xs font-black text-slate-700 uppercase italic underline decoration-teal-200 underline-offset-4 decoration-2">${item.advisorName}</p>
                        </div>
                    </div>
                </div>

                <!-- FOOTER: SCHEDULE & ACTION -->
                <div class="mt-10 pt-10 border-t border-slate-50 relative z-10">
                    <div class="flex items-center justify-between">
                        <div class="space-y-4">
                            <div class="flex items-center gap-3">
                                <span class="w-10 h-10 bg-teal-50 text-teal-600 rounded-xl flex items-center justify-center border border-teal-50 shadow-sm">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z"></path></svg>
                                </span>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Thời gian bảo vệ</p>
                                    <p class="text-sm font-black text-slate-900 italic underline decoration-teal-100 underline-offset-2">${dateStr} <span class="mx-2 text-teal-400">•</span> ${item.defenseTime || '--:--'}</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="w-10 h-10 bg-slate-900 text-white rounded-xl flex items-center justify-center shadow-lg shadow-slate-100">
                                    🏛️
                                </span>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Phòng</p>
                                    <p class="text-sm font-black text-slate-900">${item.defenseRoom || '--'}</p>
                                </div>
                            </div>
                        </div>

                        <!-- ACTION: VÀO PHẢN BIỆN -->
                        <div class="flex flex-col items-end gap-3">
                            <a href="/teacher/review" class="flex flex-col items-center gap-1 group/btn p-4 bg-teal-600 text-white rounded-2xl shadow-xl shadow-teal-100 hover:scale-105 transition-all duration-300">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <span class="text-[9px] font-black uppercase tracking-widest">Vào Phản biện</span>
                            </a>
                            
                            ${item.council ? `
                            <div class="group/council relative">
                                <div class="px-4 py-2 bg-slate-50 text-slate-600 rounded-xl border border-slate-100 cursor-help hover:bg-slate-900 hover:text-white transition-all text-center">
                                    <span class="block text-[8px] font-black uppercase tracking-tight opacity-60">Board</span>
                                    <span class="block text-[10px] font-black uppercase">${item.council.councilName.split(' ')[2] || 'Details'}</span>
                                </div>
                                <div class="hidden group-hover/council:flex absolute bottom-full right-0 mb-4 bg-slate-900 text-white p-6 rounded-[2rem] shadow-2xl z-[100] flex-col gap-4 min-w-[280px] animate-in zoom-in duration-300 text-left">
                                    <p class="text-[10px] font-black text-teal-400 uppercase tracking-[0.3em] border-b border-white/10 pb-2 italic">Thành phần hội đồng</p>
                                    <div class="space-y-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-teal-500/20 text-teal-400 flex items-center justify-center text-[10px] font-black italic">CT</div>
                                            <div><p class="text-[8px] text-white/40 uppercase">Chủ tịch</p><p class="text-xs font-black uppercase font-black">${item.council.chairmanId.fullName}</p></div>
                                        </div>
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-[10px] font-black italic">TK</div>
                                            <div><p class="text-[8px] text-white/40 uppercase">Thư ký</p><p class="text-xs font-black uppercase font-black">${item.council.secretaryId.fullName}</p></div>
                                        </div>
                                        <div>
                                            <p class="text-[8px] text-white/40 uppercase mb-2">Ủy viên cùng chấm</p>
                                            <div class="flex flex-wrap gap-1.5">
                                                ${item.council.memberIds.map(m => `<span class="px-2.5 py-1 bg-white/10 rounded text-[9px] font-bold uppercase">${m.fullName}</span>`).join('')}
                                            </div>
                                        </div>
                                    </div>
                                    <div class="absolute bottom-[-10px] right-6 w-5 h-5 bg-slate-900 rotate-45"></div>
                                </div>
                            </div>
                            ` : ''}
                        </div>
                    </div>
                </div>
            </div>
            `;
        }).join('');
    }

    init();
</script>

<style>
    .animate-in {
        animation: animate-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes animate-in {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
