<div class="space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700">

    <!-- PAGE HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-emerald-600 rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-emerald-100">
                📈
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Chấm điểm Đồ án</h1>
                <p class="text-slate-500 font-medium mt-1">Đánh giá kết luận và nhập điểm chính thức cho sinh viên</p>
            </div>
        </div>
        
        <div class="flex items-center gap-2 px-5 py-3 bg-white rounded-2xl shadow-sm border border-slate-100">
             <span class="w-3 h-3 bg-emerald-500 rounded-full"></span>
             <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Hội đồng chấm thi</span>
        </div>
    </div>

    <!-- MAIN TABLE CONTAINER -->
    <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden relative group">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 to-indigo-500"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-6">Sinh viên</th>
                        <th class="px-8 py-6">Đề tài đồ án</th>
                        <th class="px-8 py-6">Trạng thái</th>
                        <th class="px-8 py-6">Điểm số</th>
                        <th class="px-8 py-6 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="studentTable" class="divide-y divide-slate-50">
                    <!-- Dynamic content from score.js -->
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- PREMIUM MODAL OVERLAY -->
<div id="modal" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center p-4 bg-slate-900/40 backdrop-blur-md">
    <div class="bg-white w-full max-w-md p-10 rounded-[3rem] shadow-2xl relative z-10 animate-in zoom-in duration-300 transform scale-100">
        <button id="closeModalBtn" class="absolute top-6 right-6 w-10 h-10 bg-slate-50 text-slate-400 hover:text-slate-900 rounded-full flex items-center justify-center transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="text-center mb-10">
            <div class="w-20 h-20 rounded-[2rem] bg-emerald-50 text-emerald-500 flex items-center justify-center text-3xl font-black mx-auto mb-6 shadow-inner border-4 border-white">
                📊
            </div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight">Nhập điểm Đồ án</h2>
            <p id="studentName" class="text-sm font-bold text-indigo-500 mt-2">Nguyễn Văn A</p>
        </div>

        <div class="space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Điểm số (thang điểm 10)</label>
                <input id="scoreInput" type="number" min="0" max="10" step="0.1" placeholder="8.5"
                    class="w-full bg-slate-50 border-2 border-transparent focus:border-emerald-500 focus:bg-white rounded-2xl p-4 text-2xl font-black text-slate-700 outline-none transition-all shadow-inner text-center">
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Nhận xét chi tiết</label>
                <textarea id="commentInput" rows="4" 
                    class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-500 focus:bg-white rounded-2xl p-4 text-slate-600 font-bold outline-none transition-all shadow-inner italic" 
                    placeholder="Nhận xét về thái độ làm việc và kết quả sản phẩm..."></textarea>
            </div>
        </div>

        <button id="saveScoreBtn" class="mt-10 w-full py-5 bg-gradient-to-r from-emerald-600 to-indigo-600 text-white font-black rounded-3xl transition-all hover:scale-105 shadow-xl shadow-emerald-200">
            XÁC NHẬN LƯU ĐIỂM
        </button>
    </div>
</div>
