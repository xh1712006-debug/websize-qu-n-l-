<div class="space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700">

    <!-- PAGE HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 bg-purple-600 rounded-3xl flex items-center justify-center text-3xl shadow-xl shadow-purple-100">
                ⚖️
            </div>
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Điểm Phản biện</h1>
                <p class="text-slate-500 font-medium mt-1">Đánh giá khách quan và nhập điểm phản biện cho các đồ án được phân công</p>
            </div>
        </div>
        
        <div class="flex items-center gap-2 px-5 py-3 bg-white rounded-2xl shadow-sm border border-slate-100">
             <span class="w-3 h-3 bg-purple-500 rounded-full animate-bounce"></span>
             <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Vai trò: Phản biện</span>
        </div>
    </div>

    <!-- MAIN TABLE CONTAINER -->
    <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden relative group">
        <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-r from-purple-500 to-indigo-500"></div>
        
        <div class="overflow-x-auto relative z-10">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black border-b border-slate-50">
                        <th class="px-8 py-6">Sinh viên</th>
                        <th class="px-8 py-6">Đề tài đồ án</th>
                        <th class="px-8 py-6">Trạng thái</th>
                        <th class="px-8 py-6 text-center">Báo cáo mới nhất</th>
                        <th class="px-8 py-6">Điểm PB</th>
                        <th class="px-8 py-6 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="studentTable" class="divide-y divide-slate-50">
                    <!-- Dynamic content from scoreFeedback.js -->
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- PREMIUM MODAL OVERLAY -->
<div id="modal" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center p-4 bg-slate-900/40 backdrop-blur-md">
    <div class="bg-white w-full max-w-md p-10 rounded-[3rem] shadow-2xl relative z-10 animate-in zoom-in duration-300 transform scale-100">
        <button id="closeModalBtn" class="absolute top-6 right-6 w-10 h-10 bg-slate-50 text-slate-400 hover:text-slate-900 rounded-full flex items-center justify-center transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="text-center mb-10">
            <div class="w-20 h-20 rounded-[2rem] bg-purple-50 text-purple-500 flex items-center justify-center text-3xl font-black mx-auto mb-6 shadow-inner border-4 border-white">
                🖋️
            </div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight">Chấm phản biện</h2>
            <p id="studentName" class="text-sm font-bold text-purple-600 mt-2">Nguyễn Văn A</p>
        </div>

        <div class="space-y-6">
            <div id="projectDetailArea" class="p-5 bg-indigo-50/50 border border-indigo-100 rounded-2xl text-[11px] font-medium text-indigo-900 hidden">
                <p class="uppercase font-black text-[9px] text-indigo-400 tracking-widest mb-2">Nội dung đồ án:</p>
                <div id="projectText" class="line-clamp-6 italic leading-relaxed"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1 block">Điểm (0-10)</label>
                    <input id="scoreInput" type="number" min="0" max="10" step="0.1" placeholder="8.5"
                        class="w-full bg-slate-50 border-2 border-transparent focus:border-purple-500 focus:bg-white rounded-2xl p-4 text-2xl font-black text-slate-700 outline-none transition-all shadow-inner text-center">
                </div>
                <div class="flex items-end">
                    <button id="toggleDetailBtn" class="w-full py-4 bg-white border border-slate-200 text-slate-500 font-bold text-[10px] uppercase tracking-widest rounded-2xl hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                        <span>Chi tiết Đồ án</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                    </button>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1 block">Nhận xét phản biện</label>
                <textarea id="commentInput" rows="3" placeholder="Góp ý cho sinh viên và giải trình về mức điểm..."
                    class="w-full bg-slate-50 border-2 border-transparent focus:border-purple-500 focus:bg-white rounded-2xl p-5 text-sm font-medium text-slate-700 outline-none transition-all shadow-inner resize-none"></textarea>
            </div>
            
            <p class="text-[10px] text-slate-400 font-bold text-center leading-relaxed">Ghi chú: Nhận xét này sẽ giúp sinh viên và Hội đồng hiểu rõ các điểm cần cải thiện.</p>
        </div>

        <button id="saveScoreBtn" class="mt-10 w-full py-5 bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-black rounded-3xl transition-all hover:scale-105 shadow-xl shadow-purple-200">
            LƯU ĐIỂM PHẢN BIỆN
        </button>
    </div>
</div>
