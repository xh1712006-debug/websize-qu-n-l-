<div class="space-y-10 animate-in">
    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                📝 Real-time Minutes Recording
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Lập Biên bản Bảo vệ</h1>
            <p class="text-slate-500 font-medium italic">Ghi lại các câu hỏi của Hội đồng và câu trả lời của sinh viên trong phiên bảo vệ.</p>
        </div>
        <button onclick="fetchStudents()" class="p-4 bg-white border border-slate-100 rounded-2xl text-slate-400 hover:text-indigo-600 transition-all shadow-sm group">
            <svg class="w-6 h-6 transform group-hover:rotate-180 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </button>
    </div>

    <!-- MAIN GRID -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        <!-- STUDENT LIST -->
        <div class="lg:col-span-4 space-y-6">
            <div class="flex items-center justify-between px-4">
                <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Danh sách bảo vệ</h4>
                <div class="px-2 py-0.5 bg-slate-100 rounded text-[8px] font-bold text-slate-400" id="student-count-badge">-- SV</div>
            </div>
            
            <div id="student-list" class="space-y-4 max-h-[70vh] overflow-y-auto pr-4 custom-scrollbar">
                <!-- Skeleton Loading -->
                <div class="p-6 bg-white border border-slate-50 rounded-[2rem] animate-pulse">
                    <div class="flex justify-between items-center">
                        <div class="space-y-2 w-2/3">
                            <div class="h-3 bg-slate-100 rounded-full w-full"></div>
                            <div class="h-2 bg-slate-50 rounded-full w-1/2"></div>
                        </div>
                        <div class="w-8 h-8 bg-slate-50 rounded-xl"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- EDITOR AREA -->
        <div id="editor-area" class="lg:col-span-8 bg-white rounded-[3.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-12 hidden relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-indigo-600"></div>
            <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-50 rounded-full blur-3xl -mr-32 -mt-32 opacity-40"></div>
            
            <div class="relative z-10 space-y-12">
                <!-- Student Identity Header -->
                <div class="flex items-start justify-between">
                    <div class="space-y-2">
                        <div class="inline-flex items-center gap-2 px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded text-[9px] font-black uppercase tracking-widest">
                            Đang thực hiện
                        </div>
                        <h3 id="edit-student-name" class="text-3xl font-black text-slate-900 uppercase tracking-tight leading-none">--</h3>
                        <p id="edit-student-code" class="text-xs text-indigo-500 font-bold uppercase tracking-widest">--</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Điểm TB hiện tại</p>
                        <div class="flex items-baseline justify-end gap-1">
                            <span id="display-final-score" class="text-4xl font-black text-slate-900">--</span>
                            <span class="text-xs font-bold text-slate-300">/10</span>
                        </div>
                    </div>
                </div>

                <!-- PROJECT TITLE -->
                <div class="p-6 bg-slate-50 rounded-[2rem] border border-slate-100">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-2 font-mono">Project Topic</p>
                    <p id="edit-project-name" class="text-sm font-bold text-slate-700 italic">--</p>
                </div>

                <!-- QUESTIONS & ANSWERS -->
                <div class="space-y-8">
                    <div class="flex items-center justify-between border-b border-slate-100 pb-4">
                        <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest flex items-center gap-3">
                            <span class="w-8 h-8 bg-indigo-600 text-white rounded-xl flex items-center justify-center text-[10px]">Q</span>
                            Biên bản Hỏi & Đáp
                        </h4>
                        <button onclick="addQuestion()" class="px-5 py-2.5 bg-indigo-50 text-indigo-600 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-indigo-600 hover:text-white transition-all shadow-sm">
                            + Thêm Câu hỏi
                        </button>
                    </div>

                    <div id="questions-container" class="space-y-6">
                        <!-- Questions will be dynamically added here -->
                    </div>
                </div>

                <!-- CONCLUSION -->
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 bg-slate-900 text-white rounded-xl flex items-center justify-center text-[10px]">C</span>
                        <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest">Kết luận chung của Hội đồng</h4>
                    </div>
                    <textarea id="edit-conclusion" rows="5" class="w-full px-8 py-8 bg-slate-50 border border-slate-100 rounded-[2.5rem] text-sm font-bold focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all resize-none shadow-inner" placeholder="Nhập tóm tắt kết luận của hội đồng sau buổi bảo vệ..."></textarea>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="pt-6 grid grid-cols-2 gap-6">
                    <button onclick="submitMinutes()" class="py-6 bg-emerald-600 text-white rounded-[2.5rem] font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-emerald-200 hover:bg-emerald-700 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                        Lưu Biên bản
                    </button>
                    <button onclick="synthesizeAndRefresh()" class="py-6 bg-slate-900 text-white rounded-[2.5rem] font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-slate-200 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path></svg>
                        Tổng hợp Điểm
                    </button>
                </div>
            </div>
        </div>

        <!-- EMPTY STATE / PLACEHOLDER -->
        <div id="editor-placeholder" class="lg:col-span-8 bg-white rounded-[3.5rem] border-2 border-dashed border-slate-100 flex flex-col items-center justify-center p-20 text-center animate-in fade-in zoom-in duration-700">
            <div class="w-24 h-24 bg-slate-50 rounded-[2.5rem] flex items-center justify-center text-5xl mb-8 shadow-inner">📋</div>
            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight">Chưa chọn Sinh viên</h3>
            <p class="text-slate-400 font-medium mt-4 max-w-sm uppercase text-[10px] tracking-widest leading-loose">Vui lòng chọn một sinh viên từ bảng điều khiển bên trái để bắt đầu lập biên bản phiên bảo vệ hội đồng.</p>
        </div>
    </div>
</div>

{{#section 'script'}}
<script>
    let currentStudentId = null;
    let currentQuestions = [];

    async function fetchStudents() {
        try {
            const res = await fetch('/teacher/secretary/api/students');
            const data = await res.json();
            const list = document.getElementById('student-list');
            document.getElementById('student-count-badge').innerText = `${data.length} SV`;
            
            list.innerHTML = data.map(s => {
                const isSelected = currentStudentId === s.studentId;
                const hasScore = s.finalScore != null;
                const hasMinutes = s.defenseQuestions.length > 0;

                return `
                <div onclick="selectStudent('${s.studentId}', '${s.fullName}', '${s.studentCode}', '${s.projectName}', '${s.finalScore || '--'}', ${JSON.stringify(s.defenseQuestions).replace(/"/g, '&quot;')}, '${(s.defenseConclusion || '').replace(/'/g, "\\'")}')" 
                    class="group p-6 rounded-[2.5rem] border transition-all duration-300 cursor-pointer ${isSelected ? 'bg-indigo-600 border-indigo-600 text-white shadow-xl shadow-indigo-100 ring-8 ring-indigo-50' : 'bg-white border-slate-50 hover:border-indigo-200 shadow-sm'}">
                    <div class="flex items-center justify-between">
                        <div class="flex-1 min-w-0">
                            <h4 class="text-xs font-black uppercase tracking-tight truncate ${isSelected ? 'text-white' : 'text-slate-900'}">${s.fullName}</h4>
                            <div class="flex items-center gap-2 mt-1">
                                <p class="text-[9px] font-bold uppercase tracking-widest ${isSelected ? 'text-indigo-200' : 'text-indigo-400'}">${s.studentCode}</p>
                                ${hasMinutes ? '<span class="w-1 h-1 rounded-full bg-emerald-400"></span>' : ''}
                                ${hasMinutes ? '<span class="text-[8px] font-black uppercase tracking-tighter text-emerald-400">Biên bản OK</span>' : ''}
                            </div>
                        </div>
                        <div class="text-right ml-4">
                            <div class="text-xs font-black ${isSelected ? 'text-white' : (hasScore ? 'text-indigo-600' : 'text-slate-200')}">
                                ${s.finalScore || '--'}
                            </div>
                            <div class="text-[7px] font-black uppercase tracking-tighter ${isSelected ? 'text-indigo-200' : 'text-slate-400'}">Final Score</div>
                        </div>
                    </div>
                </div>
            `}).join('');
        } catch (err) { console.error(err); }
    }

    function selectStudent(id, name, code, projectName, finalScore, questions, conclusion) {
        currentStudentId = id;
        currentQuestions = questions || [];
        
        document.getElementById('editor-placeholder').classList.add('hidden');
        document.getElementById('editor-area').classList.remove('hidden');
        
        document.getElementById('edit-student-name').innerText = name;
        document.getElementById('edit-student-code').innerText = code;
        document.getElementById('edit-project-name').innerText = projectName;
        document.getElementById('display-final-score').innerText = finalScore;
        document.getElementById('edit-conclusion').value = conclusion || '';

        renderQuestions();
        fetchStudents(); // Highlight active
    }

    function renderQuestions() {
        const container = document.getElementById('questions-container');
        if (currentQuestions.length === 0) {
            container.innerHTML = `
                <div class="p-12 border-2 border-dashed border-slate-100 rounded-[2.5rem] text-center space-y-3">
                    <p class="text-xs font-black text-slate-300 uppercase tracking-widest">Chưa có câu hỏi nào</p>
                    <button onclick="addQuestion()" class="text-[10px] font-black text-indigo-500 hover:text-indigo-600 uppercase tracking-widest">+ Bấm để thêm câu hỏi đầu tiên</button>
                </div>
            `;
            return;
        }

        container.innerHTML = currentQuestions.map((q, index) => `
            <div class="p-8 bg-slate-50 border border-slate-100 rounded-[2.5rem] space-y-6 relative group animate-in slide-in-from-top-4 duration-300">
                <button onclick="removeQuestion(${index})" class="absolute top-6 right-6 w-8 h-8 bg-white border border-slate-100 text-slate-300 hover:text-rose-500 hover:border-rose-100 rounded-xl flex items-center justify-center transition-all shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Người hỏi (Hội đồng)</label>
                        <input type="text" value="${q.asker || ''}" onchange="updateQuestion(${index}, 'asker', this.value)" class="w-full px-5 py-3 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:ring-4 focus:ring-indigo-500/5 focus:border-indigo-500 outline-none transition-all shadow-sm" placeholder="VD: GVPB Nguyễn Văn A">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Nội dung câu hỏi</label>
                        <input type="text" value="${q.question || ''}" onchange="updateQuestion(${index}, 'question', this.value)" class="w-full px-5 py-3 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:ring-4 focus:ring-indigo-500/5 focus:border-indigo-500 outline-none transition-all shadow-sm" placeholder="Nhập câu hỏi...">
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Sinh viên trả lời</label>
                    <textarea onchange="updateQuestion(${index}, 'answer', this.value)" class="w-full px-6 py-4 bg-white border border-slate-200 rounded-[1.5rem] text-xs font-bold focus:ring-4 focus:ring-indigo-500/5 focus:border-indigo-500 outline-none transition-all shadow-sm resize-none" rows="3" placeholder="Nhập tóm tắt câu trả lời...">${q.answer || ''}</textarea>
                </div>
            </div>
        `).join('');
    }

    function addQuestion() {
        currentQuestions.push({ asker: '', question: '', answer: '' });
        renderQuestions();
    }

    function updateQuestion(index, field, value) {
        currentQuestions[index][field] = value;
    }

    function removeQuestion(index) {
        currentQuestions.splice(index, 1);
        renderQuestions();
    }

    async function submitMinutes() {
        if (!currentStudentId) return;
        const conclusion = document.getElementById('edit-conclusion').value;
        
        try {
            const res = await fetch('/teacher/council/submitMinutes', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    studentId: currentStudentId, 
                    questions: currentQuestions,
                    conclusion: conclusion
                })
            });
            const data = await res.json();
            if (data.success) {
                // Show success toast (simulated by alert here)
                alert('Đã lưu biên bản thành công!');
                fetchStudents();
            } else {
                alert(data.message);
            }
        } catch (err) { console.error(err); }
    }

    async function synthesizeAndRefresh() {
        if (!currentStudentId) return;
        try {
            const res = await fetch('/teacher/council/synthesizeScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId: currentStudentId })
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('display-final-score').innerText = data.finalScore;
                alert('Đã tổng hợp điểm trung bình!');
                fetchStudents();
            } else {
                alert(data.message);
            }
        } catch (err) { console.error(err); }
    }

    // Initial load
    fetchStudents();
</script>
{{/section}}
