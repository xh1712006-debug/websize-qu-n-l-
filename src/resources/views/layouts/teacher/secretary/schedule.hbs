<div class="space-y-10 animate-in">
    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-amber-50 text-amber-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                📅 Council Defense Schedule
            </div>
            <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight">Lịch Bảo vệ Hội đồng</h1>
            <p class="text-slate-500 font-medium italic">Theo dõi lộ trình bảo vệ chính thức của tất cả sinh viên thuộc hội đồng của bạn.</p>
        </div>
        {{#if myCouncil}}
        <div class="flex items-center gap-3 p-2 bg-white border border-slate-100 rounded-3xl shadow-sm">
            <div class="w-12 h-12 bg-amber-500 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-amber-200">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div class="pr-6">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Phiên làm việc</p>
                <p class="text-sm font-black text-slate-900 truncate max-w-[150px]">{{myCouncil.councilName}}</p>
            </div>
        </div>
        {{/if}}
    </div>

    {{#if noCouncil}}
    <div class="bg-white rounded-[3.5rem] border border-slate-100 shadow-sm p-20 text-center space-y-6">
        <div class="w-24 h-24 bg-slate-50 rounded-[2.5rem] flex items-center justify-center text-5xl mx-auto">🏝️</div>
        <div class="space-y-2">
            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight">Chưa có lịch hội đồng</h3>
            <p class="text-slate-500 font-medium max-w-sm mx-auto">Bạn chưa được gán vào lịch bảo vệ hội đồng nào trong đợt này.</p>
        </div>
    </div>
    {{else}}

    <!-- TIMELINE CONTAINER -->
    <div class="bg-white rounded-[3.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-amber-50 rounded-full blur-3xl -mr-48 -mt-48 opacity-40"></div>
        
        <div class="relative z-10 space-y-12">
            <!-- Council Summary -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-10 border-b border-slate-50">
                <div class="space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Phòng bảo vệ</p>
                    <div class="flex items-center gap-3">
                        <span class="w-10 h-10 bg-slate-900 text-white rounded-xl flex items-center justify-center text-xs font-black shadow-lg shadow-slate-200">
                            {{#if schedules.0.defenseRoom}}{{schedules.0.defenseRoom}}{{else}}--{{/if}}
                        </span>
                        <p class="text-lg font-black text-slate-900 uppercase tracking-tight">Main Defense Hall</p>
                    </div>
                </div>
                <div class="space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Ngày bảo vệ</p>
                    <p class="text-lg font-black text-slate-900 uppercase tracking-tight">
                        {{#if schedules.0.defenseDate}}{{formatDate schedules.0.defenseDate}}{{else}}Chưa ấn định{{/if}}
                    </p>
                </div>
                <div class="space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Chủ tịch Hội đồng</p>
                    <p class="text-lg font-black text-indigo-600 uppercase tracking-tight">{{myCouncil.chairmanId.fullName}}</p>
                </div>
            </div>

            <!-- THE LIST -->
            <div class="space-y-8">
                <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest flex items-center gap-3">
                    <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span> Thứ tự bảo vệ chi tiết
                </h4>

                <div class="space-y-6">
                    {{#each schedules}}
                    <div class="p-8 bg-slate-50/50 border border-slate-100 rounded-[2.5rem] group hover:bg-white hover:border-amber-200 hover:shadow-xl hover:shadow-amber-500/5 transition-all duration-500 relative">
                        <!-- Time indicator -->
                        <div class="absolute -left-3 top-1/2 -translate-y-1/2 w-6 h-12 bg-amber-500 rounded-full flex items-center justify-center text-[10px] font-black text-white shadow-lg shadow-amber-200 opacity-0 group-hover:opacity-100 transition-all">
                            {{math @index "+" 1}}
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
                            <!-- TIME SLOT -->
                            <div class="lg:col-span-2 text-center lg:text-left">
                                <p class="text-2xl font-black text-slate-900 tracking-tight">{{#if this.defenseTime}}{{this.defenseTime}}{{else}}--:--{{/if}}</p>
                                <p class="text-[9px] font-black text-amber-600 uppercase tracking-widest mt-1">Khung giờ</p>
                            </div>

                            <!-- STUDENT INFO -->
                            <div class="lg:col-span-4 flex items-center gap-5">
                                <div class="w-14 h-14 bg-white border border-slate-100 rounded-2xl flex items-center justify-center text-slate-900 font-black text-sm shadow-sm group-hover:bg-amber-50 group-hover:border-amber-100 transition-all">
                                    {{substring this.studentName 0 1}}
                                </div>
                                <div class="min-w-0">
                                    <h5 class="text-sm font-black text-slate-900 uppercase tracking-tight truncate">{{this.studentName}}</h5>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">{{this.studentCode}}</p>
                                </div>
                            </div>

                            <!-- TOPIC -->
                            <div class="lg:col-span-4 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <p class="text-[9px] font-black text-amber-600 uppercase tracking-widest">{{this.councilName}}</p>
                                    <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest italic">Tên đề tài</p>
                                </div>
                                <p class="text-xs font-bold text-slate-700 leading-relaxed truncate group-hover:text-slate-900">"{{this.projectName}}"</p>
                            </div>

                            <!-- ACTIONS / STATUS -->
                            <div class="lg:col-span-2 text-right">
                                <a href="/teacher/secretary/minutes" class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-slate-100 rounded-xl text-[9px] font-black text-slate-400 uppercase tracking-widest group-hover:bg-slate-900 group-hover:text-white group-hover:border-slate-900 transition-all shadow-sm">
                                    Biên bản <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    {{/each}}

                    {{#unless schedules}}
                    <div class="p-16 border-2 border-dashed border-slate-100 rounded-[3rem] text-center space-y-4">
                        <p class="text-4xl text-slate-200">⏳</p>
                        <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Đang chờ Admin xếp lịch chi tiết cho hội đồng...</p>
                    </div>
                    {{/unless}}
                </div>
            </div>
        </div>
    </div>
    {{/if}}
</div>
