<div class="space-y-10 animate-in fade-in slide-in-from-bottom-6 duration-700">

    <!-- HEADER SECTION -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Sinh viên Hướng dẫn</h1>
            <p class="text-slate-500 font-medium mt-1">Quản lý và theo dõi tiến độ các sinh viên được phân công</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="px-4 py-2 bg-white rounded-2xl shadow-sm border border-slate-100 font-bold text-xs text-indigo-600">
                {{data.length}} sinh viên đang theo dõi
            </span>
        </div>
    </div>

    <!-- STUDENT LIST GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        {{#each data}}
        <!-- PREMIUM STUDENT CARD -->
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 group hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-slate-50 rounded-full -mr-16 -mt-16 group-hover:bg-indigo-50 transition-colors"></div>
            
            <div class="flex items-center gap-4 mb-8 relative z-10">
                <div class="w-14 h-14 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center text-lg font-black shadow-inner group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                    {{substring fullName 0 1}}
                </div>
                <div>
                    <h3 class="font-black text-slate-900 tracking-tight text-lg">{{fullName}}</h3>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">{{studentCode}}</p>
                </div>
            </div>

            <div class="space-y-4 mb-8 flex-1 relative z-10">
                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 group-hover:border-indigo-100 transition-colors">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Đề tài đang thực hiện</p>
                    <p class="text-sm font-bold text-slate-700 leading-snug line-clamp-2" title="{{projectName}}">{{projectName}}</p>
                </div>
                <div class="flex items-center justify-between px-2">
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Trạng thái</span>
                    <div class="flex flex-col items-end gap-1">
                        {{#if isAdvisorApproved}}
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-wider border border-emerald-100 bg-emerald-50 text-emerald-600">
                                ✅ Đã chốt ĐK
                            </span>
                        {{else if isRejected}}
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-wider border border-rose-100 bg-rose-50 text-rose-600">
                                ❌ Đã từ chối
                            </span>
                        {{else if isReadyToApprove}}
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-wider border border-amber-100 bg-amber-50 text-amber-600 animate-pulse">
                                ✨ Sẵn sàng duyệt
                            </span>
                        {{else}}
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-wider border border-slate-100 bg-slate-50 text-slate-400 italic">
                                Đang thực hiện
                            </span>
                        {{/if}}
                    </div>
                </div>
            </div>

            <!-- PROGRESS BAR UNIT -->
            <div class="mb-8 relative z-10 px-2 space-y-2">
                <div class="flex justify-between items-center">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tiến độ kỳ hạn</span>
                    <span class="text-sm font-black text-slate-900">{{percent}}%</span>
                </div>
                <div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden p-0.5">
                    <div class="h-full rounded-full transition-all duration-1000 {{barColor}}" style="width: {{percent}}%"></div>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="grid grid-cols-2 gap-3 relative z-10">
                <button onclick="openStudentModal('{{fullName}}', '{{studentCode}}', '{{studentEmail}}', '{{phont}}', '{{projectName}}')"
                   class="py-3 bg-slate-900 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-600 transition-colors shadow-lg shadow-slate-200">
                    Hồ sơ SV
                </button>
                <button onclick="openProjectModal('{{projectName}}', '{{projectDesc}}', '{{projectTech}}', '{{percent}}')"
                   class="py-3 bg-indigo-50 text-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-600 hover:text-white transition-all border border-indigo-100">
                    Đồ án
                </button>
            </div>
        </div>
        {{/each}}

        {{^data}}
        <div class="col-span-full py-24 text-center bg-white rounded-[3rem] border border-dashed border-slate-200">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl opacity-50">👥</div>
            <h3 class="text-2xl font-black text-slate-900">Danh sách trống</h3>
            <p class="text-slate-500 font-medium mt-2">Chưa có sinh viên nào đăng ký và được duyệt trong danh sách của bạn.</p>
        </div>
        {{/data}}

    </div>
</div>

<!-- STUDENT MODAL (PREMIUM) -->
<div id="studentModal" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-md transition-opacity" onclick="closeModal('studentModal')"></div>
    <div class="bg-white w-full max-w-md p-10 rounded-[3rem] shadow-2xl relative z-10 transform scale-95 transition-all duration-300" id="studentModalContent">
        <button onclick="closeModal('studentModal')" class="absolute top-6 right-6 w-10 h-10 bg-slate-50 text-slate-400 hover:text-slate-900 rounded-full flex items-center justify-center transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <div class="text-center mb-10">
            <div class="w-24 h-24 rounded-[2.5rem] bg-indigo-50 text-indigo-500 flex items-center justify-center text-4xl font-black mx-auto mb-6 shadow-inner border-4 border-white">
                <span id="m_avatar">S</span>
            </div>
            <h2 id="m_stu_name" class="text-2xl font-black text-slate-900 tracking-tight">Tên Sinh Viên</h2>
            <p id="m_stu_code" class="text-[11px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-2">MSSV: </p>
        </div>

        <div class="space-y-6 text-sm">
            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                <span class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-xl shadow-sm">📧</span>
                <div class="flex-1 min-w-0">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Email liên hệ</p>
                    <p id="m_stu_email" class="font-bold text-slate-700 truncate"></p>
                </div>
            </div>
            <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                <span class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-xl shadow-sm">📱</span>
                <div class="flex-1">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Số điện thoại</p>
                    <p id="m_stu_phone" class="font-bold text-slate-700"></p>
                </div>
            </div>
            <div class="flex items-start gap-4 p-4 bg-indigo-50/50 rounded-2xl border border-indigo-100">
                <span class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-xl shadow-sm">📘</span>
                <div class="flex-1">
                    <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">Đề tài hiện tại</p>
                    <p id="m_stu_project" class="font-bold text-indigo-700 leading-snug line-clamp-2 mt-1"></p>
                </div>
            </div>
        </div>

        <button onclick="closeModal('studentModal')" class="mt-10 w-full py-4 bg-slate-900 text-white font-black rounded-2xl transition-all hover:bg-slate-800 shadow-xl shadow-slate-200">HOÀN TẤT</button>
    </div>
</div>

<!-- PROJECT MODAL (PREMIUM) -->
<div id="projectModal" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-md transition-opacity" onclick="closeModal('projectModal')"></div>
    <div class="bg-white w-full max-w-lg p-12 rounded-[3.5rem] shadow-2xl relative z-10 transform scale-95 transition-all duration-300" id="projectModalContent">
        <button onclick="closeModal('projectModal')" class="absolute top-8 right-8 w-10 h-10 bg-slate-50 text-slate-400 hover:text-slate-900 rounded-full flex items-center justify-center transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <h2 class="text-3xl font-black text-slate-900 flex items-center gap-4 mb-10">
            <span class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center text-2xl shadow-sm">📘</span>
            Chi tiết Đồ án
        </h2>
        
        <div class="space-y-8">
            <div class="space-y-2">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Tên đề tài đồ án</p>
                <p id="m_pro_name" class="text-xl font-black text-slate-900 leading-tight italic"></p>
            </div>

            <div class="space-y-4">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Mô tả và Yêu cầu</p>
                <div id="m_pro_desc" class="text-sm text-slate-600 bg-slate-50 p-6 rounded-[2rem] border border-slate-100 max-h-48 overflow-y-auto leading-relaxed italic font-medium"></div>
            </div>

            <div class="grid grid-cols-2 gap-8 items-end">
                <div class="space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Công nghệ sử dụng</p>
                    <div id="m_pro_tech" class="text-sm font-black text-indigo-600 bg-indigo-50 px-5 py-2.5 inline-block rounded-xl border border-indigo-100 uppercase tracking-widest"></div>
                </div>
                <div class="text-right">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2 mr-1">Tiến độ tổng thể</p>
                    <div class="flex items-center justify-end gap-3 px-1">
                        <span id="m_pro_percent" class="text-4xl font-black text-emerald-600 tracking-tighter">0%</span>
                        <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-xl shadow-inner border border-emerald-100">🚀</div>
                    </div>
                </div>
            </div>
        </div>
        
        <button onclick="closeModal('projectModal')" class="mt-12 w-full py-5 bg-emerald-600 text-white font-black rounded-3xl transition-all hover:bg-emerald-700 shadow-[0_15px_30px_rgba(16,185,129,0.3)] hover:shadow-[0_20px_40px_rgba(16,185,129,0.4)]">QUAY LẠI TRANG CHỦ</button>
    </div>
</div>

<style>
    #studentModalContent, #projectModalContent {
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .hidden #studentModalContent, .hidden #projectModalContent {
        transform: scale(0.9) translateY(20px);
    }
</style>
