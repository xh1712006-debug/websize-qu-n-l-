<div class="animate-in pb-20">
    <!-- PAGE HEADER -->
    <div class="mb-12 flex flex-col xl:flex-row xl:items-end justify-between gap-8">
        <div class="space-y-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 text-indigo-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 00-1-1H6zM4 8h12v9H4V8zm5-4h2v2H9V4z"></path></svg>
                Trung tâm Điều phối Hội đồng
            </div>
            <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight">Lịch bảo vệ <span class="text-indigo-600">Sinh viên</span></h1>
            <p class="text-slate-500 font-medium italic">Theo dõi toàn diện thời gian, địa điểm và hội đồng chấm cho các sinh viên bạn đang hướng dẫn.</p>
        </div>

        {{#if activePeriod}}
        <div class="flex-1 max-w-xl">
             <div class="px-6 py-4 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-[2rem] shadow-xl shadow-indigo-100 flex items-center justify-between text-white overflow-hidden relative group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 relative z-10">
                    <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center text-xl backdrop-blur-md border border-white/20">
                        📅
                    </div>
                    <div>
                        <p class="text-[8px] font-black uppercase tracking-[0.2em] text-indigo-100 mb-0.5">Đợt đăng ký hiện tại</p>
                        <h4 class="text-sm font-black uppercase tracking-tight">{{activePeriod.name}}</h4>
                    </div>
                </div>
                <div class="flex items-center gap-2 relative z-10 bg-white/20 px-3 py-1.5 rounded-xl border border-white/20">
                    <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                    <span class="text-[9px] font-black uppercase tracking-widest">Đang hoạt động</span>
                </div>
             </div>
        </div>
        {{/if}}

        <div class="flex items-center gap-4">
             <div class="px-8 py-5 bg-white rounded-3xl border border-slate-100 shadow-sm transition-all hover:border-indigo-100 flex items-center gap-6">
                <div class="text-center">
                    <p class="text-[9px] font-black text-slate-300 uppercase tracking-widest mb-1">Tổng SV</p>
                    <p class="text-xl font-black text-slate-900 leading-none">{{stats.total}}</p>
                </div>
                <div class="w-[1px] h-6 bg-slate-100"></div>
                <div class="text-center">
                    <p class="text-[9px] font-black text-slate-300 uppercase tracking-widest mb-1 italic">Đã có lịch</p>
                    <p class="text-xl font-black text-indigo-600 leading-none">{{stats.scheduled}}</p>
                </div>
             </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="flex flex-wrap gap-4 mb-10">
        <button onclick="switchTab('finished')" id="tab-finished" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-slate-900"></span>
            Lịch bảo vệ (Đã xếp)
            <span id="count-finished" class="ml-2 px-2 py-0.5 bg-slate-100 text-slate-700 rounded-md text-[8px]">0</span>
        </button>
        <button onclick="switchTab('pending')" id="tab-pending" class="tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2">
            <span class="w-2 h-2 rounded-full bg-amber-500"></span>
            Chờ xếp lịch
            <span id="count-pending" class="ml-2 px-2 py-0.5 bg-amber-100 text-amber-700 rounded-md text-[8px]">0</span>
        </button>
    </div>

    <!-- TIMELINE CONTAINER -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="scheduleTimeline">
        <!-- Injected by JS -->
    </div>

    <!-- EMPTY STATE -->
    <div id="emptySchedule" class="hidden py-40 text-center bg-white rounded-[4rem] border border-dashed border-slate-200">
        <div class="w-32 h-32 bg-slate-50 rounded-[3rem] flex items-center justify-center mx-auto mb-8 text-6xl opacity-30">🗓️</div>
        <h3 class="text-2xl font-black text-slate-300 uppercase tracking-widest">Không có lịch bảo vệ</h3>
        <p class="text-slate-400 font-medium mt-3 italic tracking-wide">Hiện không tìm thấy buổi bảo vệ nào trong mục này.</p>
    </div>

</div>

<!-- SCRIPTS -->
<script>
    const scheduleData = {{{json projects}}};
    let currentTab = 'finished';

    function init() {
        const items = scheduleData.map(item => {
            if (!item.defenseDate) {
                return { ...item, category: 'pending' };
            }
            return {
                ...item,
                category: 'finished',
                sortDate: new Date(item.defenseDate).getTime()
            };
        });

        const categories = {
            finished: items.filter(i => i.category === 'finished').sort((a,b) => b.sortDate - a.sortDate),
            pending: items.filter(i => i.category === 'pending')
        };

        document.getElementById('count-finished').innerText = categories.finished.length;
        document.getElementById('count-pending').innerText = categories.pending.length;

        renderTimeline(categories);
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.className = 'tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 bg-slate-50 border-slate-50 text-slate-400';
        });

        const activeBtn = document.getElementById(`tab-${tab}`);
        const colorClass = tab === 'finished' ? 'border-slate-900 text-slate-900' : 
                          'border-amber-500 text-amber-600';
        activeBtn.className = `tab-btn flex items-center gap-3 px-8 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm border-2 bg-white ${colorClass}`;

        init();
    }

    function renderTimeline(categories) {
        const container = document.getElementById('scheduleTimeline');
        const emptyState = document.getElementById('emptySchedule');
        const data = categories[currentTab];

        if (data.length === 0) {
            container.classList.add('hidden');
            emptyState.classList.remove('hidden');
            return;
        }

        container.classList.remove('hidden');
        emptyState.classList.add('hidden');

        container.innerHTML = data.map((item, index) => {
            const dateStr = item.defenseDate ? new Date(item.defenseDate).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' }) : 'N/A';
            const isPending = currentTab === 'pending';
            
            return `
            <div class="group relative bg-white p-10 rounded-[3.5rem] border border-slate-100 shadow-[0_10px_40px_rgba(0,0,0,0.02)] hover:shadow-[0_40px_80px_rgba(79,70,229,0.08)] hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">
                <!-- TOP DECORATION -->
                <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50/40 rounded-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-700"></div>
                
                <!-- HEADER: STUDENT IDENTITY -->
                <div class="flex items-start justify-between mb-8 relative z-10">
                    <div class="flex items-center gap-5">
                        <div class="w-16 h-16 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-black italic text-xl shadow-lg group-hover:rotate-[10deg] transition-transform duration-500 shadow-slate-200">
                            ${item.studentName.charAt(0)}
                        </div>
                        <div>
                            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight flex items-center gap-2 group-hover:text-indigo-600 transition-colors">
                                ${item.studentName}
                            </h3>
                            <span class="inline-block mt-2 px-3 py-1 bg-slate-100 text-slate-500 text-[9px] font-black uppercase tracking-widest rounded-lg border border-slate-200/50">
                                MSSV: ${item.studentCode}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- PROJECT BOARD (ELITE STYLE) -->
                <div class="flex-1 space-y-6 relative z-10">
                    <div class="p-8 bg-slate-50/50 backdrop-blur-sm border border-slate-100 rounded-[2.5rem] group-hover:bg-white group-hover:border-indigo-100 transition-all duration-500">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.3em] mb-4 leading-none italic border-l-4 border-indigo-500 pl-3">Tên đề tài đồ án</p>
                        <h4 class="text-base font-black text-slate-800 leading-relaxed uppercase tracking-tight">${item.inputProject}</h4>
                    </div>

                    <!-- REVIEWER SEAL -->
                    <div class="flex items-center gap-4 px-4">
                        <div class="w-10 h-10 bg-indigo-50 text-indigo-500 rounded-xl flex items-center justify-center text-lg shadow-inner">
                            👤
                        </div>
                        <div class="flex-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1 text-transparent bg-clip-text bg-gradient-to-r from-slate-400 to-slate-500">GVPB Thẩm định</p>
                            <p class="text-xs font-black text-slate-700 uppercase italic underline decoration-indigo-200 underline-offset-4 decoration-2">${item.reviewerName}</p>
                        </div>
                    </div>
                </div>

                <!-- FOOTER: SCHEDULE & COUNCIL -->
                <div class="mt-10 pt-10 border-t border-slate-50 relative z-10">
                    ${isPending ? `
                        <div class="flex items-center gap-4 p-5 bg-amber-50/50 rounded-[2rem] border border-dashed border-amber-200">
                            <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-xl shadow-sm">⏳</div>
                            <div>
                                <p class="text-[10px] font-black text-amber-600 uppercase tracking-widest leading-none mb-1">Trạng thái</p>
                                <p class="text-[11px] font-bold text-amber-500 uppercase italic">Đang chờ bộ môn xếp lịch...</p>
                            </div>
                        </div>
                    ` : `
                        <div class="flex items-center justify-between">
                            <div class="space-y-4">
                                <div class="flex items-center gap-3">
                                    <span class="w-10 h-10 bg-indigo-600 text-white rounded-xl flex items-center justify-center shadow-lg shadow-indigo-100">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z"></path></svg>
                                    </span>
                                    <div>
                                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Thời gian</p>
                                        <p class="text-sm font-black text-slate-900">${dateStr} <span class="mx-2 text-indigo-500">•</span> ${item.defenseTime || '--:--'}</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <span class="w-10 h-10 bg-slate-900 text-white rounded-xl flex items-center justify-center shadow-lg shadow-slate-100">
                                        🏛️
                                    </span>
                                    <div>
                                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Phòng bảo vệ</p>
                                        <p class="text-sm font-black text-slate-900">${item.defenseRoom || 'Chưa gán'}</p>
                                    </div>
                                </div>
                            </div>

                            ${item.council ? `
                            <div class="group/council relative">
                                <div class="px-5 py-4 bg-indigo-50 text-indigo-600 rounded-2xl border border-indigo-100 cursor-help hover:bg-slate-900 hover:text-white transition-all duration-300">
                                    <span class="block text-[8px] font-black uppercase tracking-widest opacity-60 leading-none mb-1">Hội đồng</span>
                                    <span class="block text-xs font-black leading-none">${item.council.councilName.split(' ')[2] || 'Board'}</span>
                                </div>
                                
                                <!-- TOOLTIP HOVER -->
                                <div class="hidden group-hover/council:flex absolute bottom-full right-0 mb-4 bg-slate-900 text-white p-6 rounded-[2rem] shadow-2xl z-[100] flex-col gap-4 min-w-[280px] animate-in zoom-in duration-300">
                                    <p class="text-[10px] font-black text-indigo-400 uppercase tracking-[0.3em] border-b border-white/10 pb-2 italic">Thành phần hội đồng</p>
                                    <div class="space-y-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-indigo-500/20 text-indigo-400 flex items-center justify-center text-[10px] font-black italic">CT</div>
                                            <div><p class="text-[8px] text-white/40 uppercase">Chủ tịch</p><p class="text-xs font-black uppercase">${item.council.chairmanId.fullName}</p></div>
                                        </div>
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-[10px] font-black italic">TK</div>
                                            <div><p class="text-[8px] text-white/40 uppercase">Thư ký</p><p class="text-xs font-black uppercase">${item.council.secretaryId.fullName}</p></div>
                                        </div>
                                        <div>
                                            <p class="text-[8px] text-white/40 uppercase mb-2">Ủy viên chấm</p>
                                            <div class="flex flex-wrap gap-1.5">
                                                ${item.council.memberIds.map(m => `<span class="px-2.5 py-1 bg-white/10 rounded text-[9px] font-bold uppercase">${m.fullName}</span>`).join('')}
                                            </div>
                                        </div>
                                    </div>
                                    <div class="absolute bottom-[-10px] right-6 w-5 h-5 bg-slate-900 rotate-45"></div>
                                </div>
                            </div>
                            ` : ''}
                        </div>
                    `}
                </div>
            </div>
            `;
        }).join('');
    }

    init();
</script>

<style>
    .animate-in {
        animation: animate-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes animate-in {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
